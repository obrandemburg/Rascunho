<CascadingAuthenticationState> @* <--- ESSA LINHA É OBRIGATÓRIA *@
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <MudText>Você não tem permissão para acessar esta página.</MudText>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Não encontrado</PageTitle>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <MudText Typo="Typo.h4" Align="Align.Center">Desculpe, não há nada neste endereço.</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>