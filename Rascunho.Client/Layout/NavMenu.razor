@* ARQUIVO: Rascunho.Client/Layout/NavMenu.razor
   
   SPRINT 8:
   - Removido link /ingressos da seção Aluno (Eventos/Ingressos fora do MVP atual)
   - Adicionado link /admin/ritmos na seção Admin (Recepção + Gerente)
*@

@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

<MudNavMenu>

    @* ══════════════════════════════════════════════════════════════
       LINKS PÚBLICOS — Visíveis para todos (com ou sem login)
    ══════════════════════════════════════════════════════════════ *@
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Início
    </MudNavLink>
    <MudNavLink Href="/ritmos" Icon="@Icons.Material.Filled.MusicNote">
        Conheça os Ritmos
    </MudNavLink>
    <MudNavLink Href="/turmas" Icon="@Icons.Material.Filled.Groups">
        Conheça as Turmas
    </MudNavLink>

    @* ══════════════════════════════════════════════════════════════
       PERFIL — Visível para qualquer usuário autenticado
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="/perfil"
                        Icon="@Icons.Material.Filled.Person">
                Meu Perfil
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       ALUNO — Acesso exclusivo às telas de aluno (RN-ACE01)
       SPRINT 8: Removido link /ingressos (fora do MVP atual)
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Aluno">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4 py-1 mud-text-secondary">
                Minha Área
            </MudText>

            <MudNavLink Href="/minhas-aulas"
                        Icon="@Icons.Material.Filled.EventAvailable">
                Minhas Aulas
            </MudNavLink>

            <MudNavLink Href="/aulas-particulares"
                        Icon="@Icons.Material.Filled.PersonSearch">
                Aulas Particulares
            </MudNavLink>

            <MudNavLink Href="/quadro-avisos"
                        Icon="@Icons.Material.Filled.Campaign">
                Quadro de Avisos
            </MudNavLink>

            <MudNavLink Href="/reagendar"
                        Icon="@Icons.Material.Filled.EventRepeat">
                Reagendar Aula
            </MudNavLink>

            <MudNavLink Href="/aula-experimental"
                        Icon="@Icons.Material.Filled.Science">
                Aula Experimental
            </MudNavLink>

            @* SPRINT 8: link /ingressos removido daqui *@
        </Authorized>
    </AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       PROFESSOR — Acesso exclusivo às telas de professor (RN-ACE03)
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Professor">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4 py-1 mud-text-secondary">
                Professor
            </MudText>

            <MudNavLink Href="/professor/minhas-turmas"
                        Icon="@Icons.Material.Filled.School">
                Minhas Turmas
            </MudNavLink>

            <MudNavLink Href="/professor/chamada"
                        Icon="@Icons.Material.Filled.Checklist">
                Fazer Chamada
            </MudNavLink>

            <MudNavLink Href="/professor/aulas-particulares"
                        Icon="@Icons.Material.Filled.PersonSearch">
                Aulas Particulares
            </MudNavLink>

            <MudNavLink Href="/quadro-avisos"
                        Icon="@Icons.Material.Filled.Campaign">
                Quadro de Avisos
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       BOLSISTA — Acesso híbrido: telas de aluno + telas de equipe
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Bolsista">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.overline" Class="px-4 py-1 mud-text-secondary">
                Bolsista
            </MudText>

            <MudNavLink Href="/minhas-aulas"
                        Icon="@Icons.Material.Filled.EventAvailable">
                Minhas Aulas
            </MudNavLink>

            <MudNavLink Href="/bolsista/turmas-obrigatorias"
                        Icon="@Icons.Material.Filled.Today">
                Turmas Obrigatórias
            </MudNavLink>

            <MudNavLink Href="/bolsista/desempenho"
                        Icon="@Icons.Material.Filled.Insights">
                Meu Desempenho
            </MudNavLink>

            <MudNavLink Href="/aulas-particulares"
                        Icon="@Icons.Material.Filled.PersonSearch">
                Aulas Particulares
            </MudNavLink>

            <MudNavLink Href="/bolsista/turmas-recomendadas"
                        Icon="@Icons.Material.Filled.Recommend">
                Turmas Recomendadas
            </MudNavLink>

            <MudNavLink Href="/bolsista/minhas-habilidades"
                        Icon="@Icons.Material.Filled.Stars">
                Minhas Habilidades
            </MudNavLink>

            <MudNavLink Href="/bolsista/relatorio-horas"
                        Icon="@Icons.Material.Filled.Timer">
                Relatório de Horas
            </MudNavLink>

            <MudNavLink Href="/quadro-avisos"
                        Icon="@Icons.Material.Filled.Campaign">
                Quadro de Avisos
            </MudNavLink>
        </Authorized>
    </AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       RECEPÇÃO E GERENTE — Menu administrativo (RN-ACE04/05)
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Recepção,Gerente">
        <Authorized>
            <MudDivider Class="my-2" />
            <MudNavGroup Title="Administração"
                         Icon="@Icons.Material.Filled.AdminPanelSettings"
                         Expanded="true">
                <MudNavLink Href="/admin/usuarios"
                            Icon="@Icons.Material.Filled.PersonAdd">
                    Criar Usuário
                </MudNavLink>
                <MudNavLink Href="/admin/turmas"
                            Icon="@Icons.Material.Filled.ManageHistory">
                    Gerir Turmas
                </MudNavLink>
                <MudNavLink Href="/admin/salas"
                            Icon="@Icons.Material.Filled.MeetingRoom">
                    Salas & Aluguéis
                </MudNavLink>
                <MudNavLink Href="/admin/ritmos"
                            Icon="@Icons.Material.Filled.MusicNote">
                    Ritmos
                </MudNavLink>
                <MudNavLink Href="/admin/avisos"
                            Icon="@Icons.Material.Filled.Campaign">
                    Criar Avisos
                </MudNavLink>
                @* SPRINT Matrícula Admin *@
                <MudNavLink Href="/admin/matricular"
                            Icon="@Icons.Material.Filled.HowToReg">
                    Matricular Aluno
                </MudNavLink>
                <MudNavLink Href="/quadro-avisos"
                            Icon="@Icons.Material.Filled.Announcement">
                    Quadro de Avisos
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       GERENTE — Gerência Estratégica (exclusivo, RN-ACE05)
    ══════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Gerente">
        <Authorized>
            <MudNavGroup Title="Gerência Estratégica"
                         Icon="@Icons.Material.Filled.Insights"
                         Expanded="false">
                <MudNavLink Href="/gerencia/dashboard"
                            Icon="@Icons.Material.Filled.QueryStats">
                    Dashboard
                </MudNavLink>

                <MudNavLink Href="/gerencia/usuarios"
                            Icon="@Icons.Material.Filled.ManageAccounts">
                    Gestão de Usuários
                </MudNavLink>

                <MudNavLink Href="/gerencia/bolsistas"
                            Icon="@Icons.Material.Filled.Groups">
                    Desempenho Bolsistas
                </MudNavLink>
            </MudNavGroup>
        </Authorized>
    </AuthorizeView>

</MudNavMenu>
