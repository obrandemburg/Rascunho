@*
  FLUXO: MainLayout é o layout raiz. Ele envolve todas as páginas via @Body.
  MudThemeProvider aplica as cores globalmente via CSS Variables do MudBlazor.

  SEGURANÇA: AuthorizeView aqui controla o que aparece na AppBar dependendo
  do estado de autenticação. Nenhuma dado sensível fica exposto antes do login.

  ALTERAÇÃO: Foto de perfil no botão direito da AppBar.
  - Remove o botão de logout separado.
  - O MudMenu exibe foto/inicial, nome do usuário, Ver Perfil e Sair.
  - FotoUrl é carregada do LocalStorage (persistida pelo AuthService no login).

  CORREÇÃO: Subscrito AuthenticationStateChanged para recarregar _fotoUrl
  sempre que o estado de autenticação mudar (pós-login ou pós-logout),
  evitando que o avatar fique sem foto após login na mesma sessão.
  Sair() agora usa AuthService.LogoutAsync() para revogar o token no servidor.
*@

@inherits LayoutComponentBase
@implements IDisposable
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using Rascunho.Client.Security
@using Rascunho.Client.Services
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudThemeProvider Theme="@PontoDaDancaTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        @* INÍCIO DA ALTERAÇÃO: Logo + Nome da escola *@
        <img src="icon-192.png" alt="Logo Ponto da Dança" style="height: 40px; margin-left: 16px; margin-right: 8px;" />
        <MudText Typo="Typo.h5" Class="font-weight-bold">Ponto da Dança</MudText>
        @* FIM DA ALTERAÇÃO *@
        
        <MudSpacer />
        
        @*
          AuthorizeView renderiza filhos diferentes com base na autenticação.
          Authorized → usuário logado.
          NotAuthorized → visitante.
          Isso evita flash de conteúdo errado.
        *@
        <AuthorizeView>
            <Authorized Context="authContext">
                @*
                  ALTERAÇÃO: Botão de logout separado REMOVIDO.
                  O menu agora centraliza todas as ações do usuário:
                  foto de perfil, nome, Ver Perfil e Sair.
                *@
                @*
                  CORREÇÃO MudBlazor v9:
                  Em v9, ActivatorContent mudou de RenderFragment para RenderFragment<MenuContext>.
                  O menu NÃO abre mais automaticamente via ActivationEvent — é preciso chamar
                  context.ToggleAsync() explicitamente no evento de clique do elemento ativador.
                  A div wrapper captura o @onclick e repassa ao MenuContext.
                  style cursor:pointer indica ao usuário que o avatar é clicável.
                *@
                <MudMenu AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <div @onclick="context.ToggleAsync"
                             style="cursor: pointer; display: inline-flex; align-items: center;">
                            <UserAvatar FotoUrl="@_fotoUrl"
                                        Nome="@(authContext.User.Identity?.Name ?? "")"
                                        Size="Size.Medium"
                                        Color="Color.Secondary" />
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        @* Cabeçalho do menu: nome do usuário *@
                        <MudText Typo="Typo.subtitle2"
                                 Class="px-4 pt-3 pb-1 mud-text-secondary"
                                 Style="font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase;">
                            @authContext.User.Identity?.Name
                        </MudText>
                        <MudDivider Class="my-1" />
                        <MudMenuItem Href="/perfil"
                                     Icon="@Icons.Material.Filled.Person">
                            Ver perfil
                        </MudMenuItem>
                        <MudMenuItem OnClick="Sair"
                                     Icon="@Icons.Material.Filled.Logout">
                            Sair
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit"
                           Variant="Variant.Outlined"
                           Href="/login">
                    Entrar
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @*
      Drawer = gaveta lateral esquerda com a NavMenu.
      ClipMode.Always faz a gaveta deslizar sob a AppBar.
      @bind-Open faz two-way binding com _drawerOpen.
    *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-8 pb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    // URL da foto do usuário logado — carregada do LocalStorage após o login
    private string _fotoUrl = "";

    protected override async Task OnInitializedAsync()
    {
        // Recupera a foto do LocalStorage (foi salva pelo AuthService no login)
        _fotoUrl = await LocalStorage.GetItemAsync<string>("userFotoUrl") ?? "";

        // CORREÇÃO: Subscreve mudanças de autenticação para atualizar _fotoUrl
        // sem precisar recarregar a página. Assim, ao fazer login, a foto/inicial
        // aparece imediatamente na AppBar sem necessidade de F5.
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
    }

    // Invocado pelo AuthenticationStateProvider sempre que o estado muda
    // (login, logout ou expiração de token detectada pelo CustomAuthStateProvider).
    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        // Recarrega a foto do LocalStorage — pode ter sido atualizada pelo
        // AuthService.LoginAsync() ou apagada pelo AuthService.LogoutAsync().
        _fotoUrl = await LocalStorage.GetItemAsync<string>("userFotoUrl") ?? "";

        // Força re-render do componente na thread do Blazor
        await InvokeAsync(StateHasChanged);
    }

    // IDisposable: remove a subscricão ao destruir o componente para evitar
    // memory leaks (o delegate ficaria preso em AuthStateProvider).
    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }

    private async Task Sair()
    {
        // Usa AuthService.LogoutAsync() que:
        //   1. Chama POST /api/auth/logout (revoga token no servidor)
        //   2. Limpa todos os itens do LocalStorage
        //   3. Remove o header Authorization do HttpClient
        //   4. Notifica o CustomAuthStateProvider → dispara OnAuthStateChanged acima
        await AuthService.LogoutAsync();

        Snackbar.Add("Sessão encerrada com sucesso.", Severity.Info);
        NavigationManager.NavigateTo("/login");
    }

    // Tema centralizado — altere aqui para refletir em toda a aplicação
    MudTheme PontoDaDancaTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1b5e20",         // Verde escuro da identidade visual
            Secondary = "#fbc02d",        // Amarelo para destaques e CTAs
            AppbarBackground = "#1b5e20",
            Background = "#f5f5f5",       // Fundo levemente acinzentado
            Surface = "#ffffff",          // Cards e painéis brancos
            Success = "#4caf50",
            Info = "#2196f3",
            Warning = "#ff9800",
            Error = "#f44336"
        }
    };
}