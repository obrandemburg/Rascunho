@inherits LayoutComponentBase
@using MudBlazor

@* Estes Providers são obrigatórios para os pop-ups e temas do MudBlazor funcionarem *@
<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudMainContent Class="d-flex align-center justify-center" Style="min-height: 100vh; background-color: #f5f5f5;">
        @* Onde o @Body está, o Blazor vai injetar o conteúdo da tela de Login *@
        @Body
    </MudMainContent>
</MudLayout>