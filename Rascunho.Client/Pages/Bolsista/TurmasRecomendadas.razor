@*
  ARQUIVO: Rascunho.Client/Pages/Bolsista/TurmasRecomendadas.razor
  ROTA:    /bolsista/turmas-recomendadas
  ACESSO:  Bolsista

  CORREÇÃO SPRINT 6:
  Igual à TurmasObrigatorias.razor: os cards exibiam o hash criptografado
  como título da turma. Agora exibem RitmoNome, DiaDaSemana e horário.

  BUG-007:
  - TurmasObrigatorias.razor removida (duplicava este endpoint).
  - Adicionado filtro de dia da semana (padrão = dia atual).
  - API chamada com ?diaDaSemana=N conforme dia selecionado.
*@

@page "/bolsista/turmas-recomendadas"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@attribute [Authorize(Roles = "Bolsista")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Turmas Recomendadas — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.Recommend" Class="mr-2" />
    Turmas Recomendadas
</MudText>
<MudText Class="mb-4 mud-text-secondary">
    Turmas analisadas pelo sistema com base no equilíbrio de condutores e conduzidos.
</MudText>

@* BUG-007: Filtro de dia da semana *@
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-6">
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Dia:</MudText>
    <MudSelect T="int" @bind-Value="diaSelecionado"
               Variant="Variant.Outlined" Dense="true"
               Style="min-width: 180px;"
               Label="">
        @foreach (var kv in diasDaSemana)
        {
            <MudSelectItem T="int" Value="@kv.Key">@kv.Value</MudSelectItem>
        }
    </MudSelect>
    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
               OnClick="CarregarAnalises" Disabled="@carregando">
        Atualizar
    </MudButton>
</MudStack>

@if (carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (!analises.Any())
{
    <MudAlert Severity="Severity.Success">
        Todas as turmas de @diasDaSemana[diaSelecionado] estão balanceadas! 🎉
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var analise in analises)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-lg"
                         Style="@($"border-left: 4px solid {CorStatus(analise.Status)};")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            @*
                              CORREÇÃO SPRINT 6:
                              ANTES: <MudText>@analise.TurmaIdHash</MudText>
                              AGORA: RitmoNome + Dia + Horário legíveis
                            *@
                            <MudText Typo="Typo.h6">@analise.RitmoNome</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @DiaDaSemanaTexto(analise.DiaDaSemana) •
                                @analise.HorarioInicio.ToString(@"hh\:mm")–@analise.HorarioFim.ToString(@"hh\:mm")
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@IconeStatus(analise.Status)"
                                     Style="@($"color: {CorStatus(analise.Status)}")" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChip T="string"
                                 Color="@ChipCor(analise.Status)"
                                 Size="Size.Small"
                                 Variant="Variant.Filled"
                                 Class="mb-3">
                            @analise.Status
                        </MudChip>

                        @* Resumo de condutores vs conduzidos *@
                        <MudGrid Dense="true" Class="mb-2">
                            <MudItem xs="6">
                                <MudPaper Elevation="0" Class="pa-2 text-center rounded"
                                          Style="background: #e8f5e9;">
                                    <MudText Typo="Typo.h6" Color="Color.Success">
                                        @analise.TotalCondutores
                                    </MudText>
                                    <MudText Typo="Typo.caption">Condutores</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6">
                                <MudPaper Elevation="0" Class="pa-2 text-center rounded"
                                          Style="background: #fce4ec;">
                                    <MudText Typo="Typo.h6" Color="Color.Error">
                                        @analise.TotalConduzidos
                                    </MudText>
                                    <MudText Typo="Typo.caption">Conduzidos</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        @if (analise.QuantidadeFaltante > 0)
                        {
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Precisamos de <strong>@analise.QuantidadeFaltante</strong>
                                @(analise.Status.Contains("Condutor") ? "condutor(es)" : "conduzido(s)")
                            </MudText>
                        }

                        @if (analise.Sugestoes.Any())
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">
                                Bolsistas disponíveis:
                            </MudText>
                            @foreach (var sug in analise.Sugestoes.Take(3))
                            {
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Variant="Variant.Outlined"
                                         Color="Color.Primary">
                                    @sug.Nome (@sug.PapelDominante)
                                </MudChip>
                            }
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool carregando = true;
    private List<SugestaoBalanceamentoDto> analises = new();

    // BUG-007: padrão = dia da semana atual
    private int diaSelecionado = (int)DateTime.Now.DayOfWeek;

    private readonly Dictionary<int, string> diasDaSemana = new()
    {
        { 0, "Domingo" },
        { 1, "Segunda-feira" },
        { 2, "Terça-feira" },
        { 3, "Quarta-feira" },
        { 4, "Quinta-feira" },
        { 5, "Sexta-feira" },
        { 6, "Sábado" }
    };

    protected override async Task OnInitializedAsync()
    {
        await CarregarAnalises();
    }

    // BUG-007: método separado para permitir recarregar ao mudar o filtro de dia
    private async Task CarregarAnalises()
    {
        carregando = true;
        try
        {
            analises = await Http.GetFromJsonAsync<List<SugestaoBalanceamentoDto>>(
                $"api/bolsistas/turmas-recomendadas?diaDaSemana={diaSelecionado}") ?? new();
        }
        catch
        {
            Snackbar.Add("Erro ao carregar turmas do dia.", Severity.Error);
        }
        finally { carregando = false; }
    }

    private string DiaDaSemanaTexto(int dia) =>
        diasDaSemana.TryGetValue(dia, out var nome) ? nome : "—";

    private string CorStatus(string status) => status switch
    {
        "Balanceada" => "#4caf50",
        "Faltam Condutores" => "#f44336",
        "Faltam Conduzidos" => "#ff9800",
        _ => "#9e9e9e"
    };

    private string IconeStatus(string status) => status switch
    {
        "Balanceada" => Icons.Material.Filled.CheckCircle,
        _ => Icons.Material.Filled.Warning
    };

    private Color ChipCor(string status) => status switch
    {
        "Balanceada" => Color.Success,
        "Faltam Condutores" => Color.Error,
        _ => Color.Warning
    };

    // ──────────────────────────────────────────────────────────────
    // DTO LOCAL — CORRIGIDO Sprint 6
    // Campos adicionados: RitmoNome, DiaDaSemana, HorarioInicio, HorarioFim
    // ──────────────────────────────────────────────────────────────
    public class SugestaoBalanceamentoDto
    {
        public string TurmaIdHash { get; set; } = "";
        public int TotalCondutores { get; set; }
        public int TotalConduzidos { get; set; }
        public string Status { get; set; } = "";
        public int QuantidadeFaltante { get; set; }
        public List<BolsistaSugeridoDto> Sugestoes { get; set; } = new();

        // NOVO Sprint 6
        public string RitmoNome { get; set; } = "";
        public int DiaDaSemana { get; set; }
        public TimeSpan HorarioInicio { get; set; }
        public TimeSpan HorarioFim { get; set; }
    }

    public class BolsistaSugeridoDto
    {
        public string BolsistaIdHash { get; set; } = "";
        public string Nome { get; set; } = "";
        public string PapelDominante { get; set; } = "";
        public string Nivel { get; set; } = "";
    }
}
