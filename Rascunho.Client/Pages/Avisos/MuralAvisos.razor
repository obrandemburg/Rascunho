@page "/mural-avisos"
@using System.Net.Http.Json
@inject HttpClient Http

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4 font-weight-bold">Mural de Avisos</MudText>
    
    @if (carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!avisos.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">Nenhum aviso no momento. Volte mais tarde!</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var aviso in avisos)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100 border-l-4 border-solid" Style="border-left-color: #1b5e20;">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">@aviso.Titulo</MudText>
                                <MudText Typo="Typo.caption">Publicado em: @aviso.DataPublicacao.ToString("dd/MM/yyyy")</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIcon Icon="@Icons.Material.Filled.Campaign" Color="Color.Primary" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2">@aviso.Mensagem</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private bool carregando = true;
    private List<AvisoDto> avisos = new();

    public class AvisoDto
    {
        public string Titulo { get; set; } = "";
        public string Mensagem { get; set; } = "";
        public DateTime DataPublicacao { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Rota AllowAnonymous configurada no backend
            var res = await Http.GetFromJsonAsync<List<AvisoDto>>("api/avisos/geral");
            if (res != null) avisos = res;
        }
        catch { /* Erro de rede */ }
        finally { carregando = false; }
    }
}