@* ARQUIVO: Rascunho.Client/Pages/Perfil.razor
  ROTA:    /perfil
  ACESSO:  Qualquer usuário autenticado
*@

@page "/perfil"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using Blazored.LocalStorage
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS

<PageTitle>Meu Perfil — Ponto da Dança</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-8">

    <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6 font-weight-bold">
        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
        Meu Perfil
    </MudText>

    @* ── Cabeçalho: foto atual + dados básicos ─────────────────── *@
    <MudPaper Elevation="3" Class="pa-6 rounded-xl mb-6">
        <div class="d-flex align-center gap-4 mb-4">

            <UserAvatar FotoUrl="@fotoUrlAtual" Nome="@nomeCompleto" Size="Size.Large" />

            <div>
                <MudText Typo="Typo.h5" Class="font-weight-bold">@nomeCompleto</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                    @role
                </MudChip>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-1" />
                    @email
                </MudText>
            </div>
        </div>

        @* ── Área de troca de foto ────────────────────────────── *@
        <MudDivider Class="mb-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-3">Foto de Perfil</MudText>

        <div class="d-flex align-center gap-3 flex-wrap">

            <InputFile id="inputFotoPerfil"
                       OnChange="SelecionarFoto"
                       accept="image/jpeg,image/jpg,image/png,image/webp"
                       style="display: none;" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CameraAlt"
                       OnClick="AbrirSeletorFoto"
                       Disabled="@(salvando)">
                @(string.IsNullOrEmpty(novaFotoPreviewUrl) ? "Escolher Foto" : "Trocar Novamente")
            </MudButton>

            @if (!string.IsNullOrEmpty(nomeFotoSelecionada))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    📎 @nomeFotoSelecionada
                </MudText>
            }
        </div>

        @if (!string.IsNullOrEmpty(novaFotoPreviewUrl))
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                Nova foto selecionada. Clique em <strong>Salvar Alterações</strong> para confirmar.
            </MudAlert>
            <div class="mt-3 d-flex align-center gap-3">
                <MudAvatar Style="width: 64px; height: 64px; overflow: hidden; padding: 0;">
                    <img src="@novaFotoPreviewUrl" alt="Preview"
                         style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
                </MudAvatar>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Preview da nova foto</MudText>
            </div>
        }

        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
            Formatos aceitos: JPG, PNG, WEBP · Tamanho máximo: 5 MB
        </MudText>
    </MudPaper>

    @* ── Formulário de Nome Social e Biografia ─────────────────── *@
    <MudPaper Elevation="3" Class="pa-6 rounded-xl mb-6">
        <MudText Typo="Typo.h6" Class="mb-4">Editar Informações</MudText>

        <EditForm Model="@form" OnValidSubmit="SalvarPerfil">

            <MudTextField @bind-Value="form.NomeSocial"
                          Label="Nome Social (como prefere ser chamado)"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          MaxLength="100"
                          HelperText="Opcional — deixe em branco para usar o nome completo" />

            <MudTextField @bind-Value="form.Biografia"
                          Label="Biografia"
                          Variant="Variant.Outlined"
                          Lines="4"
                          Class="mb-6"
                          MaxLength="500"
                          HelperText="Conte um pouco sobre você (máx. 500 caracteres)" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@salvando"
                       StartIcon="@Icons.Material.Filled.Save">
                @if (salvando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    @statusSalvamento
                }
                else
                {
                    <text>Salvar Alterações</text>
                }
            </MudButton>
        </EditForm>
    </MudPaper>

    @* ── Formulário de Alteração de Senha ──────────────────────── *@
    <MudPaper Elevation="3" Class="pa-6 rounded-xl">
        <MudText Typo="Typo.h6" Class="mb-4">Segurança</MudText>

        <EditForm Model="@formSenha" OnValidSubmit="AlterarSenha">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="formSenha.SenhaAtual"
                          Label="Senha Atual"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          For="@(() => formSenha.SenhaAtual)" />

            <MudTextField @bind-Value="formSenha.NovaSenha"
                          Label="Nova Senha"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          For="@(() => formSenha.NovaSenha)" />

            <MudTextField @bind-Value="formSenha.ConfirmarNovaSenha"
                          Label="Confirmar Nova Senha"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-6"
                          For="@(() => formSenha.ConfirmarNovaSenha)" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Error"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@salvandoSenha"
                       StartIcon="@Icons.Material.Filled.Lock">
                @if (salvandoSenha)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <text>Alterando Senha...</text>
                }
                else
                {
                    <text>Alterar Senha</text>
                }
            </MudButton>
        </EditForm>
    </MudPaper>

</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool salvando = false;
    private string statusSalvamento = "Salvando...";

    private bool salvandoSenha = false;

    // Dados lidos das Claims do JWT
    private string nomeCompleto = "";
    private string email = "";
    private string role = "";

    // Foto atual
    private string fotoUrlAtual = "";

    // Estado da nova foto selecionada
    private string? novaFotoPreviewUrl = null;
    private string nomeFotoSelecionada = "";
    private IBrowserFile? arquivoFotoSelecionado = null;

    private EditarPerfilForm form = new();
    private AlterarSenhaForm formSenha = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            nomeCompleto = user.Identity?.Name ?? "Usuário";
            email = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
            role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        }

        try
        {
            fotoUrlAtual = await LocalStorage.GetItemAsync<string>("userFotoUrl") ?? "";
        }
        catch { fotoUrlAtual = ""; }
    }

    private async Task AbrirSeletorFoto()
    {
        await JS.InvokeVoidAsync("fileUpload.abrirSeletor", "inputFotoPerfil");
    }

    private async Task SelecionarFoto(InputFileChangeEventArgs e)
    {
        arquivoFotoSelecionado = e.File;
        nomeFotoSelecionada = e.File.Name;
        novaFotoPreviewUrl = null;

        try
        {
            var buffer = new byte[arquivoFotoSelecionado.Size];
            await arquivoFotoSelecionado
                .OpenReadStream(maxAllowedSize: 5 * 1024 * 1024)
                .ReadAsync(buffer);

            var base64 = Convert.ToBase64String(buffer);
            novaFotoPreviewUrl = $"data:{arquivoFotoSelecionado.ContentType};base64,{base64}";
        }
        catch
        {
            Snackbar.Add("Arquivo grande demais para preview — será enviado ao salvar.", Severity.Info);
        }
    }

    private async Task SalvarPerfil()
    {
        salvando = true;
        statusSalvamento = "Salvando...";

        try
        {
            var fotoParaEnviar = fotoUrlAtual;

            if (arquivoFotoSelecionado != null)
            {
                statusSalvamento = "Enviando foto...";
                StateHasChanged();

                using var content = new MultipartFormDataContent();
                using var stream = arquivoFotoSelecionado.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                using var streamContent = new StreamContent(stream);
                streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(arquivoFotoSelecionado.ContentType);
                content.Add(streamContent, "foto", arquivoFotoSelecionado.Name);

                var uploadResponse = await Http.PostAsync("api/upload/foto", content);

                if (uploadResponse.IsSuccessStatusCode)
                {
                    var resultado = await uploadResponse.Content.ReadFromJsonAsync<UploadFotoDto>();

                    if (resultado != null && !string.IsNullOrEmpty(resultado.Url))
                    {
                        fotoParaEnviar = resultado.Url;
                        fotoUrlAtual = fotoParaEnviar;
                        await LocalStorage.SetItemAsync("userFotoUrl", fotoParaEnviar);

                        arquivoFotoSelecionado = null;
                        novaFotoPreviewUrl = null;
                        nomeFotoSelecionada = "";
                    }
                }
                else
                {
                    Snackbar.Add("Não foi possível enviar a foto. Tente novamente.", Severity.Warning);
                    return;
                }
            }

            statusSalvamento = "Salvando perfil...";
            StateHasChanged();

            var payload = new
            {
                NomeSocial = form.NomeSocial ?? "",
                Biografia = form.Biografia ?? "",
                FotoUrl = fotoParaEnviar
            };

            var perfilResponse = await Http.PutAsJsonAsync("api/usuarios/meu-perfil/atualizar", payload);

            if (perfilResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Perfil atualizado com sucesso! ✅", Severity.Success);
            }
            else if ((int)perfilResponse.StatusCode == 400)
            {
                Snackbar.Add("Dados inválidos. Verifique os campos.", Severity.Warning);
            }
            else
            {
                var erro = await perfilResponse.Content.ReadAsStringAsync();
                Snackbar.Add($"Erro ao salvar: {erro}", Severity.Error);
            }
        }
        finally
        {
            salvando = false;
            statusSalvamento = "Salvando...";
        }
    }

    // ──────────────────────────────────────────────────────────────
    // ALTERAR SENHA
    // ──────────────────────────────────────────────────────────────
    private async Task AlterarSenha()
    {
        salvandoSenha = true;

        try
        {
            var payload = new
            {
                SenhaAtual = formSenha.SenhaAtual,
                NovaSenha = formSenha.NovaSenha
            };

            // Ajuste esta URL para a rota correta da sua Minimal API / Controller ASP.NET Core
            var response = await Http.PutAsJsonAsync("api/usuarios/meu-perfil/alterar-senha", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Senha alterada com sucesso! 🔒", Severity.Success);
                formSenha = new AlterarSenhaForm(); // Limpa o formulário
            }
        }
        finally
        {
            salvandoSenha = false;
        }
    }

    // ── DTOs e modelos ────────────────────────────────────────────

    public class UploadFotoDto
    {
        public string Url { get; set; } = "";
        public string NomeArquivo { get; set; } = "";
        public long TamanhoBytes { get; set; }
    }

    public class EditarPerfilForm
    {
        public string? NomeSocial { get; set; }
        public string? Biografia { get; set; }
    }

    public class AlterarSenhaForm
    {
        [Required(ErrorMessage = "A senha atual é obrigatória.")]
        public string SenhaAtual { get; set; } = "";

        [Required(ErrorMessage = "A nova senha é obrigatória.")]
        [MinLength(8, ErrorMessage = "A nova senha deve ter no mínimo 8 caracteres.")]
        public string NovaSenha { get; set; } = "";

        [Required(ErrorMessage = "A confirmação da senha é obrigatória.")]
        [Compare(nameof(NovaSenha), ErrorMessage = "As senhas não coincidem.")]
        public string ConfirmarNovaSenha { get; set; } = "";
    }
}