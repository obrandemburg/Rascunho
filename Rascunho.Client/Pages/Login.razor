@page "/login"
@using System.Net.Http.Json
@using Blazored.LocalStorage
@using Rascunho.Shared.DTOs
@using Rascunho.Client.Security
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="3" Class="pa-8" Style="border-radius: 16px;">
        
        <div class="d-flex justify-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Large" Color="Color.Primary" />
        </div>
        
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6 font-weight-bold">Acesse sua conta</MudText>

        <MudForm @ref="form" @bind-IsValid="@success">
            <MudTextField @bind-Value="model.Email"
                          Label="E-mail"
                          Required="true"
                          RequiredError="O e-mail é obrigatório!"
                          Email="true"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudTextField @bind-Value="model.Senha"
                          Label="Senha"
                          Required="true"
                          RequiredError="A senha é obrigatória!"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-6" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       OnClick="EfetuarLogin"
                       Disabled="@(!success || loading)">
                @if (loading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Validando...</MudText>
                }
                else
                {
                    <MudText>Entrar na Escola</MudText>
                }
            </MudButton>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    private MudForm form = default!;
    private bool success;
    private bool loading = false;
    
    // Usamos um modelo local limpo para o Binding de tela
    private LoginModel model = new();

    private async Task EfetuarLogin()
    {
        await form.Validate();
        if (!form.IsValid) return;

        loading = true;
        try
        {
            // Usamos o seu DTO puro para respeitar a arquitetura
            var requestDto = new LoginRequest(model.Email, model.Senha);
            
            var response = await Http.PostAsJsonAsync("/api/auth/login", requestDto);
            
            if (response.IsSuccessStatusCode)
            {
                var loginResponse = await response.Content.ReadFromJsonAsync<LoginResponse>();
                
                if (loginResponse != null)
                {
                    // 1. Salva a chave no celular do aluno
                    await LocalStorage.SetItemAsync("authToken", loginResponse.Token);
                    // 2. Avisa as catracas do sistema que ele entrou
                    ((CustomAuthStateProvider)AuthStateProvider).NotifyUserAuthentication(loginResponse.Token);
                    // 3. Joga ele pro Dashboard
                    NavigationManager.NavigateTo("/");
                }
            }
            else
            {
                // Erro 400 ou 401 (Senha errada ou usuário não existe)
                Snackbar.Add("E-mail ou senha incorretos.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Não foi possível conectar ao servidor. O sistema está offline?", Severity.Warning);
        }
        finally
        {
            loading = false;
        }
    }

    // Classe auxiliar de tela
    public class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }
}