@* 
  ARQUIVO: Rascunho.Client/Pages/Aluno/AulasParticulares.razor
  ROTA:    /aulas-particulares
  ACESSO:  Aluno, Bolsista

  NOVIDADES Sprint 4:
  - Exibe ValorCobrado com indicador de desconto para bolsistas
  - Botão "Reagendar" para aulas Pendentes ou Aceitas
    → Abre dialog com seletor de data e horário
    → Chama PUT /api/aulas-particulares/{id}/reagendar
*@

@page "/aulas-particulares"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@attribute [Authorize(Roles = "Aluno,Bolsista")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Aulas Particulares — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
    Aulas Particulares
</MudText>

<MudGrid>
    @* ── COLUNA ESQUERDA: Formulário de solicitação ─────────────── *@
    <MudItem xs="12" md="5">
        <MudPaper Elevation="3" Class="pa-6 rounded-xl">
            <MudText Typo="Typo.h6" Class="mb-4">Solicitar Nova Aula</MudText>

            <EditForm Model="@novaAula" OnValidSubmit="SolicitarAula">
                <MudSelect T="string"
                           @bind-Value="novaAula.ProfessorIdHash"
                           Label="Professor"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (var prof in professores)
                    {
                        <MudSelectItem T="string" Value="@prof.IdHash">@prof.Nome</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string"
                           @bind-Value="novaAula.RitmoIdHash"
                           Label="Ritmo"
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    @foreach (var ritmo in ritmos)
                    {
                        <MudSelectItem T="string" Value="@ritmo.IdHash">
                            @ritmo.Nome (@ritmo.Modalidade)
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudDatePicker @bind-Date="dataInicio"
                               Label="Data da Aula"
                               Variant="Variant.Outlined"
                               Class="mb-4"
                               MinDate="@DateTime.Today.AddDays(1)"
                               DateFormat="dd/MM/yyyy" />

                <MudTimePicker @bind-Time="horaInicio"
                               Label="Horário de Início"
                               Variant="Variant.Outlined"
                               Class="mb-4"
                               AmPm="false" />

                <MudTimePicker @bind-Time="horaFim"
                               Label="Horário de Fim"
                               Variant="Variant.Outlined"
                               Class="mb-4"
                               AmPm="false" />

                @* Preview do valor que será cobrado *@
                @if (!string.IsNullOrEmpty(novaAula.RitmoIdHash))
                {
                    <MudAlert Severity="@(ehBolsista? Severity.Success: Severity.Info)"
                              Dense="true" Class="mb-4">
                        @if (ehBolsista)
                        {
                            <span>
                                💰 Seu valor: <b>R$ @((precoBase * 0.5m).ToString("F2"))</b>
                                <small>(50% de desconto bolsista)</small>
                            </span>
                        }
                        else
                        {
                            <span>💰 Valor: <b>R$ @precoBase.ToString("F2")</b></span>
                        }
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@enviando">
                    @(enviando ? "Solicitando..." : "Solicitar Aula")
                </MudButton>
            </EditForm>
        </MudPaper>
    </MudItem>

    @* ── COLUNA DIREITA: Lista de aulas existentes ───────────────── *@
    <MudItem xs="12" md="7">
        @if (carregando)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (!aulasParticulares.Any())
        {
            <MudAlert Severity="Severity.Info">
                Nenhuma aula particular solicitada ainda.
            </MudAlert>
        }
        else
        {
            @foreach (var aula in aulasParticulares)
            {
                <MudCard Elevation="2" Class="rounded-lg mb-3">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1">
                                Prof. <b>@aula.ProfessorNome</b> — @aula.RitmoNome
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                📅 @aula.DataHoraInicio.ToString("dd/MM/yyyy — HH:mm")
                                até @aula.DataHoraFim.ToString("HH:mm")
                            </MudText>
                            @* NOVO: Exibição do valor cobrado *@
                            <MudText Typo="Typo.caption"
                                     Style="@(ehBolsista && aula.ValorCobrado < precoBase ? "color: #4caf50; font-weight: bold;" : "")">
                                💰 @(aula.ValorCobrado == 0
                                                                       ? "Gratuito"
                                                                       : $"R$ {aula.ValorCobrado:F2}")
                                @if (ehBolsista && aula.ValorCobrado < precoBase)
                                {
                                    <text> (50% desconto bolsista)</text>
                                }
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@StatusCor(aula.Status)"
                                     Variant="Variant.Filled">
                                @aula.Status
                            </MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardActions Class="justify-space-between">
                        <MudButton Color="Color.Error"
                                   Variant="Variant.Text"
                                   Disabled="@(aula.Status != "Pendente" && aula.Status != "Aceita")"
                                   OnClick="@(() => Cancelar(aula.IdHash))">
                            Cancelar
                        </MudButton>

                        @* NOVO: Botão Reagendar *@
                        @if (aula.Status == "Pendente" || aula.Status == "Aceita")
                        {
                            <MudButton Color="Color.Info"
                                       Variant="Variant.Text"
                                       StartIcon="@Icons.Material.Filled.EventRepeat"
                                       OnClick="@(() => AbrirDialogReagendar(aula))">
                                Reagendar
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            }
        }
    </MudItem>
</MudGrid>

@* ── DIALOG DE REAGENDAMENTO ─────────────────────────────────────── *@
@if (aulaParaReagendar != null)
{
    <MudDialog @bind-IsVisible="dialogReagendarAberto"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">
                Reagendar — Prof. @aulaParaReagendar.ProfessorNome
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
                A aula reagendada volta para <b>Pendente</b> e o professor
                precisará aceitar o novo horário.
            </MudAlert>

            <MudDatePicker @bind-Date="novaDataReagendar"
                           Label="Nova Data"
                           Variant="Variant.Outlined"
                           DateFormat="dd/MM/yyyy"
                           MinDate="@DateTime.Today.AddDays(1)"
                           Class="mb-4" />

            <MudTimePicker @bind-Time="novaHoraInicioReagendar"
                           Label="Novo Horário de Início"
                           Variant="Variant.Outlined"
                           AmPm="false"
                           Class="mb-4" />

            <MudTimePicker @bind-Time="novaHoraFimReagendar"
                           Label="Novo Horário de Fim"
                           Variant="Variant.Outlined"
                           AmPm="false"
                           Class="mb-4" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => dialogReagendarAberto = false)"
                       Variant="Variant.Text">Cancelar</MudButton>
            <MudButton OnClick="ConfirmarReagendar"
                       Variant="Variant.Filled"
                       Color="Color.Info"
                       Disabled="@(novaDataReagendar == null || novaHoraInicioReagendar == null || novaHoraFimReagendar == null || processando)">
                @(processando ? "Reagendando..." : "Confirmar")
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool carregando = true;
    private bool enviando = false;
    private bool processando = false;
    private bool dialogReagendarAberto = false;
    private bool ehBolsista = false;
    private decimal precoBase = 80.00m;

    private List<AulaParticularDto> aulasParticulares = new();
    private List<ProfessorSimples> professores = new();
    private List<RitmoSimples> ritmos = new();
    private AulaParticularDto? aulaParaReagendar;

    private SolicitarAulaRequest novaAula = new();
    private DateTime? dataInicio;
    private TimeSpan? horaInicio;
    private TimeSpan? horaFim;
    private DateTime? novaDataReagendar;
    private TimeSpan? novaHoraInicioReagendar;
    private TimeSpan? novaHoraFimReagendar;

    protected override async Task OnInitializedAsync()
    {
        // Verifica role do usuário para exibir preços corretos
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            ehBolsista = authState.User.IsInRole("Bolsista");
        }

        // Carrega dados em paralelo
        var profTask = Http.GetFromJsonAsync<List<ProfessorSimples>>("api/usuarios/tipo/Professor/ativos/lista");
        var ritmoTask = Http.GetFromJsonAsync<List<RitmoSimples>>("api/ritmos/listar");
        var aulasTask = Http.GetFromJsonAsync<List<AulaParticularDto>>("api/aulas-particulares/minhas");
        var configTask = Http.GetFromJsonAsync<ConfigDto>("api/gerente/configuracoes");

        await Task.WhenAll(profTask, ritmoTask, aulasTask);

        professores = profTask.Result ?? new();
        ritmos = (ritmoTask.Result ?? new()).Where(r => r.Ativo).ToList();
        aulasParticulares = aulasTask.Result ?? new();

        // Tenta obter preço atualizado (pode falhar se não for Gerente)
        try
        {
            var config = await configTask;
            if (config != null) precoBase = config.PrecoAulaParticular;
        }
        catch { /* usa preço padrão */ }

        carregando = false;
    }

    private async Task SolicitarAula()
    {
        if (dataInicio == null || horaInicio == null || horaFim == null) return;

        enviando = true;
        try
        {
            var payload = new
            {
                novaAula.ProfessorIdHash,
                novaAula.RitmoIdHash,
                DataHoraInicio = dataInicio.Value.Date + horaInicio.Value,
                DataHoraFim = dataInicio.Value.Date + horaFim.Value,
                Observacao = ""
            };

            var response = await Http.PostAsJsonAsync("api/aulas-particulares/solicitar", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Solicitação enviada! Aguarde o professor aceitar. ✅", Severity.Success);
                novaAula = new();
                dataInicio = null; horaInicio = null; horaFim = null;
                aulasParticulares = await Http.GetFromJsonAsync<List<AulaParticularDto>>(
                    "api/aulas-particulares/minhas") ?? new();
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                Snackbar.Add(erro, Severity.Error);
            }
        }
        finally { enviando = false; }
    }

    private async Task Cancelar(string idHash)
    {
        var response = await Http.DeleteAsync($"api/aulas-particulares/{idHash}/cancelar");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Aula cancelada.", Severity.Info);
            aulasParticulares = await Http.GetFromJsonAsync<List<AulaParticularDto>>(
                "api/aulas-particulares/minhas") ?? new();
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            Snackbar.Add(msg, Severity.Warning);
        }
    }

    private void AbrirDialogReagendar(AulaParticularDto aula)
    {
        aulaParaReagendar = aula;
        novaDataReagendar = null;
        novaHoraInicioReagendar = aula.DataHoraInicio.TimeOfDay;
        novaHoraFimReagendar = aula.DataHoraFim.TimeOfDay;
        dialogReagendarAberto = true;
    }

    private async Task ConfirmarReagendar()
    {
        if (aulaParaReagendar == null || novaDataReagendar == null ||
            novaHoraInicioReagendar == null || novaHoraFimReagendar == null) return;

        processando = true;
        try
        {
            var decodedHash = aulaParaReagendar.IdHash;
            var payload = new
            {
                NovaDataHoraInicio = novaDataReagendar.Value.Date + novaHoraInicioReagendar.Value,
                NovaDataHoraFim = novaDataReagendar.Value.Date + novaHoraFimReagendar.Value
            };

            var response = await Http.PutAsJsonAsync(
                $"api/aulas-particulares/{decodedHash}/reagendar", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(
                    "Aula reagendada! O professor receberá a nova solicitação. ✅",
                    Severity.Success);
                dialogReagendarAberto = false;
                aulasParticulares = await Http.GetFromJsonAsync<List<AulaParticularDto>>(
                    "api/aulas-particulares/minhas") ?? new();
            }
            else
            {
                var msg = await response.Content.ReadAsStringAsync();
                Snackbar.Add(msg, Severity.Warning);
            }
        }
        finally { processando = false; }
    }

    private Color StatusCor(string status) => status switch
    {
        "Aceita" => Color.Success,
        "Recusada" => Color.Error,
        "Cancelada" => Color.Default,
        _ => Color.Warning  // Pendente
    };

    public class SolicitarAulaRequest
    {
        public string ProfessorIdHash { get; set; } = "";
        public string RitmoIdHash { get; set; } = "";
    }

    public class AulaParticularDto
    {
        public string IdHash { get; set; } = "";
        public string ProfessorIdHash { get; set; } = "";
        public string ProfessorNome { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public DateTime DataHoraInicio { get; set; }
        public DateTime DataHoraFim { get; set; }
        public string Status { get; set; } = "";
        public decimal ValorCobrado { get; set; }    // NOVO Sprint 3/4
    }

    public class ProfessorSimples
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
    }

    public class RitmoSimples
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
        public string Modalidade { get; set; } = "";
        public bool Ativo { get; set; }
    }

    // Para leitura do preço atual (tentativa)
    public class ConfigDto
    {
        public decimal PrecoAulaParticular { get; set; }
    }
}