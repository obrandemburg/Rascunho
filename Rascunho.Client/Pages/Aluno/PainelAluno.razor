@* 
  ROTA: /painel (redirecionamento pós-login)
  ACESSO: Roles = Aluno, Bolsista
  
  FLUXO:
  1. [Authorize] bloqueia não autenticados → redireciona para /login
  2. AuthorizeView com Roles renderiza conteúdo específico por perfil
  3. Cards de acesso rápido com Href direto para sub-páginas
  4. Notificações: buscamos aulas da semana atual
  
  SEGURANÇA: O [Authorize] atributo protege a rota.
  AuthorizeView dentro protege seções específicas dentro da página.
  Dupla proteção garante que mesmo com URL direta, o usuário vê
  apenas o que tem direito.
*@

@page "/painel"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Meu Painel — Ponto da Dança</PageTitle>

@* ============================================================
   HEADER COM BOAS-VINDAS E NOTIFICAÇÕES
============================================================ *@
<AuthorizeView>
    <Authorized Context="authContext">
        <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-1 font-weight-bold">
            Olá, @authContext.User.Identity?.Name! 👋
        </MudText>
    </Authorized>
</AuthorizeView>

<MudText Typo="Typo.subtitle1" Class="mb-6 mud-text-secondary">
    Seja bem-vindo(a) ao portal da Ponto da Dança.
</MudText>

@* ============================================================
   BANNER DE PRÓXIMA AULA (notificação contextual)
============================================================ *@
@if (proximaAula != null)
{
    <MudAlert Severity="Severity.Success"
              Icon="@Icons.Material.Filled.EventAvailable"
              Class="mb-6"
              Elevation="2">
        <strong>Próxima aula:</strong> @proximaAula.RitmoNome —
        @DiaDaSemana(proximaAula.DiaDaSemana) às @proximaAula.HorarioInicio.ToString(@"hh\:mm")
        na Sala @proximaAula.SalaNome
    </MudAlert>
}

@* ============================================================
   CARDS DE ACESSO RÁPIDO
============================================================ *@
<AuthorizeView Roles="Aluno,Bolsista">
    <Authorized>
        <MudText Typo="Typo.h6" Class="mb-3">Acesso Rápido</MudText>
        <MudGrid>

            @* Card: Minhas Aulas *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-lg h-100"
                         Style="border-left: 4px solid #1b5e20;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Minhas Aulas</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.EventAvailable"
                                     Color="Color.Success" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            Veja as turmas em que está matriculado,
                            links de WhatsApp e avisos específicos.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/minhas-aulas"
                                   Variant="Variant.Text"
                                   Color="Color.Primary">
                            Acessar Turmas
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Card: Aulas Particulares *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-lg h-100"
                         Style="border-left: 4px solid #fbc02d;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Aulas Particulares</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                     Color="Color.Warning" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            Agende sessões personalizadas com professores.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/aulas-particulares"
                                   Variant="Variant.Text"
                                   Color="Color.Warning">
                            Agendar Aula
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Card: Ingressos de Eventos *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="rounded-lg h-100"
                         Style="border-left: 4px solid #9c27b0;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Eventos & Ingressos</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
                                     Color="Color.Secondary" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            Compre ingressos para bailes, workshops e eventos especiais.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/ingressos"
                                   Variant="Variant.Text"
                                   Color="Color.Secondary">
                            Ver Eventos
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

        </MudGrid>
    </Authorized>
</AuthorizeView>

@code {
    // DTO simplificado para próxima aula
    private TurmaResumoDto? proximaAula;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // GET /api/turmas/minhas-turmas — retorna turmas do aluno logado
            // O token JWT já identifica o aluno via Claims
            var turmas = await Http.GetFromJsonAsync<List<TurmaResumoDto>>(
                "api/turmas/minhas-turmas");

            if (turmas != null && turmas.Any())
            {
                // Pega a próxima aula mais próxima do dia atual
                var hoje = (int)DateTime.Now.DayOfWeek;
                proximaAula = turmas
                    .OrderBy(t => ((t.DiaDaSemana - hoje + 7) % 7))
                    .FirstOrDefault();
            }
        }
        catch
        {
            // Silencioso: não exibe o banner se falhar
        }
    }

    // Converte int do DayOfWeek para português
    private string DiaDaSemana(int dia) => dia switch
    {
        0 => "Domingo",
        1 => "Segunda-feira",
        2 => "Terça-feira",
        3 => "Quarta-feira",
        4 => "Quinta-feira",
        5 => "Sexta-feira",
        6 => "Sábado",
        _ => "—"
    };

    public class TurmaResumoDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string SalaNome { get; set; } = "";
        public int DiaDaSemana { get; set; }
        public TimeSpan HorarioInicio { get; set; }
        public string? LinkWhatsApp { get; set; }
    }
}