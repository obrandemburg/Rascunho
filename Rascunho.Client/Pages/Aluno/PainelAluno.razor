@*
  ROTA: /painel (redirecionamento pós-login)
  ACESSO: Roles = Aluno, Bolsista

  BUG-008: Substituído DTO local TurmaResumoDto (com TimeSpan HorarioInicio)
  pelo DTO compartilhado ObterTurmaResponse (com string HorarioInicio).
  O banner de "Próxima aula" agora usa HorarioInicio diretamente como string.
*@

@page "/painel"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@using Rascunho.Shared.DTOs
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Meu Painel — Ponto da Dança</PageTitle>

@* ============================================================
   HEADER COM BOAS-VINDAS E NOTIFICAÇÕES
============================================================ *@
<AuthorizeView>
    <Authorized Context="authContext">
        <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-1 font-weight-bold">
            Olá, @authContext.User.Identity?.Name! 👋
        </MudText>
    </Authorized>
</AuthorizeView>

<MudText Typo="Typo.subtitle1" Class="mb-6 mud-text-secondary">
    Seja bem-vindo(a) ao portal da Ponto da Dança.
</MudText>

@* ============================================================
   BANNER DE PRÓXIMA AULA (notificação contextual)
============================================================ *@
@if (proximaAula != null)
{
    <MudAlert Severity="Severity.Success"
              Icon="@Icons.Material.Filled.EventAvailable"
              Class="mb-6"
              Elevation="2">
        <strong>Próxima aula:</strong> @proximaAula.RitmoNome —
        @DiaDaSemana(proximaAula.DiaDaSemana) às @proximaAula.HorarioInicio
        na Sala @proximaAula.SalaNome
    </MudAlert>
}

@* ============================================================
   CARDS DE ACESSO RÁPIDO
   SPRINT 8: Card de Ingressos de Eventos removido
============================================================ *@
<AuthorizeView Roles="Aluno,Bolsista">
    <Authorized>
        <MudText Typo="Typo.h6" Class="mb-3">Acesso Rápido</MudText>
        <MudGrid>

            @* Card: Minhas Aulas *@
            <MudItem xs="12" sm="6" md="6">
                <MudCard Elevation="3" Class="rounded-lg h-100"
                         Style="border-left: 4px solid #1b5e20;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Minhas Aulas</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.EventAvailable"
                                     Color="Color.Success" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            Veja as turmas em que está matriculado,
                            links de WhatsApp e avisos específicos.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/minhas-aulas"
                                   Variant="Variant.Text"
                                   Color="Color.Primary">
                            Acessar Turmas
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Card: Aulas Particulares *@
            <MudItem xs="12" sm="6" md="6">
                <MudCard Elevation="3" Class="rounded-lg h-100"
                         Style="border-left: 4px solid #fbc02d;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Aulas Particulares</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                     Color="Color.Warning" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            Agende sessões personalizadas com professores.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/aulas-particulares"
                                   Variant="Variant.Text"
                                   Color="Color.Warning">
                            Agendar Aula
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Card de Ingressos/Eventos removido na Sprint 8 *@
            @* Será reintroduzido na fase 1.2 (Eventos e Ingressos) *@

        </MudGrid>
    </Authorized>
</AuthorizeView>

@code {
    // BUG-008: substituído TurmaResumoDto (TimeSpan) por ObterTurmaResponse (string)
    private ObterTurmaResponse? proximaAula;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var turmas = await Http.GetFromJsonAsync<List<ObterTurmaResponse>>(
                "api/turmas/minhas-turmas");

            if (turmas != null && turmas.Any())
            {
                var hoje = (int)DateTime.Now.DayOfWeek;
                proximaAula = turmas
                    .OrderBy(t => ((t.DiaDaSemana - hoje + 7) % 7))
                    .FirstOrDefault();
            }
        }
        catch
        {
            // Silencioso: não exibe o banner se falhar
        }
    }

    private string DiaDaSemana(int dia) => dia switch
    {
        0 => "Domingo",
        1 => "Segunda-feira",
        2 => "Terça-feira",
        3 => "Quarta-feira",
        4 => "Quinta-feira",
        5 => "Sexta-feira",
        6 => "Sábado",
        _ => "—"
    };
}
