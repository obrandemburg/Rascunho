@* 
  ARQUIVO: Rascunho.Client/Pages/Home.razor
  
  CAUSA DO ERRO CORRIGIDA:
  Havia dois componentes com @page "/":
  - Pages/Home.razor          ← este arquivo (original)
  - Pages/Public/Index.razor  ← criado pelo guia (CONFLITO)
  
  SOLUÇÃO: Este arquivo absorve AMBAS as responsabilidades.
  Ele é a rota "/" única e decide o que renderizar via AuthorizeView:
  
  ┌─────────────────────────────────────────────┐
  │  Usuário NÃO logado → Landing Page pública  │
  │  Usuário logado     → Painel personalizado  │
  └─────────────────────────────────────────────┘
  
  DELETE o arquivo Pages/Public/Index.razor após esta correção.
  
  FLUXO COMPLETO:
  1. Blazor carrega "/"
  2. AuthorizeView verifica o token JWT no LocalStorage
  3. <NotAuthorized> → mostra hero + avisos públicos (sem login)
  4. <Authorized>    → mostra painel com cards por role
*@

@page "/"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Ponto da Dança</PageTitle>

<AuthorizeView>

    @* ══════════════════════════════════════════════════
       ÁREA PÚBLICA — visitante não autenticado
       Exibe: hero section + avisos gerais do mural
    ══════════════════════════════════════════════════ *@
    <NotAuthorized>

        @* ── Hero Section ── *@
        <MudPaper Elevation="0"
                  Class="py-16 px-8 text-center mb-8"
                  Style="background: linear-gradient(135deg, #1b5e20 0%, #2e7d32 60%, #388e3c 100%);
            color: white; border-radius: 16px;">
            <MudText Typo="Typo.h2" Class="font-weight-bold mb-2">
                🎵 Ponto da Dança
            </MudText>
            <MudText Typo="Typo.h5" Class="mb-6" Style="opacity: 0.9;">
                Sua escola de dança em Belo Horizonte
            </MudText>
            <MudButton Href="/quadro-turmas"
                       Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Groups"
                       Class="mr-3">
                Conheça as Turmas
            </MudButton>
            <MudButton Href="/login"
                       Variant="Variant.Outlined"
                       Style="color: white; border-color: white;"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Login">
                Acessar Portal
            </MudButton>
        </MudPaper>

        @* ── Mural de Avisos Públicos ── *@
        <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">
            <MudIcon Icon="@Icons.Material.Filled.Campaign"
                     Class="mr-2"
                     Color="Color.Primary" />
            Avisos & Eventos
        </MudText>

        @if (carregandoAvisos)
        {
            <MudGrid>
                @for (int i = 0; i < 3; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                                     Height="160px"
                                     Class="rounded-lg" />
                    </MudItem>
                }
            </MudGrid>
        }
        else if (!avisos.Any())
        {
            <MudAlert Severity="Severity.Info">
                Nenhum aviso publicado no momento. Volte em breve!
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var aviso in avisos)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100">
                            <div style="height: 4px; background: #1b5e20;
                            border-radius: 8px 8px 0 0;" />
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@aviso.Titulo</MudText>
                                    <MudText Typo="Typo.caption"
                                             Class="mud-text-secondary">
                                        @aviso.DataPublicacao.ToString("dd/MM/yyyy")
                                    </MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">@aviso.Mensagem</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

    </NotAuthorized>

    @* ══════════════════════════════════════════════════
       ÁREA AUTENTICADA — painel personalizado por role
    ══════════════════════════════════════════════════ *@
    <Authorized Context="authContext">

        @* Saudação *@
        <MudText Typo="Typo.h4" Color="Color.Primary"
                 Class="mb-1 font-weight-bold">
            Olá, @authContext.User.Identity?.Name! 👋
        </MudText>
        <MudText Typo="Typo.subtitle1" Class="mb-6 mud-text-secondary">
            Seja bem-vindo(a) ao portal da Ponto da Dança.
        </MudText>

        @* ── ALUNO e BOLSISTA ── *@
        <AuthorizeView Roles="Aluno,Bolsista" Context="alunoCtx">
            <Authorized>
                <MudText Typo="Typo.h6" Class="mb-3">Acesso Rápido</MudText>
                <MudGrid Class="mb-6">

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #1b5e20;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Minhas Aulas</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.EventAvailable"
                                             Color="Color.Success" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Turmas matriculadas, horários e grupo WhatsApp.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/minhas-aulas"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Acessar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #fbc02d;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Aulas Particulares</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.PersonSearch"
                                             Color="Color.Warning" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Agende sessões personalizadas com professores.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/aulas-particulares"
                                           Variant="Variant.Text"
                                           Color="Color.Warning">
                                    Agendar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #9c27b0;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Eventos & Ingressos</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
                                             Color="Color.Secondary" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Compre ingressos para bailes e workshops.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/ingressos"
                                           Variant="Variant.Text"
                                           Color="Color.Secondary">
                                    Ver Eventos
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── PROFESSOR ── *@
        <AuthorizeView Roles="Professor" Context="profCtx">
            <Authorized>
                <MudText Typo="Typo.h6" Class="mb-3">Acesso Rápido — Professor</MudText>
                <MudGrid Class="mb-6">

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #1b5e20;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Minhas Turmas</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.School"
                                             Color="Color.Success" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Turmas que você leciona, horários e alunos.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/minhas-turmas"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Ver Turmas
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #2196f3;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Fazer Chamada</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.Checklist"
                                             Color="Color.Info" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Registre a presença dos alunos em suas aulas.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/fazer-chamada"
                                           Variant="Variant.Text"
                                           Color="Color.Info">
                                    Abrir Diário
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #fbc02d;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Aulas Particulares</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.PersonSearch"
                                             Color="Color.Warning" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Gerencie solicitações e aulas agendadas.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/aulas-particulares"
                                           Variant="Variant.Text"
                                           Color="Color.Warning">
                                    Gerenciar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── BOLSISTA (extras além do Aluno) ── *@
        <AuthorizeView Roles="Bolsista" Context="bolsistaCtx">
            <Authorized>
                <MudText Typo="Typo.h6" Class="mb-3">Área do Bolsista</MudText>
                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #f44336;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Turmas Recomendadas</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.Recommend"
                                             Color="Color.Error" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Turmas do dia que precisam de condutores ou conduzidos.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/bolsista/turmas-recomendadas"
                                           Variant="Variant.Text"
                                           Color="Color.Error">
                                    Ver Recomendadas
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── RECEPÇÃO e GERENTE ── *@
        <AuthorizeView Roles="Recepção,Gerente" Context="adminCtx">
            <Authorized>
                <MudText Typo="Typo.h6" Class="mb-3">Administração</MudText>
                <MudGrid Class="mb-6">

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #2196f3;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Criar Usuário</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd"
                                             Color="Color.Info" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Cadastre alunos, professores e bolsistas.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/admin/usuarios"
                                           Variant="Variant.Text"
                                           Color="Color.Info">
                                    Cadastrar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #1b5e20;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Gerir Turmas</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.ManageHistory"
                                             Color="Color.Success" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Crie e gerencie a grade de turmas da escola.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/admin/turmas"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Abrir Gestão
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #ff9800;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Criar Avisos</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.Campaign"
                                             Color="Color.Warning" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Publique avisos gerais ou para a equipe interna.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/admin/avisos"
                                           Variant="Variant.Text"
                                           Color="Color.Warning">
                                    Publicar Aviso
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>

                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── GERENTE (exclusivo) ── *@
        <AuthorizeView Roles="Gerente" Context="gerenteCtx">
            <Authorized>
                <MudText Typo="Typo.h6" Class="mb-3">Gerência Estratégica</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="rounded-lg h-100"
                                 Style="border-left: 4px solid #f44336;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Gestão de Usuários</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts"
                                             Color="Color.Error" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2">
                                    Ative, desative ou exclua usuários do sistema.
                                </MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="/gerencia/usuarios"
                                           Variant="Variant.Text"
                                           Color="Color.Error">
                                    Gerenciar
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </Authorized>
        </AuthorizeView>

    </Authorized>

</AuthorizeView>

@code {
    private bool carregandoAvisos = true;
    private List<AvisoPublicoDto> avisos = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // GET /api/avisos/geral — AllowAnonymous, não precisa de token
            var res = await Http.GetFromJsonAsync<List<AvisoPublicoDto>>("api/avisos/geral");
            avisos = res ?? new();
        }
        catch
        {
            // Falha silenciosa: não quebra a página inicial
        }
        finally
        {
            carregandoAvisos = false;
        }
    }

    public class AvisoPublicoDto
    {
        public string Titulo { get; set; } = "";
        public string Mensagem { get; set; } = "";
        public DateTime DataPublicacao { get; set; }
    }
}
