                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #1b5e20;">
                            <div class="pd-card-icon" style="background:#e8f5e9;">📈</div>
                            <p class="pd-card-title">Desempenho Bolsistas</p>
                            <p class="pd-card-desc">
                                Quadro completo de frequência.
                                @if (!carregandoDesempenho && totalCriticos > 0)
                                {
                                    <span style="color:#c62828;font-weight:600;"> @totalCriticos em situação crítica!</span>
                                }
                                else if (!carregandoDesempenho)
                                {
                                    <span style="color:#1b5e20;font-weight:600;"> Todos saudáveis ✓</span>
                                }
                            </p>
                            <a href="/gerencia/bolsistas" class="pd-card-link" style="color:#1b5e20;">Ver Quadro</a>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #607d8b;">
                            <div class="pd-card-icon" style="background:#eceff1;">⚙️</div>
                            <p class="pd-card-title">Dashboard Geral</p>
                            <p class="pd-card-desc">Métricas, próximos eventos e atalhos gerenciais.</p>
                            <a href="/gerencia/dashboard" class="pd-card-link" style="color:#607d8b;">Acessar</a>
                        </div>
                    </MudItem>
                </MudGrid>
            </Authorized>
        </AuthorizeView>

    </Authorized>
</AuthorizeView>

@code {
    private bool carregandoAvisos     = true;
    private bool carregandoDesempenho = true;
    private int  totalCriticos        = 0;
    private List<AvisoPublicoDto> avisos = new();

    protected override async Task OnInitializedAsync()
    {
        // Carrega avisos públicos (AllowAnonymous)
        try
        {
            var res = await Http.GetFromJsonAsync<List<AvisoPublicoDto>>("api/avisos/geral");
            avisos = res ?? new();
        }
        catch { }
        finally { carregandoAvisos = false; }

        // Contagem de bolsistas críticos (apenas para Gerente — 403 para outros é esperado)
        try
        {
            var bolsistas = await Http.GetFromJsonAsync<List<BolsistaResumoDto>>(
                "api/gerente/desempenho-bolsistas");
            totalCriticos = bolsistas?.Count(b => b.IndicadorSituacao == "Crítico") ?? 0;
        }
        catch { }
        finally { carregandoDesempenho = false; }
    }

    private class AvisoPublicoDto
    {
        public string   Titulo         { get; set; } = "";
        public string   Mensagem       { get; set; } = "";
        public DateTime DataPublicacao { get; set; }
    }

    private class BolsistaResumoDto
    {
        public string IndicadorSituacao { get; set; } = "";
    }
}
