@page "/"
@using System.Net.Http.Json
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Ponto da Dança — Sua escola em Belo Horizonte</PageTitle>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@@0,700;0,900;1,700&family=Poppins:wght@@300;400;500;600&display=swap');

    :root {
        --pd-g1: #0d3b17; --pd-g2: #1b5e20; --pd-g3: #2e7d32; --pd-g4: #388e3c;
        --pd-gold: #fbc02d; --pd-gold2: #fff176; --pd-cream: #f9f7f2;
        --pd-dark: #12201a; --pd-text: #2c3e30; --pd-muted: #6b7f6e;
    }

    .pd-hero { position:relative; min-height:100vh; display:flex; align-items:center; justify-content:center; overflow:hidden; background:var(--pd-g1); margin:-32px -24px 0; padding:100px 24px 80px; }
    .pd-hero-bg { position:absolute; inset:0; background: radial-gradient(ellipse 80% 60% at 70% 30%, rgba(46,125,50,0.6) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 20% 80%, rgba(27,94,32,0.8) 0%, transparent 60%), linear-gradient(160deg, #0d3b17 0%, #1b5e20 40%, #0d3b17 100%); animation:pd-bg-shift 12s ease-in-out infinite alternate; }
    @@keyframes pd-bg-shift { from{opacity:1} to{opacity:.85} }
    .pd-orb { position:absolute; border-radius:50%; background:radial-gradient(circle, rgba(251,192,45,0.18) 0%, transparent 70%); animation:pd-pulse 6s ease-in-out infinite; }
    .pd-orb-1 { width:700px; height:700px; top:-200px; right:-150px; animation-delay:0s; }
    .pd-orb-2 { width:500px; height:500px; bottom:-150px; left:-100px; animation-delay:-3s; }
    .pd-orb-3 { width:300px; height:300px; top:40%; left:60%; animation-delay:-1.5s; }
    @@keyframes pd-pulse { 0%,100%{transform:scale(1) rotate(0deg);opacity:.6} 50%{transform:scale(1.1) rotate(10deg);opacity:1} }
    .pd-deco-line { position:absolute; width:2px; height:200px; background:linear-gradient(180deg, transparent, rgba(251,192,45,0.4), transparent); animation:pd-line-fall 4s linear infinite; }
    .pd-deco-line:nth-child(1){left:15%;top:-200px;animation-delay:0s}
    .pd-deco-line:nth-child(2){left:40%;top:-200px;animation-delay:1.5s}
    .pd-deco-line:nth-child(3){right:20%;top:-200px;animation-delay:.8s}
    @@keyframes pd-line-fall { from{transform:translateY(0);opacity:0} 10%{opacity:1} 90%{opacity:1} to{transform:translateY(calc(100vh + 300px));opacity:0} }
    .pd-hero-content { position:relative; z-index:10; text-align:center; max-width:820px; width:100%; }
    .pd-hero-eyebrow { display:inline-flex; align-items:center; gap:10px; background:rgba(251,192,45,0.12); border:1px solid rgba(251,192,45,0.35); color:var(--pd-gold); padding:7px 22px; border-radius:100px; font-family:'Poppins',sans-serif; font-size:.72rem; font-weight:600; letter-spacing:.18em; text-transform:uppercase; margin-bottom:28px; animation:pd-fade-in .8s ease forwards; }
    .pd-hero-eyebrow::before{content:'★';font-size:.6rem}
    @@keyframes pd-fade-in { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
    .pd-hero-title { font-family:'Playfair Display',serif; font-size:clamp(3.5rem,10vw,7rem); font-weight:900; color:#fff; line-height:.95; margin:0 0 8px; animation:pd-fade-in .8s ease .15s both; letter-spacing:-.02em; }
    .pd-hero-title-accent { font-style:italic; color:var(--pd-gold); display:block; }
    .pd-hero-divider { width:60px; height:3px; background:linear-gradient(90deg,transparent,var(--pd-gold),transparent); margin:24px auto; animation:pd-fade-in .8s ease .3s both; }
    .pd-hero-sub { font-family:'Poppins',sans-serif; font-size:clamp(1rem,2.5vw,1.2rem); font-weight:300; color:rgba(255,255,255,0.75); margin:0 0 48px; letter-spacing:.03em; animation:pd-fade-in .8s ease .45s both; }
    .pd-hero-btns { display:flex; gap:16px; justify-content:center; flex-wrap:wrap; animation:pd-fade-in .8s ease .6s both; }
    .pd-btn-gold { display:inline-flex; align-items:center; gap:8px; background:var(--pd-gold); color:#1a1200; font-family:'Poppins',sans-serif; font-weight:600; font-size:.95rem; padding:15px 34px; border-radius:100px; text-decoration:none; cursor:pointer; transition:all .3s cubic-bezier(.175,.885,.32,1.275); box-shadow:0 6px 30px rgba(251,192,45,.45); border:none; }
    .pd-btn-gold:hover { background:var(--pd-gold2); transform:translateY(-3px) scale(1.02); box-shadow:0 12px 40px rgba(251,192,45,.55); text-decoration:none; color:#1a1200; }
    .pd-btn-ghost { display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,0.08); backdrop-filter:blur(8px); color:#fff; font-family:'Poppins',sans-serif; font-weight:500; font-size:.95rem; padding:15px 34px; border-radius:100px; text-decoration:none; border:1px solid rgba(255,255,255,0.25); transition:all .3s ease; cursor:pointer; }
    .pd-btn-ghost:hover { background:rgba(255,255,255,0.15); border-color:rgba(255,255,255,0.5); transform:translateY(-2px); text-decoration:none; color:#fff; }
    .pd-scroll { position:absolute; bottom:36px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:6px; color:rgba(255,255,255,.35); font-family:'Poppins',sans-serif; font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; z-index:10; animation:pd-scroll-hint 2.5s ease-in-out infinite; }
    .pd-scroll-bar { width:1px; height:40px; background:linear-gradient(180deg,rgba(251,192,45,.6),transparent); animation:pd-scroll-bar 2.5s ease-in-out infinite; }
    @@keyframes pd-scroll-hint { 0%,100%{opacity:.4} 50%{opacity:.8} }
    @@keyframes pd-scroll-bar { 0%{transform:scaleY(1);transform-origin:top} 50%{transform:scaleY(.3);transform-origin:top} 100%{transform:scaleY(1);transform-origin:top} }
    .pd-section { padding:80px 0 60px; }
    .pd-section-bg { background:var(--pd-cream); margin:0 -24px; padding:80px 24px 60px; }
    .pd-label { font-family:'Poppins',sans-serif; font-size:.7rem; font-weight:600; letter-spacing:.25em; text-transform:uppercase; color:var(--pd-g3); margin-bottom:12px; }
    .pd-heading { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:700; color:var(--pd-dark); line-height:1.15; margin-bottom:48px; }
    .pd-heading em { font-style:italic; color:var(--pd-g3); }
    .pd-feat-card { background:#fff; border-radius:20px; padding:36px 28px; height:100%; box-shadow:0 1px 3px rgba(0,0,0,.05),0 8px 24px rgba(0,0,0,.04); border:1px solid rgba(0,0,0,.06); transition:all .35s cubic-bezier(.175,.885,.32,1.275); position:relative; overflow:hidden; }
    .pd-feat-card::after { content:''; position:absolute; top:0;left:0; width:100%;height:3px; background:linear-gradient(90deg,var(--pd-g2),var(--pd-g4)); transform:scaleX(0); transform-origin:left; transition:transform .35s ease; }
    .pd-feat-card:hover { transform:translateY(-8px); box-shadow:0 24px 60px rgba(27,94,32,.14); }
    .pd-feat-card:hover::after { transform:scaleX(1); }
    .pd-feat-icon { width:64px;height:64px; background:linear-gradient(135deg,#e8f5e9,#c8e6c9); border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:30px; margin-bottom:22px; }
    .pd-feat-title { font-family:'Playfair Display',serif; font-size:1.2rem; font-weight:700; color:var(--pd-dark); margin-bottom:10px; }
    .pd-feat-text { font-family:'Poppins',sans-serif; font-size:.875rem; color:var(--pd-muted); line-height:1.7; margin:0; }
    .pd-stats { background:linear-gradient(135deg,var(--pd-g1) 0%,var(--pd-g3) 100%); border-radius:28px; padding:56px 40px; position:relative; overflow:hidden; }
    .pd-stats::before { content:''; position:absolute; top:-60px;right:-60px; width:300px;height:300px; border-radius:50%; background:rgba(251,192,45,.08); }
    .pd-stat-n { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,5vw,3.5rem); font-weight:900; color:var(--pd-gold); display:block; line-height:1; margin-bottom:6px; }
    .pd-stat-l { font-family:'Poppins',sans-serif; font-size:.8rem; color:rgba(255,255,255,.65); font-weight:300; letter-spacing:.05em; }
    .pd-aviso { background:#fff; border-radius:18px; padding:28px 24px; height:100%; border-left:4px solid var(--pd-g3); box-shadow:0 2px 16px rgba(0,0,0,.05); transition:all .3s ease; }
    .pd-aviso:hover { transform:translateY(-4px); box-shadow:0 12px 36px rgba(27,94,32,.12); }
    .pd-aviso-date { font-family:'Poppins',sans-serif; font-size:.68rem; color:#aaa; letter-spacing:.06em; text-transform:uppercase; margin-bottom:10px; }
    .pd-aviso-titulo { font-family:'Playfair Display',serif; font-size:1.05rem; font-weight:700; color:var(--pd-dark); margin-bottom:10px; }
    .pd-aviso-msg { font-family:'Poppins',sans-serif; font-size:.85rem; color:var(--pd-muted); line-height:1.6; margin:0; }
    .pd-cta-bottom { background:var(--pd-cream); border-radius:28px; padding:64px 40px; text-align:center; margin:40px 0; border:1px solid rgba(27,94,32,.08); }
    .pd-cta-bottom-title { font-family:'Playfair Display',serif; font-size:clamp(1.6rem,3.5vw,2.2rem); color:var(--pd-dark); margin-bottom:14px; }
    .pd-cta-bottom-sub { font-family:'Poppins',sans-serif; font-size:.95rem; color:var(--pd-muted); margin-bottom:36px; max-width:500px; margin-left:auto; margin-right:auto; }
    .pd-dash-hero { background:linear-gradient(135deg,var(--pd-g1) 0%,var(--pd-g3) 100%); border-radius:28px; padding:52px 48px; margin-bottom:48px; position:relative; overflow:hidden; }
    .pd-dash-hero::before { content:'🎵'; position:absolute; right:48px;top:50%; transform:translateY(-50%); font-size:100px; opacity:.1; }
    .pd-dash-greeting { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,2.8rem); font-weight:700; color:#fff; margin:0 0 8px; }
    .pd-dash-sub { font-family:'Poppins',sans-serif; font-size:1rem; color:rgba(255,255,255,.7); font-weight:300; margin:0; }
    .pd-section-heading { font-family:'Playfair Display',serif; font-size:1.3rem; font-weight:700; color:var(--pd-dark); margin-bottom:20px; padding-bottom:12px; border-bottom:2px solid #f0ede6; }
    .pd-card { background:#fff; border-radius:20px; padding:28px 24px 20px; height:100%; box-shadow:0 1px 4px rgba(0,0,0,.05),0 4px 16px rgba(0,0,0,.04); border-top:4px solid; transition:all .3s ease; display:flex; flex-direction:column; }
    .pd-card:hover { transform:translateY(-5px); box-shadow:0 16px 48px rgba(0,0,0,.1); }
    .pd-card-icon { width:48px;height:48px; border-radius:14px; display:flex;align-items:center;justify-content:center; font-size:22px; margin-bottom:16px; flex-shrink:0; }
    .pd-card-title { font-family:'Playfair Display',serif; font-size:1.1rem; font-weight:700; color:var(--pd-dark); margin-bottom:8px; }
    .pd-card-desc { font-family:'Poppins',sans-serif; font-size:.82rem; color:var(--pd-muted); line-height:1.6; flex:1; margin-bottom:20px; }
    .pd-card-link { font-family:'Poppins',sans-serif; font-size:.85rem; font-weight:600; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:gap .2s ease; margin-top:auto; }
    .pd-card-link:hover{gap:10px;text-decoration:none}
    .pd-card-link::after{content:'→'}
    @@media (max-width:640px) {
        .pd-hero{margin:-16px -16px 0;padding:80px 16px 70px}
        .pd-stats{padding:40px 20px}
        .pd-dash-hero{padding:36px 28px}
        .pd-dash-hero::before{display:none}
        .pd-cta-bottom{padding:44px 24px}
        .pd-section-bg{margin:0 -16px;padding:60px 16px 48px}
    }
</style>

<AuthorizeView>

    @* ══════════════════════════════════════════════════════════════
       LANDING PAGE — visitante não autenticado
    ══════════════════════════════════════════════════════════════ *@
    <NotAuthorized>

        @* ── HERO ── *@
        <div class="pd-hero">
            <div class="pd-hero-bg"></div>
            <div class="pd-orb pd-orb-1"></div>
            <div class="pd-orb pd-orb-2"></div>
            <div class="pd-orb pd-orb-3"></div>
            <div class="pd-deco-line"></div>
            <div class="pd-deco-line"></div>
            <div class="pd-deco-line"></div>
            <div class="pd-hero-content">
                <div class="pd-hero-eyebrow">Escola de Dança em BH</div>
                <h1 class="pd-hero-title">
                    Ponto
                    <span class="pd-hero-title-accent">da Dança</span>
                </h1>
                <div class="pd-hero-divider"></div>
                <p class="pd-hero-sub">
                    Onde a música encontra o movimento.<br/>
                    Encontre seu ritmo, transforme sua vida.
                </p>
                <div class="pd-hero-btns">
                    <a href="/quadro-turmas" class="pd-btn-gold">💃 Ver Turmas</a>
                    <a href="/login" class="pd-btn-ghost">Acessar Portal</a>
                </div>
            </div>
            <div class="pd-scroll">
                <span>Role para ver</span>
                <div class="pd-scroll-bar"></div>
            </div>
        </div>

        @* ── POR QUE NOS ESCOLHER ── *@
        <div class="pd-section">
            <div style="text-align:center">
                <p class="pd-label">Nossa proposta</p>
                <h2 class="pd-heading" style="margin-bottom:52px;">
                    Uma experiência completa<br/>de <em>dança e comunidade</em>
                </h2>
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6" md="4">
                    <div class="pd-feat-card">
                        <div class="pd-feat-icon">🎓</div>
                        <p class="pd-feat-title">Todos os Níveis</p>
                        <p class="pd-feat-text">Do primeiro passo ao palco. Turmas desde iniciante até avançado, com progressão clara e professores dedicados.</p>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <div class="pd-feat-card">
                        <div class="pd-feat-icon">🏆</div>
                        <p class="pd-feat-title">Professores Apaixonados</p>
                        <p class="pd-feat-text">Nossa equipe transforma cada aula em uma experiência. Aprenda com quem vive e respira a dança todos os dias.</p>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <div class="pd-feat-card">
                        <div class="pd-feat-icon">🎵</div>
                        <p class="pd-feat-title">Múltiplos Ritmos</p>
                        <p class="pd-feat-text">Forró, Salsa, Samba, Zouk e mais. Explore a riqueza da dança brasileira e encontre o ritmo que é seu.</p>
                    </div>
                </MudItem>
            </MudGrid>
        </div>

        @* ── STATS ── *@
        <div class="pd-stats">
            <MudGrid Spacing="4" Justify="Justify.Center">
                <MudItem xs="12" sm="4" Class="text-center">
                    <span class="pd-stat-n">+200</span>
                    <span class="pd-stat-l">Alunos formados</span>
                </MudItem>
                <MudItem xs="12" sm="4" Class="text-center">
                    <span class="pd-stat-n">8+</span>
                    <span class="pd-stat-l">Ritmos disponíveis</span>
                </MudItem>
                <MudItem xs="12" sm="4" Class="text-center">
                    <span class="pd-stat-n">5★</span>
                    <span class="pd-stat-l">Avaliação dos alunos</span>
                </MudItem>
            </MudGrid>
        </div>

        @* ── AVISOS PÚBLICOS ── *@
        <div class="pd-section">
            @if (carregandoAvisos)
            {
                <MudGrid Spacing="3">
                    @for (int i = 0; i < 3; i++)
                    {
                        <MudItem xs="12" sm="4">
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="160px" Class="rounded-xl" />
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (avisos.Any())
            {
                <div class="text-center" style="margin-bottom:48px;">
                    <p class="pd-label">Comunicados</p>
                    <h2 class="pd-heading" style="margin-bottom:0;">Novidades da escola</h2>
                </div>
                <MudGrid Spacing="3">
                    @foreach (var aviso in avisos)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <div class="pd-aviso">
                                <p class="pd-aviso-date">@aviso.DataPublicacao.ToString("dd 'de' MMMM", new CultureInfo("pt-BR"))</p>
                                <p class="pd-aviso-titulo">@aviso.Titulo</p>
                                <p class="pd-aviso-msg">@aviso.Mensagem</p>
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            }
        </div>

        @* ── CTA FINAL ── *@
        <div class="pd-cta-bottom">
            <p class="pd-cta-bottom-title">Pronto para começar a dançar?</p>
            <p class="pd-cta-bottom-sub">Acesse o portal, escolha sua turma favorita e comece ainda hoje.<br/>Primeira aula é gratuita!</p>
            <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
                <a href="/login" class="pd-btn-gold">Criar minha conta</a>
                <a href="/turmas" class="pd-btn-ghost" style="background:transparent;border:1px solid #1b5e20;color:#1b5e20;">Ver ritmos disponíveis</a>
            </div>
        </div>

    </NotAuthorized>

    @* ══════════════════════════════════════════════════════════════
       DASHBOARD — usuário autenticado (por perfil)
    ══════════════════════════════════════════════════════════════ *@
    <Authorized Context="authContext">

        <div class="pd-dash-hero">
            <p class="pd-dash-greeting">
                Olá, @(authContext.User.Identity?.Name?.Split(' ').FirstOrDefault() ?? "bem-vindo")! 👋
            </p>
            <p class="pd-dash-sub">
                Seja bem-vindo(a) ao portal da Ponto da Dança. Aqui está o seu acesso rápido.
            </p>
        </div>

        @* ── ALUNO e BOLSISTA
             SPRINT 8: card "Eventos & Ingressos" removido.
             Será reintroduzido na fase 1.2 com funcionalidade completa.
        *@
        <AuthorizeView Roles="Aluno,Bolsista" Context="alunoCtx">
            <Authorized>
                <p class="pd-section-heading">Minha Área</p>
                <MudGrid Spacing="3" Class="mb-8">
                    <MudItem xs="12" sm="6" md="6">
                        <div class="pd-card" style="border-color: #1b5e20;">
                            <div class="pd-card-icon" style="background:#e8f5e9;">📅</div>
                            <p class="pd-card-title">Minhas Aulas</p>
                            <p class="pd-card-desc">Turmas matriculadas, horários e links do grupo WhatsApp.</p>
                            <a href="/minhas-aulas" class="pd-card-link" style="color:#1b5e20;">Acessar</a>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="6">
                        <div class="pd-card" style="border-color: #f59f00;">
                            <div class="pd-card-icon" style="background:#fff8e1;">🎯</div>
                            <p class="pd-card-title">Aulas Particulares</p>
                            <p class="pd-card-desc">Agende sessões personalizadas com professores da escola.</p>
                            <a href="/aulas-particulares" class="pd-card-link" style="color:#f59f00;">Agendar</a>
                        </div>
                    </MudItem>
                    @* Card de Eventos/Ingressos removido na Sprint 8 — fase 1.2 *@
                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── PROFESSOR ── *@
        <AuthorizeView Roles="Professor" Context="profCtx">
            <Authorized>
                <p class="pd-section-heading">Área do Professor</p>
                <MudGrid Spacing="3" Class="mb-8">
                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #1b5e20;">
                            <div class="pd-card-icon" style="background:#e8f5e9;">🏫</div>
                            <p class="pd-card-title">Minhas Turmas</p>
                            <p class="pd-card-desc">Turmas vinculadas ao seu perfil, com lista de alunos e atalho para chamada.</p>
                            <a href="/professor/minhas-turmas" class="pd-card-link" style="color:#1b5e20;">Ver Turmas</a>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #1565c0;">
                            <div class="pd-card-icon" style="background:#e3f2fd;">✅</div>
                            <p class="pd-card-title">Fazer Chamada</p>
                            <p class="pd-card-desc">Registre presenças com seção B para bolsistas e alunos experimentais.</p>
                            <a href="/professor/chamada" class="pd-card-link" style="color:#1565c0;">Abrir Diário</a>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #f59f00;">
                            <div class="pd-card-icon" style="background:#fff8e1;">👤</div>
                            <p class="pd-card-title">Aulas Particulares</p>
                            <p class="pd-card-desc">Gerencie solicitações, aulas agendadas e sua disponibilidade semanal.</p>
                            <a href="/professor/aulas-particulares" class="pd-card-link" style="color:#f59f00;">Gerenciar</a>
                        </div>
                    </MudItem>
                </MudGrid>
            </Authorized>
        </AuthorizeView>

        @* ── BOLSISTA (extras além de aluno) ── *@
        <AuthorizeView Roles="Bolsista" Context="bolCtx">
            <Authorized>
                <p class="pd-section-heading">Área do Bolsista</p>
                <MudGrid Spacing="3" Class="mb-8">
                    <MudItem xs="12" sm="6" md="4">
                        <div class="pd-card" style="border-color: #d32f2f;">
                            <div class="pd-card-icon" style="background:#ffebee;">📊</div>
                            <p class="pd-card-title">Meu Desempenho</p>
                            <p class="pd-card-desc">Acompanhe sua frequência nos dias obrigatórios e histórico de presenças.</p>
                            <a href="/bolsista/desempenho" class="pd-card-link" style="color:#d32f2f;">Ver Desempenho</a>
                        </div>
                    </MudItem>
