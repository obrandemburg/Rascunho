@page "/gerencia/usuarios"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using Rascunho.Client.Shared
@using Rascunho.Shared.DTOs
@attribute [Authorize(Roles = "Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Gestão de Usuários — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="mr-2" />
    Gestão de Usuários
</MudText>
<MudText Class="mb-6 mud-text-secondary">
    Gerencie todos os usuários cadastrados no sistema.
</MudText>

<MudPaper Elevation="1" Class="pa-4 mb-6 rounded-lg border-solid border-2 mud-border-primary">
    <MudText Typo="Typo.subtitle2" Class="mb-2">Busca Rápida de Alunos e Bolsistas (Matrícula)</MudText>
    <MudAutocomplete T="BuscarUsuarioResponse"
                     Label="Digite o nome ou CPF..."
                     SearchFunc="@BuscarAlunosAutocomplete"
                     ToStringFunc="@(u => u == null ? null : $"{u.Nome} ({u.Tipo})")"
                     ResetValueOnEmptyText="true"
                     Variant="Variant.Outlined"
                     AdornmentIcon="@Icons.Material.Filled.Search"
                     Clearable="true">
        <ItemTemplate Context="aluno">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudAvatar Size="Size.Small" Image="@aluno.FotoUrl" Color="Color.Primary" />
                <MudText>@aluno.Nome</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@aluno.Tipo</MudChip>
            </MudStack>
        </ItemTemplate>
    </MudAutocomplete>
</MudPaper>

<MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="filtroNome"
                          Label="Buscar por nome no grid"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.FilterAlt"
                          Immediate="true" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="string"
                       @bind-Value="filtroTipo"
                       Label="Tipo"
                       Variant="Variant.Outlined"
                       Clearable="true">
                <MudSelectItem T="string" Value="@("Aluno")">Aluno</MudSelectItem>
                <MudSelectItem T="string" Value="@("Professor")">Professor</MudSelectItem>
                <MudSelectItem T="string" Value="@("Bolsista")">Bolsista</MudSelectItem>
                <MudSelectItem T="string" Value="@("Recepção")">Recepção</MudSelectItem>
                <MudSelectItem T="string" Value="@("Gerente")">Gerente</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="string"
                       @bind-Value="filtroStatus"
                       Label="Status"
                       Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("desativados")">Desativados</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton OnClick="AplicarFiltrosGrid"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true">
                Filtrar
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudDataGrid T="UsuarioDto"
             ServerData="@CarregarDadosServidor"
             @ref="grid"
             Sortable="false"
             Hover="true"
             Dense="true"
             Elevation="3"
             Class="rounded-xl">
    <Columns>
        <TemplateColumn Title="" CellClass="pa-1" HeaderStyle="width: 52px;">
            <CellTemplate Context="cell">
                <UserAvatar FotoUrl="@cell.Item.FotoUrl"
                            Nome="@cell.Item.Nome"
                            Size="Size.Small"
                            Color="@CorTipoAvatar(cell.Item.Tipo)" />
            </CellTemplate>
        </TemplateColumn>

        <PropertyColumn Property="u => u.Nome" Title="Nome" />
        <PropertyColumn Property="u => u.Email" Title="E-mail" />
        <TemplateColumn Title="Tipo">
            <CellTemplate Context="cell">
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@CorTipo(cell.Item.Tipo)"
                         Variant="Variant.Filled">
                    @cell.Item.Tipo
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Status">
            <CellTemplate Context="cell">
                <MudSwitch T="bool"
                           Value="@cell.Item.Ativo"
                           ValueChanged="@((bool v) => OnStatusChanged(cell.Item, v))"
                           Color="Color.Success"
                           Label="@(cell.Item.Ativo ? "Ativo" : "Inativo")" />
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Ações" CellClass="d-flex justify-end">
            <CellTemplate Context="cell">
                <MudTooltip Text="Excluir permanentemente">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => ConfirmarExclusao(cell.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="UsuarioDto" RowsPerPageString="Itens por página:" />
    </PagerContent>
</MudDataGrid>


@code {
    private MudDataGrid<UsuarioDto>? grid;
    
    // Filtros do grid
    private string filtroNome = "";
    private string filtroTipo = "";
    private string filtroStatus = "todos";

    // Busca no Autocomplete (Endpoint de buscar)
    private async Task<IEnumerable<BuscarUsuarioResponse>> BuscarAlunosAutocomplete(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
            return new List<BuscarUsuarioResponse>();

        try
        {
            // O endpoint que já existe: group.MapGet("/buscar" ...
            return await Http.GetFromJsonAsync<List<BuscarUsuarioResponse>>($"api/usuarios/buscar?q={value}", token) ?? new();
        }
        catch
        {
            return new List<BuscarUsuarioResponse>();
        }
    }

    // Paginação no Servidor
    private async Task<GridData<UsuarioDto>> CarregarDadosServidor(GridState<UsuarioDto> state, CancellationToken token)
    {
        try
        {
            var url = $"api/usuarios/listar-paginado?page={state.Page}&pageSize={state.PageSize}";
            
            if (!string.IsNullOrWhiteSpace(filtroNome)) url += $"&nome={Uri.EscapeDataString(filtroNome)}";
            if (!string.IsNullOrWhiteSpace(filtroTipo)) url += $"&tipo={Uri.EscapeDataString(filtroTipo)}";
            if (!string.IsNullOrWhiteSpace(filtroStatus)) url += $"&status={Uri.EscapeDataString(filtroStatus)}";

            // Repassando o 'token' para o GetFromJsonAsync
            var response = await Http.GetFromJsonAsync<PaginacaoResponse<UsuarioDto>>(url, token);

            if (response != null)
            {
                return new GridData<UsuarioDto>
                {
                    TotalItems = response.TotalItens,
                    Items = response.Itens.ToList()
                };
            }
        }
        catch (TaskCanceledException)
        {
            // Ignora o erro se a requisição foi cancelada intencionalmente pelo MudBlazor ao mudar de página rápido
        }
        catch
        {
            Snackbar.Add("Erro ao carregar usuários.", Severity.Error);
        }

        return new GridData<UsuarioDto> { TotalItems = 0, Items = new List<UsuarioDto>() };
    }

    // Recarrega o grid aplicando os filtros e voltando para a página 1
    private async Task AplicarFiltrosGrid()
    {
        if (grid != null)
        {
            await grid.ReloadServerData();
        }
    }

    private async Task OnStatusChanged(UsuarioDto usuario, bool novoStatus)
    {
        var response = await Http.PutAsJsonAsync($"api/usuarios/status/{usuario.IdHash}", novoStatus);

        if (response.IsSuccessStatusCode)
        {
            usuario.Ativo = novoStatus;
            Snackbar.Add($"{usuario.Nome} {(novoStatus ? "ativado" : "desativado")}.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Erro ao alterar status.", Severity.Error);
        }
    }

    private async Task ConfirmarExclusao(UsuarioDto usuario)
    {
        var parametros = new DialogParameters
        {
            { "ContentText", $"⚠️ ATENÇÃO: Excluir {usuario.Nome} é permanente e irreversível.\n\nDeseja continuar?" },
            { "ButtonText", "Excluir Permanentemente" },
            { "Color", Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirmar Exclusão", parametros);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var response = await Http.DeleteAsync($"api/usuarios/deletar/{usuario.IdHash}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"{usuario.Nome} excluído permanentemente.", Severity.Warning);
                await AplicarFiltrosGrid(); // Recarrega os dados do servidor após exclusão
            }
        }
    }

    private Color CorTipo(string tipo) => tipo switch
    {
        "Gerente" => Color.Error,
        "Recepção" => Color.Warning,
        "Professor" => Color.Info,
        "Bolsista" => Color.Secondary,
        _ => Color.Default
    };

    private Color CorTipoAvatar(string tipo) => tipo switch
    {
        "Gerente" => Color.Error,
        "Recepção" => Color.Warning,
        "Professor" => Color.Info,
        "Bolsista" => Color.Secondary,
        _ => Color.Primary
    };

    public class UsuarioDto
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
        public string Email { get; set; } = "";
        public string Tipo { get; set; } = "";
        public bool Ativo { get; set; }
        public string FotoUrl { get; set; } = "";
    }
}