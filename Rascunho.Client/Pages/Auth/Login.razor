@page "/login"
@using System.Net.Http.Json
@using Blazored.LocalStorage
@using Microsoft.AspNetCore.Components.Authorization
@using Rascunho.Client.Security
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl border-t-4 border-solid" Style="border-top-color: #4caf50;">
        <div class="d-flex justify-center mb-4">
            <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Success" Size="Size.Large" />
        </div>
        <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Success" Class="mb-6 font-weight-bold">
            Ponto da Dança
        </MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6">
            Faça login para acessar o seu portal.
        </MudText>

        <EditForm Model="@loginModel" OnValidSubmit="RealizarLogin">
            <MudTextField @bind-Value="loginModel.Email"
                          Label="E-mail"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4"
                          InputType="InputType.Email"
                          Required="true" />

            <MudTextField @bind-Value="loginModel.Senha"
                          Label="Senha"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-6"
                          InputType="InputType.Password"
                          Required="true" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Success"
                       Size="Size.Large"
                       FullWidth="true"
                       Disabled="@carregando">
                @if (carregando)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Autenticando...</MudText>
                }
                else
                {
                    <MudText>Entrar no Sistema</MudText>
                }
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private bool carregando = false;
    private LoginRequest loginModel = new();

    // Classes espelhando o payload da API
    public class LoginRequest
    {
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }

    public class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
    }

    private async Task RealizarLogin()
    {
        carregando = true;

        try
        {
            // Dispara requisição para o endpoint de produção (AllowAnonymous)
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                
                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    // 1. Salva o Token no Local Storage (Armazenamento do Navegador)
                    await LocalStorage.SetItemAsync("authToken", result.Token);
                    
                    // 2. Avisa a aplicação que o usuário logou (Atualiza o estado global)
                    var customAuthStateProvider = (CustomAuthStateProvider)AuthStateProvider;
                    customAuthStateProvider.NotifyUserAuthentication(result.Token);

                    // 3. Redireciona para o painel principal
                    Snackbar.Add("Login realizado com sucesso!", Severity.Success);
                    NavManager.NavigateTo("/");
                }
            }
            else
            {
                // Tratamento de erro (Ex: 400 Bad Request se a senha estiver errada)
                Snackbar.Add("E-mail ou senha incorretos.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao conectar com o servidor.", Severity.Error);
        }
        finally
        {
            carregando = false;
        }
    }
}