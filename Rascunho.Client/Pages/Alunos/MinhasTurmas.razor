@page "/minhas-aulas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Aluno,Bolsista")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Success" Class="mb-2 font-weight-bold">Minhas Aulas</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6">Confira sua grade de horários e materiais das turmas.</MudText>

    @if (carregando)
    {
        <MudProgressCircular Color="Color.Success" Indeterminate="true" />
    }
    else if (!turmasMatriculadas.Any())
    {
        <MudAlert Severity="Severity.Info">Você ainda não possui matrículas ativas. Vá ao <a href="/quadro-turmas">Quadro de Turmas</a> para começar!</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasMatriculadas)
            {
                <MudItem xs="12" md="6">
                    <MudCard Elevation="4" Class="rounded-xl border-l-8 border-solid" Style="border-left-color: #2e7d32;">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h5" Color="Color.Success">@turma.RitmoNome</MudText>
                                <MudText Typo="Typo.caption">Professor(a): @turma.ProfessorNome</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Text">@turma.Nivel</MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex align-center mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-2" />
                                <MudText Typo="Typo.body1">@turma.DiaSemana às @turma.HorarioInicio</MudText>
                            </div>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Room" Size="Size.Small" Class="mr-2" />
                                <MudText Typo="Typo.body2">Sala: @turma.SalaNome</MudText>
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled"
                                       StartIcon="@Icons.Custom.Brands.WhatsApp"
                                       Color="Color.Success"
                                       Href="@turma.LinkWhatsapp"
                                       Target="_blank"
                                       Class="mr-2">
                                Grupo da Turma
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Success" Href="@($"/turmas/{turma.IdHash}/mural")">Mural da Turma</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private bool carregando = true;
    private List<MinhaTurmaAlunoDto> turmasMatriculadas = new();

    public class MinhaTurmaAlunoDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string ProfessorNome { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string Nivel { get; set; } = "";
        public string SalaNome { get; set; } = "";
        public string LinkWhatsapp { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // O endpoint utiliza o Token JWT para saber quem é o aluno [cite: 23]
            var result = await Http.GetFromJsonAsync<List<MinhaTurmaAlunoDto>>("api/turmas/minhas");
            if (result != null) turmasMatriculadas = result;
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar suas turmas.", Severity.Error);
        }
        finally { carregando = false; }
    }
}