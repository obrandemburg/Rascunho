@page "/aulas-particulares"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Aluno,Bolsista")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2 font-weight-bold">Aulas Particulares</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6">Acelere seu aprendizado com atenção exclusiva. Escolha um professor e proponha um horário.</MudText>

    <MudPaper Elevation="2" Class="pa-6 rounded-xl border-l-4 border-solid" Style="border-left-color: #fbc02d;">
        <EditForm Model="@solicitacao" OnValidSubmit="EnviarSolicitacao">
            <MudGrid>
                <MudItem xs="12" md="12">
                    <MudSelect T="string" Label="Escolha o Professor" @bind-Value="solicitacao.ProfessorIdHash" Variant="Variant.Outlined" Required="true" AnchorOrigin="Origin.BottomCenter">
                        @foreach (var prof in professores)
                        {
                            <MudSelectItem Value="@prof.IdHash">@prof.Nome</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker Label="Data da Aula" @bind-Date="dataAula" Variant="Variant.Outlined" Required="true" DisableToolbar="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTimePicker Label="Horário de Início" @bind-Time="horaInicio" Variant="Variant.Outlined" Required="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTimePicker Label="Horário de Fim" @bind-Time="horaFim" Variant="Variant.Outlined" Required="true" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Send">
                        Enviar Convite ao Professor
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private SolicitacaoAulaDto solicitacao = new();
    private DateTime? dataAula = DateTime.Today.AddDays(1);
    private TimeSpan? horaInicio = new TimeSpan(14, 0, 0);
    private TimeSpan? horaFim = new TimeSpan(15, 0, 0);

    private List<ItemSimplesDto> professores = new();

    public class SolicitacaoAulaDto
    {
        public string ProfessorIdHash { get; set; } = "";
        public DateTime DataHoraInicio { get; set; }
        public DateTime DataHoraFim { get; set; }
    }

    public class ItemSimplesDto
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<List<ItemSimplesDto>>("api/usuarios/listar/tipo/Professor");
            if (res != null) professores = res;
        }
        catch { /* Tratamento silencioso ou log */ }
    }

    private async Task EnviarSolicitacao()
    {
        if (dataAula.HasValue && horaInicio.HasValue && horaFim.HasValue)
        {
            // Mescla a data com a hora selecionada
            solicitacao.DataHoraInicio = dataAula.Value.Date + horaInicio.Value;
            solicitacao.DataHoraFim = dataAula.Value.Date + horaFim.Value;

            if (solicitacao.DataHoraFim <= solicitacao.DataHoraInicio)
            {
                Snackbar.Add("O horário de fim deve ser depois do início.", Severity.Warning);
                return;
            }

            var response = await Http.PostAsJsonAsync("api/aulas-particulares/solicitar", solicitacao);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Solicitação enviada! Aguarde a confirmação do professor.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Não foi possível enviar a solicitação. Verifique os dados.", Severity.Error);
            }
        }
    }
}