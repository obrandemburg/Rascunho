@*
  ═══════════════════════════════════════════════════════════════════════════
  ARQUIVO: Rascunho.Client/Pages/Public/RitmosPublico.razor
  ROTA:    /ritmos
  ACESSO:  Anônimo (página pública)

  SPRINT 9 — TAREFA S9-03:
  ALTERAÇÕES:
    1. MudChipSet: substituído SelectedValues + SelectedValuesChanged (one-way)
       por @bind-SelectedValues (two-way binding automático)
    2. REMOVIDO o método OnFiltroChanged (desnecessário com two-way binding)
    3. ADICIONADO filtro Ativo == true no ritmosFiltrados (exibe apenas ativos)
    4. ADICIONADO campo Ativo no RitmoDto (necessário para o filtro)

  COMO RESOLVE O BUG:
  O problema era que o MudChipSet usava binding ONE-WAY:
    SelectedValues="modalidadesSelecionadas"           ← o componente LÊ o valor
    SelectedValuesChanged="OnFiltroChanged"             ← callback manual para ESCREVER

  O callback OnFiltroChanged até atualizava a variável e chamava StateHasChanged(),
  mas no MudBlazor 9.x o MudChipSet precisa que o valor ESCRITO de volta no
  SelectedValues seja a mesma referência que ele gerencia internamente.
  Com one-way binding, o componente não sabe que o valor foi atualizado.

  A solução é @bind-SelectedValues, que faz TWO-WAY binding:
    - O MudChipSet LÊ E ESCREVE na mesma variável automaticamente
    - O Blazor detecta a mudança e re-renderiza (recalculando ritmosFiltrados)
    - É o mesmo padrão usado com sucesso em Turmas.razor e GerenciarRitmos.razor

  RESULTADO:
    - Clicar "Dança de Salão" → filtra instantaneamente
    - Clicar "Dança Solo" → filtra instantaneamente  
    - Clicar ambos → mostra ambas modalidades
    - Nenhum clicado → mostra todos os ritmos ativos
  ═══════════════════════════════════════════════════════════════════════════
*@

@page "/ritmos"
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Ritmos — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Class="mr-2" />
    Conheça os Ritmos
</MudText>
<MudText Typo="Typo.body1" Class="mb-6 mud-text-secondary">
    Explore os ritmos que ensinamos e encontre a modalidade perfeita para você!
</MudText>

@*
  SPRINT 9 — S9-03: CORREÇÃO DO BUG DE FILTRO
  
  ANTES (QUEBRADO — one-way binding):
    <MudChipSet T="string"
                SelectedValues="modalidadesSelecionadas"
                SelectedValuesChanged="OnFiltroChanged"
                MultiSelection="true">

  DEPOIS (CORRIGIDO — two-way binding):
    <MudChipSet T="string"
                @bind-SelectedValues="modalidadesSelecionadas"
                MultiSelection="true">
    
  @bind-SelectedValues faz com que o MudChipSet:
    1. LEIA o valor inicial de modalidadesSelecionadas (Array.Empty)
    2. ESCREVA de volta quando o usuário clica num chip
    3. O Blazor detecta a mudança e recalcula ritmosFiltrados automaticamente
*@
<MudChipSet T="string"
            @bind-SelectedValues="modalidadesSelecionadas"
            MultiSelection="true"
            Class="mb-6">
    <MudChip T="string" Value="@("Dança de salão")" Color="Color.Primary" Variant="Variant.Outlined">
        Dança de Salão
    </MudChip>
    <MudChip T="string" Value="@("Dança solo")" Color="Color.Info" Variant="Variant.Outlined">
        Dança Solo
    </MudChip>
</MudChipSet>

@if (carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (!ritmosFiltrados.Any())
{
    <MudAlert Severity="Severity.Info">
        Nenhum ritmo encontrado para o filtro selecionado.
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var ritmo in ritmosFiltrados)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="rounded-lg h-100"
                         Style="@($"border-top: 4px solid {(ritmo.Modalidade == "Dança de salão" ? "#1b5e20" : "#2196f3")};")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@ritmo.Nome</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(ritmo.Modalidade == "Dança de salão" ? Color.Success : Color.Info)"
                                     Variant="Variant.Filled">
                                @ritmo.Modalidade
                            </MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">
                            @(string.IsNullOrEmpty(ritmo.Descricao) ? "Em breve mais informações!" : ritmo.Descricao)
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool carregando = true;
    private List<RitmoDto> ritmos = new();

    // Tipo IReadOnlyCollection<string> — exigido pelo MudChipSet T="string"
    // Inicializado como Array.Empty para evitar NullReferenceException
    private IReadOnlyCollection<string> modalidadesSelecionadas = Array.Empty<string>();

    /// <summary>
    /// Propriedade computada que filtra os ritmos exibidos.
    /// Recalcula automaticamente quando modalidadesSelecionadas muda
    /// (graças ao two-way binding que dispara re-render do Blazor).
    ///
    /// SPRINT 9 — S9-03:
    ///   - Adicionado filtro r.Ativo (exibe apenas ritmos ativos na página pública)
    ///   - Sem essa condição, ritmos desativados pelo admin apareciam na vitrine
    /// </summary>
    private IEnumerable<RitmoDto> ritmosFiltrados
    {
        get
        {
            // Primeiro: filtra apenas ritmos ativos (página pública não deve exibir inativos)
            var ativos = ritmos.Where(r => r.Ativo);

            // Depois: aplica filtro de modalidade se algum chip estiver selecionado
            return modalidadesSelecionadas.Any()
                ? ativos.Where(r => modalidadesSelecionadas.Contains(r.Modalidade))
                : ativos;
        }
    }

    // SPRINT 9 — S9-03: REMOVIDO o método OnFiltroChanged
    // Com @bind-SelectedValues, o MudChipSet atualiza modalidadesSelecionadas
    // automaticamente. Não precisa de callback manual.
    //
    // ANTES (desnecessário):
    //   private void OnFiltroChanged(IReadOnlyCollection<string> values)
    //   {
    //       modalidadesSelecionadas = values;
    //       StateHasChanged();
    //   }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ritmos = await Http.GetFromJsonAsync<List<RitmoDto>>("api/ritmos/listar") ?? new();
        }
        catch
        {
            // Silencioso — não quebra página pública para visitantes
        }
        finally { carregando = false; }
    }

    /// <summary>
    /// DTO local espelhando ObterRitmoResponse do backend.
    /// SPRINT 9 — S9-03: Adicionado campo Ativo (bool) para filtrar
    /// ritmos inativos na exibição pública.
    /// </summary>
    public class RitmoDto
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
        public string? Descricao { get; set; }
        public string Modalidade { get; set; } = "";
        public bool Ativo { get; set; }  // ← SPRINT 9: necessário para filtrar inativos
    }
}
