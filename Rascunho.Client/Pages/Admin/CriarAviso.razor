@* 
  ARQUIVO: Rascunho.Client/Pages/Admin/CriarAviso.razor
  ROTA:    /admin/avisos
  ACESSO:  Recepção, Gerente
*@

@page "/admin/avisos"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Criar Aviso — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="mr-2" />
    Publicar Aviso no Mural
</MudText>

<MudGrid>
    @* ── Formulário ─────────────────────────────────────────────── *@
    <MudItem xs="12" md="7">
        <MudPaper Elevation="4" Class="pa-8 rounded-xl">
            <EditForm Model="@novoAviso" OnValidSubmit="PublicarAviso">

                <MudTextField @bind-Value="novoAviso.Titulo"
                              Label="Título do Aviso"
                              Variant="Variant.Outlined"
                              Class="mb-4"
                              MaxLength="150"
                              HelperText="Máximo 150 caracteres"
                              Required="true" />

                <MudTextField @bind-Value="novoAviso.Mensagem"
                              Label="Conteúdo do Aviso"
                              Variant="Variant.Outlined"
                              Lines="5"
                              Class="mb-4"
                              MaxLength="1000"
                              HelperText="Máximo 1000 caracteres" />

                @*
                  RadioGroup para tipo de visibilidade.
                  Valores exatos que a API aceita (case-sensitive!):
                    "Geral"  → AllowAnonymous, visível no site público
                    "Equipe" → requer role Professor/Bolsista/Líder/Recepção/Gerente
                *@
                <MudText Typo="Typo.body1" Class="mb-2">Visibilidade:</MudText>
                <MudRadioGroup T="string" @bind-Value="novoAviso.TipoVisibilidade" Class="mb-4">
                    <MudRadio Value="@("Geral")" Color="Color.Primary">
                        🌐 Geral (visível no site público, sem login)
                    </MudRadio>
                    <MudRadio Value="@("Equipe")" Color="Color.Info">
                        🔒 Equipe (apenas professores, bolsistas e staff)
                    </MudRadio>
                </MudRadioGroup>

                @*
                  Data de expiração: obrigatória e deve ser no futuro.
                  MinDate = amanhã para bloquear datas passadas já no picker.
                  A API também valida: DataExpiracao > DateTime.UtcNow.
                *@
                <MudDatePicker @bind-Date="dataExpiracao"
                               Label="Válido até"
                               Variant="Variant.Outlined"
                               Class="mb-6"
                               MinDate="@DateTime.Today.AddDays(1)"
                               DateFormat="dd/MM/yyyy"
                               HelperText="O aviso desaparece automaticamente após essa data" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@publicando"
                           StartIcon="@Icons.Material.Filled.Send">
                    @(publicando ? "Publicando..." : "Publicar Aviso")
                </MudButton>
            </EditForm>
        </MudPaper>
    </MudItem>

    @* ── Preview ────────────────────────────────────────────────── *@
    <MudItem xs="12" md="5">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Pré-visualização:</MudText>
        <MudCard Elevation="3" Class="rounded-lg">
            <div style="height: 4px; background: #1b5e20; border-radius: 8px 8px 0 0;" />
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        @(string.IsNullOrEmpty(novoAviso.Titulo) ? "Título do aviso" : novoAviso.Titulo)
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Publicado hoje · Expira: @(dataExpiracao?.ToString("dd/MM/yyyy") ?? "—")
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    @if (novoAviso.TipoVisibilidade == "Equipe")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                            🔒 Equipe
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            🌐 Geral
                        </MudChip>
                    }
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @*
                  CORREÇÃO: era novoAviso.Conteudo → agora novoAviso.Mensagem
                *@
                <MudText Typo="Typo.body2" Style="white-space: pre-line;">
                    @(string.IsNullOrEmpty(novoAviso.Mensagem)
                        ? "Conteúdo do aviso aparecerá aqui..."
                        : novoAviso.Mensagem)
                </MudText>
            </MudCardContent>
        </MudCard>

        @* Dica sobre os tipos de visibilidade *@
        <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
            <strong>Geral:</strong> aparece na Home sem login e em QuadroAvisos para todos.<br />
            <strong>Equipe:</strong> visível apenas para professores, bolsistas e staff logados.
        </MudAlert>
    </MudItem>
</MudGrid>

@code {
    private bool publicando = false;
    private DateTime? dataExpiracao = DateTime.Today.AddDays(30);

    private CriarAvisoForm novoAviso = new();

    private async Task PublicarAviso()
    {
        if (dataExpiracao == null)
        {
            Snackbar.Add("Informe a data de expiração do aviso.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(novoAviso.Titulo))
        {
            Snackbar.Add("O título é obrigatório.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(novoAviso.Mensagem))
        {
            Snackbar.Add("O conteúdo do aviso é obrigatório.", Severity.Warning);
            return;
        }

        publicando = true;

        try
        {
            var payload = new
            {
                novoAviso.Titulo,
                Mensagem = novoAviso.Mensagem,
                novoAviso.TipoVisibilidade,
                DataExpiracao = dataExpiracao.Value.ToUniversalTime()
            };

            var response = await Http.PostAsJsonAsync("api/avisos/admin/criar", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Aviso publicado com sucesso! 📢", Severity.Success);

                // Reseta o formulário mantendo visibilidade padrão
                novoAviso = new CriarAvisoForm();
                dataExpiracao = DateTime.Today.AddDays(30);
            }
            
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            publicando = false;
        }
    }

    public class CriarAvisoForm
    {
        public string Titulo { get; set; } = "";
        public string Mensagem { get; set; } = "";                  // ← era: Conteudo
        public string TipoVisibilidade { get; set; } = "Geral";    // Padrão: público
    }
}
