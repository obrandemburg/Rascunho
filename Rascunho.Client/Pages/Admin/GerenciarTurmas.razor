@* 
  ARQUIVO: Rascunho.Client/Pages/Admin/GerenciarTurmas.razor
  ROTA:    /admin/turmas
  ACESSO:  Recepção, Gerente

  HISTÓRICO DE SPRINTS:
  Sprint 1 — Criação com formulário e listagem básica
  Sprint 2 — Dropdowns populados via API (professores, ritmos, salas)
  Sprint 3 — Sem alterações nesta tela
  Sprint 4 — Botão "Ver Alunos" (modal) + Botão "Encerrar Turma" (ConfirmDialog)

  ENDPOINTS USADOS:
  GET  /api/usuarios/tipo/Professor/ativos/lista  → professores para dropdown
  GET  /api/ritmos/listar                         → ritmos para dropdown
  GET  /api/salas/ativas                          → salas para dropdown
  GET  /api/turmas/listar-ativas                  → listagem de turmas
  POST /api/turmas/criar                          → criar turma
  GET  /api/turmas/{idHash}/alunos                → alunos da turma (modal)
  PUT  /api/turmas/{idHash}/encerrar              → encerrar turma (Sprint 4)
*@

@page "/admin/turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using Rascunho.Client.Shared
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-6 font-weight-bold">
        <MudIcon Icon="@Icons.Material.Filled.ManageHistory" Class="mr-2" />
        Gerenciar Turmas
    </MudText>

    @* ══════════════════════════════════════════════════════════════════
       SEÇÃO 1: FORMULÁRIO — ABRIR NOVA TURMA
    ══════════════════════════════════════════════════════════════════ *@
    <MudPaper Elevation="3"
              Class="pa-6 rounded-lg mb-8"
              Style="border-top: 4px solid #1b5e20;">
        <MudText Typo="Typo.h5" Class="mb-4">Abrir Nova Turma</MudText>

        @if (carregandoDependencias)
        {
            <div class="d-flex align-center gap-2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                <MudText>Carregando ritmos, professores e salas...</MudText>
            </div>
        }
        else
        {
            <EditForm Model="@novaTurma" OnValidSubmit="CriarTurma">
                <MudGrid>

                    @* ── RITMO ── *@
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string"
                                   Label="Ritmo"
                                   @bind-Value="novaTurma.RitmoIdHash"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var ritmo in ritmos)
                            {
                                <MudSelectItem T="string" Value="@ritmo.IdHash">
                                    @ritmo.Nome
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* ── PROFESSOR ── *@
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string"
                                   Label="Professor"
                                   @bind-Value="novaTurma.ProfessorIdHash"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var prof in professores)
                            {
                                <MudSelectItem T="string" Value="@prof.IdHash">
                                    @prof.Nome
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* ── SALA ── *@
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string"
                                   Label="Sala"
                                   @bind-Value="novaTurma.SalaIdHash"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var sala in salas)
                            {
                                <MudSelectItem T="string" Value="@sala.IdHash">
                                    @sala.Nome (cap. @sala.CapacidadeMaxima)
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* ── DIA DA SEMANA ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string"
                                   Label="Dia da Semana"
                                   @bind-Value="novaTurma.DiaSemana"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="string" Value="@("Segunda-feira")">Segunda-feira</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Terça-feira")">Terça-feira</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Quarta-feira")">Quarta-feira</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Quinta-feira")">Quinta-feira</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Sexta-feira")">Sexta-feira</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Sábado")">Sábado</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    @* ── NÍVEL ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string"
                                   Label="Nível"
                                   @bind-Value="novaTurma.Nivel"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem T="string" Value="@("Iniciante")">Iniciante</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Intermediário")">Intermediário</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Avançado")">Avançado</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    @* ── HORÁRIO INÍCIO ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudTimePicker @bind-Time="horarioInicio"
                                       Label="Horário de Início"
                                       Variant="Variant.Outlined"
                                       AmPm="false"
                                       Required="true" />
                    </MudItem>

                    @* ── HORÁRIO FIM ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudTimePicker @bind-Time="horarioFim"
                                       Label="Horário de Fim"
                                       Variant="Variant.Outlined"
                                       AmPm="false"
                                       Required="true" />
                    </MudItem>

                    @* ── DATA DE INÍCIO ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudDatePicker @bind-Date="dataInicio"
                                       Label="Data de Início"
                                       Variant="Variant.Outlined"
                                       DateFormat="dd/MM/yyyy"
                                       MinDate="@DateTime.Today" />
                    </MudItem>

                    @* ── LIMITE DE ALUNOS ── *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField T="int"
                                         @bind-Value="novaTurma.LimiteAlunos"
                                         Label="Limite de Alunos"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Required="true" />
                    </MudItem>

                    @* ── LINK WHATSAPP ── *@
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="novaTurma.LinkWhatsApp"
                                      Label="Link do Grupo WhatsApp (opcional)"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Chat"
                                      HelperText="https://chat.whatsapp.com/..." />
                    </MudItem>

                    @* ── BOTÃO CRIAR ── *@
                    <MudItem xs="12" Class="d-flex justify-end mt-4">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   Disabled="@criando"
                                   StartIcon="@Icons.Material.Filled.Add">
                            @(criando ? "Criando..." : "Criar Turma na Grade")
                        </MudButton>
                    </MudItem>

                </MudGrid>
            </EditForm>
        }
    </MudPaper>

    @* ══════════════════════════════════════════════════════════════════
       SEÇÃO 2: LISTAGEM DAS TURMAS EXISTENTES
    ══════════════════════════════════════════════════════════════════ *@
    <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">
        Turmas Cadastradas
        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                 Variant="Variant.Filled" Class="ml-2">
            @turmas.Count
        </MudChip>
    </MudText>

    @if (carregandoTurmas)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!turmas.Any())
    {
        <MudAlert Severity="Severity.Info">
            Nenhuma turma cadastrada ainda. Use o formulário acima para criar a primeira!
        </MudAlert>
    }
    else
    {
        <MudDataGrid T="TurmaListaDto"
                     Items="@turmas"
                     Sortable="true"
                     Hover="true"
                     Dense="true"
                     Elevation="3"
                     Class="rounded-xl">
            <Columns>

                <PropertyColumn Property="t => t.RitmoNome"
                                Title="Ritmo"
                                Sortable="true" />

                <PropertyColumn Property="t => t.DiaSemana"
                                Title="Dia" />

                <TemplateColumn Title="Horário">
                    <CellTemplate Context="cell">
                        <MudText Typo="Typo.body2">
                            @cell.Item.HorarioInicio — @cell.Item.HorarioFim
                        </MudText>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="t => t.SalaNome"
                                Title="Sala" />

                <PropertyColumn Property="t => t.Nivel"
                                Title="Nível" />

                <TemplateColumn Title="Vagas">
                    <CellTemplate Context="cell">
                        <div class="d-flex align-center gap-2">
                            <MudText Typo="Typo.caption">
                                @cell.Item.QuantidadeMatriculados / @cell.Item.LimiteAlunos
                            </MudText>
                            <MudProgressLinear Color="@(cell.Item.QuantidadeMatriculados >= cell.Item.LimiteAlunos
                                                                                                               ? Color.Error : Color.Success)"
                                               Value="@(cell.Item.LimiteAlunos > 0
                                                                                                ? (double)cell.Item.QuantidadeMatriculados / cell.Item.LimiteAlunos * 100
                                                                                                : 0)"
                                               Style="width: 60px;"
                                               Rounded="true" />
                        </div>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Status">
                    <CellTemplate Context="cell">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(cell.Item.Ativa ? Color.Success : Color.Default)"
                                 Variant="Variant.Filled">
                            @(cell.Item.Ativa ? "Ativa" : "Inativa")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>

                @* ── SPRINT 4: Coluna de ações ── *@
                <TemplateColumn Title="Ações" CellClass="d-flex gap-1 align-center">
                    <CellTemplate Context="cell">

                        @* Botão Ver Alunos — sempre disponível *@
                        <MudTooltip Text="Ver alunos matriculados">
                            <MudIconButton Icon="@Icons.Material.Filled.People"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => AbrirModalAlunos(cell.Item))" />
                        </MudTooltip>

                        @* Botão Encerrar — apenas para turmas ativas *@
                        @if (cell.Item.Ativa)
                        {
                            <MudTooltip Text="Encerrar turma">
                                <MudIconButton Icon="@Icons.Material.Filled.StopCircle"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               OnClick="@(() => ConfirmarEncerrarTurma(cell.Item))" />
                            </MudTooltip>
                        }

                    </CellTemplate>
                </TemplateColumn>

            </Columns>
        </MudDataGrid>
    }

</MudContainer>

@* ══════════════════════════════════════════════════════════════════
   MODAL: Alunos da Turma (Sprint 4)
   Abre quando o professor/recepção clica no ícone de pessoas.
   Chama GET /api/turmas/{idHash}/alunos
══════════════════════════════════════════════════════════════════ *@
<MudDialog @bind-IsVisible="modalAlunosAberto"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" />
            <MudText Typo="Typo.h6">
                Alunos Matriculados — @turmaSelecionada?.RitmoNome
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (carregandoAlunos)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (!alunosDaTurma.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                Nenhum aluno matriculado nesta turma.
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Class="mb-3 mud-text-secondary">
                @alunosDaTurma.Count aluno(s) matriculado(s)
            </MudText>
            <MudList T="AlunoMatriculadoDto" Dense="true">
                @foreach (var aluno in alunosDaTurma)
                {
                    <MudListItem T="AlunoMatriculadoDto">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                @aluno.Nome.FirstOrDefault()
                            </MudAvatar>
                            <div style="flex: 1;">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @aluno.Nome
                                </MudText>
                            </div>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="Color.Default"
                                     Variant="Variant.Outlined">
                                @aluno.Papel
                            </MudChip>
                        </MudStack>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => modalAlunosAberto = false)"
                   Variant="Variant.Text">
            Fechar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ── Estado de carregamento ──────────────────────────────────────
    private bool carregandoDependencias = true;
    private bool carregandoTurmas = true;
    private bool carregandoAlunos = false;
    private bool criando = false;
    private bool modalAlunosAberto = false;

    // ── Dados do formulário de criação ──────────────────────────────
    private TurmaRequest novaTurma = new() { LimiteAlunos = 30 };
    private TimeSpan? horarioInicio;
    private TimeSpan? horarioFim;
    private DateTime? dataInicio = DateTime.Today;

    // ── Listas para os dropdowns (carregadas da API) ────────────────
    private List<ItemSimplesDto> professores = new();
    private List<ItemSimplesDto> ritmos = new();
    private List<SalaDto> salas = new();

    // ── Dados da listagem e modal ───────────────────────────────────
    private List<TurmaListaDto> turmas = new();
    private List<AlunoMatriculadoDto> alunosDaTurma = new();
    private TurmaListaDto? turmaSelecionada;

    // ──────────────────────────────────────────────────────────────
    // Inicialização: carrega todas as dependências em paralelo.
    // Task.WhenAll garante que as 4 chamadas ocorram simultaneamente,
    // reduzindo o tempo de carregamento de ~4x para ~1x a chamada mais lenta.
    // ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Endpoint /lista retorna List<> simples (sem envelope {Quantidade, Usuarios})
        // necessário para o frontend desserializar diretamente em List<ItemSimplesDto>
        var profTask = Http.GetFromJsonAsync<List<ItemSimplesDto>>("api/usuarios/tipo/Professor/ativos/lista");
        var ritmoTask = Http.GetFromJsonAsync<List<ItemSimplesDto>>("api/ritmos/listar");
        var salaTask = Http.GetFromJsonAsync<List<SalaDto>>("api/salas/ativas");
        var turmasTask = Http.GetFromJsonAsync<List<TurmaListaDto>>("api/turmas/listar-ativas");

        await Task.WhenAll(profTask, ritmoTask, salaTask, turmasTask);

        professores = profTask.Result ?? new();
        ritmos = ritmoTask.Result ?? new();
        salas = salaTask.Result ?? new();
        turmas = turmasTask.Result ?? new();

        carregandoDependencias = false;
        carregandoTurmas = false;
    }

    // ──────────────────────────────────────────────────────────────
    // CRIAR TURMA
    // Valida campos de tempo e envia para POST /api/turmas/criar.
    // O backend valida RN-TUR01 (choque professor) e RN-TUR02 (choque sala).
    // HTTP 422 = regra de negócio violada → exibe mensagem clara ao usuário.
    // ──────────────────────────────────────────────────────────────
    private async Task CriarTurma()
    {
        if (horarioInicio == null || horarioFim == null || dataInicio == null)
        {
            Snackbar.Add("Preencha a data de início e os horários.", Severity.Warning);
            return;
        }

        if (horarioFim <= horarioInicio)
        {
            Snackbar.Add("O horário de fim deve ser maior que o de início.", Severity.Warning);
            return;
        }

        criando = true;
        try
        {
            // Monta o payload alinhado com CriarTurmaRequest do backend
            var payload = new
            {
                RitmoIdHash = novaTurma.RitmoIdHash,
                SalaIdHash = novaTurma.SalaIdHash,
                DataInicio = dataInicio.Value,
                DiaDaSemana = DiaSemanaParaInt(novaTurma.DiaSemana),
                HorarioInicio = horarioInicio.Value,
                HorarioFim = horarioFim.Value,
                Nivel = novaTurma.Nivel,
                LimiteAlunos = novaTurma.LimiteAlunos,
                LinkWhatsApp = novaTurma.LinkWhatsApp ?? "",
                // API espera lista de professores — enviamos apenas 1 por enquanto
                ProfessoresIdsHash = new List<string> { novaTurma.ProfessorIdHash }
            };

            var response = await Http.PostAsJsonAsync("api/turmas/criar", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Turma criada com sucesso! ✅", Severity.Success);

                // Reseta o formulário
                novaTurma = new TurmaRequest { LimiteAlunos = 30 };
                horarioInicio = null;
                horarioFim = null;
                dataInicio = DateTime.Today;

                // Recarrega a listagem para exibir a nova turma
                turmas = await Http.GetFromJsonAsync<List<TurmaListaDto>>(
                    "api/turmas/listar-ativas") ?? new();
            }
            else if ((int)response.StatusCode == 422)
            {
                // Regra violada: choque de professor, sala, ou limite > capacidade
                var msg = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Conflito: {msg}", Severity.Error);
            }
            else
            {
                Snackbar.Add("Erro ao criar turma. Verifique os dados.", Severity.Warning);
            }
        }
        finally { criando = false; }
    }

    // ──────────────────────────────────────────────────────────────
    // SPRINT 4: ABRIR MODAL DE ALUNOS
    // Chama GET /api/turmas/{idHash}/alunos (endpoint em ProfessorEndpoints).
    // Exibe nome e papel de cada aluno matriculado.
    // ──────────────────────────────────────────────────────────────
    private async Task AbrirModalAlunos(TurmaListaDto turma)
    {
        turmaSelecionada = turma;
        alunosDaTurma = new();  // limpa antes de abrir para evitar flash de dados antigos
        modalAlunosAberto = true;
        carregandoAlunos = true;

        try
        {
            alunosDaTurma = await Http.GetFromJsonAsync<List<AlunoMatriculadoDto>>(
                $"api/turmas/{turma.IdHash}/alunos") ?? new();
        }
        catch
        {
            Snackbar.Add("Erro ao carregar alunos da turma.", Severity.Error);
        }
        finally { carregandoAlunos = false; }
    }

    // ──────────────────────────────────────────────────────────────
    // SPRINT 4: CONFIRMAR E ENCERRAR TURMA
    //
    // Fluxo:
    //   1. Abre ConfirmDialog com texto explicativo
    //   2. Usuário confirma → PUT /api/turmas/{idHash}/encerrar
    //   3. Backend marca turma.Ativa = false (apenas isso — sem cascata)
    //   4. Remove da lista local para feedback imediato
    //
    // Nota: a turma encerrada some automaticamente de TODAS as telas
    // do sistema porque todos os endpoints filtram por Ativa = true.
    // Dados relacionados (presenças, matrículas) são preservados.
    // ──────────────────────────────────────────────────────────────
    private async Task ConfirmarEncerrarTurma(TurmaListaDto turma)
    {
        var parametros = new DialogParameters
        {
            { "ContentText",
                $"Encerrar a turma '{turma.RitmoNome} — {turma.Nivel}'?\n\n" +
                $"• {turma.QuantidadeMatriculados} aluno(s) deixarão de ver esta turma\n" +
                "• Todos os dados (presenças, matrículas) são preservados\n" +
                "• A turma não aparecerá mais em nenhuma tela do sistema\n\n" +
                "Esta ação não pode ser desfeita." },
            { "ButtonText", "Encerrar Turma" },
            { "Color", Color.Warning }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(
            "Confirmar Encerramento", parametros);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var response = await Http.PutAsync(
                $"api/turmas/{turma.IdHash}/encerrar", null);

            if (response.IsSuccessStatusCode)
            {
                // Remove da lista local sem precisar recarregar toda a página
                turmas.RemoveAll(t => t.IdHash == turma.IdHash);
                Snackbar.Add(
                    $"Turma '{turma.RitmoNome}' encerrada. " +
                    "Os alunos deixarão de vê-la no próximo acesso.",
                    Severity.Info);
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Erro ao encerrar: {erro}", Severity.Error);
            }
        }
    }

    // ──────────────────────────────────────────────────────────────
    // AUXILIAR: Converte nome do dia para inteiro (DayOfWeek C#)
    // Domingo=0, Segunda=1, ..., Sábado=6
    // ──────────────────────────────────────────────────────────────
    private int DiaSemanaParaInt(string dia) => dia switch
    {
        "Segunda-feira" => 1,
        "Terça-feira" => 2,
        "Quarta-feira" => 3,
        "Quinta-feira" => 4,
        "Sexta-feira" => 5,
        "Sábado" => 6,
        _ => 0
    };

    // ── DTOs locais ─────────────────────────────────────────────────

    // Model do formulário de criação
    public class TurmaRequest
    {
        public string RitmoIdHash { get; set; } = "";
        public string ProfessorIdHash { get; set; } = "";
        public string SalaIdHash { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string Nivel { get; set; } = "";
        public int LimiteAlunos { get; set; }
        public string? LinkWhatsApp { get; set; }
    }

    // Para os dropdowns de Professor e Ritmo
    public class ItemSimplesDto
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
    }

    // Para o dropdown de Salas (precisa da capacidade)
    public class SalaDto : ItemSimplesDto
    {
        public int CapacidadeMaxima { get; set; }
    }

    // Espelha ObterTurmaResponse do backend
    public class TurmaListaDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string SalaNome { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public string Nivel { get; set; } = "";
        public int LimiteAlunos { get; set; }
        public int QuantidadeMatriculados { get; set; }
        public bool Ativa { get; set; }
    }

    // Espelha AlunoMatriculadoResponse do backend
    public class AlunoMatriculadoDto
    {
        public string AlunoIdHash { get; set; } = "";
        public string Nome { get; set; } = "";
        public string FotoUrl { get; set; } = "";
