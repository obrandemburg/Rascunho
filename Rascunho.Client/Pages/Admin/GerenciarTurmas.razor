@page "/admin/turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-6 font-weight-bold">Gerenciar Turmas</MudText>

    <MudPaper Elevation="3" Class="pa-6 rounded-lg mb-8 border-t-4 border-solid" Style="border-top-color: #1b5e20;">
        <MudText Typo="Typo.h5" Class="mb-4">Abrir Nova Turma</MudText>
        
        @if (carregandoDependencias)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="ml-2">Carregando professores e salas...</MudText>
        }
        else
        {
            <EditForm Model="@novaTurma" OnValidSubmit="CriarTurma">
                <MudGrid>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Label="Ritmo" @bind-Value="novaTurma.RitmoIdHash" Variant="Variant.Outlined" Required="true" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var ritmo in ritmos)
                            {
                                <MudSelectItem Value="@ritmo.IdHash">@ritmo.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Label="Professor" @bind-Value="novaTurma.ProfessorIdHash" Variant="Variant.Outlined" Required="true" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var prof in professores)
                            {
                                <MudSelectItem Value="@prof.IdHash">@prof.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Label="Sala" @bind-Value="novaTurma.SalaIdHash" Variant="Variant.Outlined" Required="true" AnchorOrigin="Origin.BottomCenter">
                            @foreach (var sala in salas)
                            {
                                <MudSelectItem Value="@sala.IdHash">@sala.Nome (Capacidade: @sala.CapacidadeMaxima)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Dia da Semana" @bind-Value="novaTurma.DiaSemana" Variant="Variant.Outlined" Required="true" AnchorOrigin="Origin.BottomCenter">
                            <MudSelectItem Value="@("Segunda-feira")" />
                            <MudSelectItem Value="@("Terça-feira")" />
                            <MudSelectItem Value="@("Quarta-feira")" />
                            <MudSelectItem Value="@("Quinta-feira")" />
                            <MudSelectItem Value="@("Sexta-feira")" />
                            <MudSelectItem Value="@("Sábado")" />
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField @bind-Value="novaTurma.HorarioInicio" Label="Início (Ex: 18:00)" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField @bind-Value="novaTurma.HorarioFim" Label="Fim (Ex: 18:50)" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="novaTurma.LimiteAlunos" Label="Limite de Alunos" Variant="Variant.Outlined" Min="1" Required="true" />
                    </MudItem>
                    
                    <MudItem xs="12" Class="d-flex justify-end mt-4">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large">
                            Criar Turma na Grade
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    private bool carregandoDependencias = true;
    private TurmaRequest novaTurma = new() { LimiteAlunos = 30 };

    // Listas para os Dropdowns
    private List<ItemSimplesDto> professores = new();
    private List<ItemSimplesDto> ritmos = new();
    private List<SalaDto> salas = new();

    public class TurmaRequest
    {
        public string RitmoIdHash { get; set; } = "";
        public string ProfessorIdHash { get; set; } = "";
        public string SalaIdHash { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public int LimiteAlunos { get; set; }
    }

    public class ItemSimplesDto
    {
        public string IdHash { get; set; } = "";
        public string Nome { get; set; } = "";
    }

    public class SalaDto : ItemSimplesDto
    {
        public int CapacidadeMaxima { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Busca dados reais da API para popular os seletores
            var profTask = Http.GetFromJsonAsync<List<ItemSimplesDto>>("api/usuarios/listar/tipo/Professor");
            var ritmoTask = Http.GetFromJsonAsync<List<ItemSimplesDto>>("api/ritmos/listar");
            var salaTask = Http.GetFromJsonAsync<List<SalaDto>>("api/salas/listar");

            await Task.WhenAll(profTask, ritmoTask, salaTask);

            professores = profTask.Result ?? new();
            ritmos = ritmoTask.Result ?? new();
            salas = salaTask.Result ?? new();
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar dados do sistema.", Severity.Error);
        }
        finally
        {
            carregandoDependencias = false;
        }
    }

    private async Task CriarTurma()
    {
        var response = await Http.PostAsJsonAsync("api/turmas/criar", novaTurma);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Turma criada com sucesso!", Severity.Success);
            novaTurma = new TurmaRequest { LimiteAlunos = 30 };
        }
        else
        {
            Snackbar.Add("Erro: Verifique se há choques de horário ou sala indisponível.", Severity.Error);
        }
    }
}