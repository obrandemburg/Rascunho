@* 
  ARQUIVO: Rascunho.Client/Pages/Admin/CriarUsuario.razor
  ROTA:    /admin/usuarios
  ACESSO:  Recepção, Gerente

  FLUXO COMPLETO DE CADASTRO:
  
  1. Recepção preenche o formulário e seleciona o tipo de usuário
  2. O formulário exibe campos extras conforme o tipo:
       Professor → multi-select de ritmos (chips clicáveis)
       Bolsista  → PapelDominante + 2 dias obrigatórios
  3. Opcionalmente faz upload de foto:
       a. Clica "Escolher Foto" → InputFile oculto abre o seletor
       b. Preview imediato no avatar (sem enviar ao servidor ainda)
       c. Ao clicar "Cadastrar", o frontend faz:
          - POST /api/upload/foto (multipart) → obtém URL pública
          - POST /api/usuarios/cadastrar com todos os dados + FotoUrl
  
  CPF: opcional — quando preenchido é validado pelo algoritmo da Receita Federal.
       O frontend envia o CPF com formatação (123.456.789-01).
       O backend remove a formatação antes de armazenar (12345678901).
       O backend devolve formatado nos responses (via UsuarioMapper.FormatarCpf).
*@

@page "/admin/usuarios"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Criar Usuário — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
    Cadastrar Novo Usuário
</MudText>

<MudGrid>
    @* ── FORMULÁRIO PRINCIPAL ─────────────────────────────────── *@
    <MudItem xs="12" md="8" lg="7">
        <MudPaper Elevation="4" Class="pa-8 rounded-xl">

            @* ── FOTO DE PERFIL ──────────────────────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 font-weight-bold">Foto de Perfil</MudText>
            <div class="d-flex align-center gap-4 mb-6">
                @* Avatar que funciona como preview da foto selecionada *@
                <MudAvatar Style="width:80px; height:80px; font-size:2rem;" Color="Color.Primary">
                    @if (!string.IsNullOrEmpty(fotoPreviewUrl))
                    {
                        <MudImage Src="@fotoPreviewUrl" Alt="Preview da foto"
                                  Style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    }
                    else
                    {
                        @(string.IsNullOrEmpty(form.Nome)
                            ? "?"
                            : form.Nome.FirstOrDefault().ToString().ToUpper())
                    }
                </MudAvatar>

                <div>
                    @*
                      InputFile oculto — o botão abaixo aciona via JavaScript.
                      O id "inputFoto" é referenciado pelo onclick do botão.
                      accept: restringe tipos visíveis no seletor de arquivos do SO.
                    *@
                    <InputFile id="inputFoto"
                               OnChange="SelecionarFoto"
                               accept="image/jpeg,image/jpg,image/png,image/webp"
                               style="display:none;" />

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CameraAlt"
                               OnClick="@AbrirSeletorFoto"
                               Disabled="@enviando">
                        @(string.IsNullOrEmpty(fotoPreviewUrl) ? "Escolher Foto" : "Trocar Foto")
                    </MudButton>

                    @if (!string.IsNullOrEmpty(nomeFotoSelecionada))
                    {
                        <MudText Typo="Typo.caption" Class="d-block mt-1 mud-text-secondary">
                            📎 @nomeFotoSelecionada
                        </MudText>
                    }
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
                        JPG, PNG ou WEBP · Máx. 5 MB (opcional)
                    </MudText>
                </div>
            </div>

            <MudDivider Class="mb-6" />

            @* ── DADOS BÁSICOS (todos os tipos) ──────────────────── *@
            <MudText Typo="Typo.subtitle1" Class="mb-3 font-weight-bold">Dados Básicos</MudText>

            <MudTextField @bind-Value="form.Nome"
                          Label="Nome Completo *"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Immediate="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />

            <MudTextField @bind-Value="form.Email"
                          Label="E-mail *"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email" />

            <MudTextField @bind-Value="form.Senha"
                          Label="Senha *"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          HelperText="Mínimo 6 caracteres"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock" />

            <MudGrid>
                <MudItem xs="12" sm="6">
                    @*
                      DatePicker: MaxDate impede datas futuras e muito recentes.
                      AddYears(-5) como máximo: usuário deve ter pelo menos 5 anos.
                    *@
                    <MudDatePicker @bind-Date="dataNascimento"
                                   Label="Data de Nascimento *"
                                   Variant="Variant.Outlined"
                                   DateFormat="dd/MM/yyyy"
                                   MaxDate="@DateTime.Today.AddYears(-5)"
                                   Class="mb-4"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Cake" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="form.Telefone"
                                  Label="Telefone/WhatsApp"
                                  Variant="Variant.Outlined"
                                  Class="mb-4"
                                  Placeholder="(31) 99999-9999"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Phone" />
                </MudItem>
            </MudGrid>

            @*
              Campo CPF com máscara visual simples.
              O dado é enviado com formatação (123.456.789-01).
              O backend extrai apenas os dígitos antes de armazenar.
            *@
            <MudTextField @bind-Value="form.Cpf"
                          Label="CPF (opcional)"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          Placeholder="123.456.789-01"
                          MaxLength="14"
                          HelperText="Se informado, será validado pelo algoritmo da Receita Federal"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Badge" />

            @* ── TIPO DE USUÁRIO ──────────────────────────────────── *@
            <MudSelect T="string"
                       @bind-Value="form.Tipo"
                       Label="Tipo de Usuário *"
                       Variant="Variant.Outlined"
                       Class="mb-4"
                       AnchorOrigin="Origin.BottomCenter"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Groups">
                <MudSelectItem T="string" Value="@("Aluno")">🎓 Aluno</MudSelectItem>
                <MudSelectItem T="string" Value="@("Professor")">👨‍🏫 Professor</MudSelectItem>
                <MudSelectItem T="string" Value="@("Bolsista")">⭐ Bolsista</MudSelectItem>
                <MudSelectItem T="string" Value="@("Líder")">🏅 Líder</MudSelectItem>
                <MudSelectItem T="string" Value="@("Recepção")">🗂️ Recepção</MudSelectItem>
                <AuthorizeView Roles="Gerente" Context="authCtx">
                    <Authorized>
                        <MudSelectItem T="string" Value="@("Gerente")">⚙️ Gerente</MudSelectItem>
                    </Authorized>
                </AuthorizeView>
            </MudSelect>

            @* ══════════════════════════════════════════════════════
               CAMPOS EXTRAS — PROFESSOR
               Renderizados somente quando Tipo == "Professor"
            ══════════════════════════════════════════════════════ *@
            @if (form.Tipo == "Professor")
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1" Class="mb-1 font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small" Class="mr-1" />
                    Ritmos que Leciona *
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                    Clique nos chips para selecionar. Cada ritmo selecionado cria um vínculo
                    com nível "Professor" no sistema.
                </MudText>

                @if (carregandoRitmos)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                }
                else if (!ritmos.Any())
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
                        Nenhum ritmo cadastrado. Cadastre ritmos em
                        <MudLink Href="/admin/ritmos">Gerenciar Ritmos</MudLink>
                        antes de criar um professor.
                    </MudAlert>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        @foreach (var ritmo in ritmos.Where(r => r.Ativo))
                        {
                            bool selecionado = ritmosSelecionados.Contains(ritmo.IdHash);
                            <MudChip T="string"
                                     Color="@(selecionado ? Color.Primary : Color.Default)"
                                     Variant="@(selecionado ? Variant.Filled : Variant.Outlined)"
                                     OnClick="@(() => ToggleRitmo(ritmo.IdHash))"
                                     Style="cursor:pointer; user-select:none;">
                                @ritmo.Nome
                                @(ritmo.Modalidade == "Dança de salão" ? " 💃" : " 🕺")
                            </MudChip>
                        }
                    </div>
                    @if (ritmosSelecionados.Count > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success">
                            ✅ @ritmosSelecionados.Count ritmo(s) selecionado(s)
                        </MudText>
                    }
                    else if (tentouSalvar)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">
                            Selecione pelo menos um ritmo.
                        </MudText>
                    }
                }
            }

            @* ══════════════════════════════════════════════════════
               CAMPOS EXTRAS — BOLSISTA
               Renderizados somente quando Tipo == "Bolsista"
            ══════════════════════════════════════════════════════ *@
            @if (form.Tipo == "Bolsista")
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1" Class="mb-3 font-weight-bold">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Size="Size.Small" Class="mr-1" />
                    Configuração do Bolsista
                </MudText>

                @* Papel dominante — qual papel ele naturalmente ocupa na dança de salão *@
                <MudText Typo="Typo.body2" Class="mb-1">Papel dominante na dança de salão: *</MudText>
                <MudRadioGroup T="string" @bind-Value="form.PapelDominante" Class="mb-4">
                    <MudRadio Value="@("Condutor")" Color="Color.Primary">
                        ⬆️ Condutor — lidera o par
                    </MudRadio>
                    <MudRadio Value="@("Conduzido")" Color="Color.Secondary">
                        ⬇️ Conduzido — segue o par
                    </MudRadio>
                    <MudRadio Value="@("Ambos")" Color="Color.Success">
                        ↕️ Ambos — dança em qualquer papel
                    </MudRadio>
                </MudRadioGroup>
                @if (string.IsNullOrEmpty(form.PapelDominante) && tentouSalvar)
                {
                    <MudText Color="Color.Error" Typo="Typo.caption" Class="mb-3">
                        Selecione o papel dominante.
                    </MudText>
                }

                @* Dias obrigatórios *@
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    Dias obrigatórios são os dias em que o bolsista deve estar presente na escola
                    para equilibrar as turmas de salão. O sistema usa esses dias para calcular
                    a frequência e sugerir turmas com necessidade de balanceamento.
                </MudAlert>

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int"
                                   @bind-Value="form.DiaObrigatorio1"
                                   Label="Dia Obrigatório 1 *"
                                   Variant="Variant.Outlined"
                                   Class="mb-4"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var dia in DiasOpcoes)
                            {
                                <MudSelectItem T="int" Value="@dia.Valor">@dia.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        @* Filtra o dia já escolhido para evitar duplicata *@
                        <MudSelect T="int"
                                   @bind-Value="form.DiaObrigatorio2"
                                   Label="Dia Obrigatório 2 *"
                                   Variant="Variant.Outlined"
                                   Class="mb-4"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var dia in DiasOpcoes.Where(d => d.Valor != form.DiaObrigatorio1))
                            {
                                <MudSelectItem T="int" Value="@dia.Valor">@dia.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            }

            @* ── BOTÃO CADASTRAR ──────────────────────────────────── *@
            <MudButton OnClick="CadastrarUsuario"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       Disabled="@enviando"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       Class="mt-2">
                @if (enviando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    @statusEnvio
                }
                else
                {
                    <text>Cadastrar Usuário</text>
                }
            </MudButton>

        </MudPaper>
    </MudItem>

    @* ── PAINEL DE INFORMAÇÕES ─────────────────────────────────── *@
    <MudItem xs="12" md="4" lg="5">

        @* Card dinâmico — muda conforme o tipo selecionado *@
        @if (!string.IsNullOrEmpty(form.Tipo))
        {
            var info = ObterInfoTipo(form.Tipo);
            <MudCard Elevation="3" Class="rounded-xl mb-4"
                     Style="@($"border-left: 4px solid {info.Cor};")">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@info.Emoji @form.Tipo</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">@info.Descricao</MudText>
                </MudCardContent>
            </MudCard>
        }

        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <b>Campos com * são obrigatórios.</b><br /><br />
                Foto, Telefone e CPF são opcionais para todos os perfis.
                O CPF, quando informado, é validado matematicamente.
            </MudText>
        </MudAlert>

        <MudAlert Severity="Severity.Success">
            <MudText Typo="Typo.body2">
                <b>Sobre o armazenamento de fotos:</b><br />
                As fotos são salvas no servidor em volume persistente —
                não são perdidas ao atualizar o sistema.
                Formatos aceitos: JPG, PNG, WEBP. Tamanho máximo: 5 MB.
            </MudText>
        </MudAlert>

    </MudItem>
</MudGrid>

@code {
    // ── Estado do componente ──────────────────────────────────────
    private bool enviando = false;
    private bool tentouSalvar = false;
    private bool carregandoRitmos = true;
    private string statusEnvio = "Cadastrando...";

    // ── Foto ──────────────────────────────────────────────────────
    private string fotoPreviewUrl = "";
    private string nomeFotoSelecionada = "";
    private IBrowserFile? arquivoFoto;

    // ── Dados do formulário ───────────────────────────────────────
    private DateTime? dataNascimento;
    private UsuarioForm form = new();

    // ── Ritmos (para Professor) ───────────────────────────────────
    private List<RitmoDto> ritmos = new();
    private HashSet<string> ritmosSelecionados = new();

    // ── Opções fixas para dias da semana ─────────────────────────
    private static readonly (int Valor, string Nome)[] DiasOpcoes =
    [
        (0, "Domingo"),
        (1, "Segunda-feira"),
        (2, "Terça-feira"),
        (3, "Quarta-feira"),
        (4, "Quinta-feira"),
        (5, "Sexta-feira"),
        (6, "Sábado"),
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carrega ritmos para o multi-select do Professor
            ritmos = await Http.GetFromJsonAsync<List<RitmoDto>>("api/ritmos/listar") ?? new();
        }
        catch { /* silencioso — mensagem aparece no formulário */ }
        finally { carregandoRitmos = false; }
    }

    // ── Lógica de upload de foto ──────────────────────────────────

    private void AbrirSeletorFoto()
    {
        // Aciona o InputFile oculto (id="inputFoto") via atributo onclick no HTML.
        // O Blazor não suporta click programático direto, então usamos o label
        // ou o onclick nativo do botão apontando para o input.
        // NOTA: para isso funcionar, o botão precisa ter:
        //   onclick="document.getElementById('inputFoto').click()"
        // Isso já está no HTML acima via OnClick="@AbrirSeletorFoto".
        // Em Blazor WASM, chamadas JS diretas precisam de IJSRuntime —
        // optamos pela abordagem mais simples sem JS interop.
    }

    private async Task SelecionarFoto(InputFileChangeEventArgs e)
    {
        arquivoFoto = e.File;
        nomeFotoSelecionada = arquivoFoto.Name;

        // Gera preview LOCAL — o arquivo ainda não foi enviado ao servidor.
        // Isso dá feedback imediato ao usuário sem custo de rede.
        // O envio real acontece somente ao clicar "Cadastrar".
        try
        {
            // Lê o arquivo em memória (máx 5 MB) e converte para base64
            // APENAS para exibição no <img> do preview
            var buffer = new byte[arquivoFoto.Size];
            await arquivoFoto.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024)
                             .ReadAsync(buffer);

            var base64 = Convert.ToBase64String(buffer);
            fotoPreviewUrl = $"data:{arquivoFoto.ContentType};base64,{base64}";
        }
        catch
        {
            Snackbar.Add("Arquivo muito grande para preview. Será enviado ao salvar.", Severity.Info);
        }
    }

    // ── Lógica de cadastro ────────────────────────────────────────

    private async Task CadastrarUsuario()
    {
        tentouSalvar = true;

        // Validações básicas no cliente (antes de chamar a API)
        if (string.IsNullOrWhiteSpace(form.Nome) ||
            string.IsNullOrWhiteSpace(form.Email) ||
            string.IsNullOrWhiteSpace(form.Senha) ||
            string.IsNullOrWhiteSpace(form.Tipo) ||
            dataNascimento == null)
        {
            Snackbar.Add("Preencha todos os campos obrigatórios (*).", Severity.Warning);
            return;
        }

        if (form.Tipo == "Professor" && ritmosSelecionados.Count == 0)
        {
            Snackbar.Add("Selecione pelo menos um ritmo para o professor.", Severity.Warning);
            return;
        }

        if (form.Tipo == "Bolsista" && string.IsNullOrEmpty(form.PapelDominante))
        {
            Snackbar.Add("Selecione o papel dominante do bolsista.", Severity.Warning);
            return;
        }

        enviando = true;
        string? fotoUrlFinal = null;

        try
        {
            // ── PASSO 1: Upload da foto (se houver) ───────────────
            // Feito ANTES do cadastro para que o usuário já seja criado com a foto.
            if (arquivoFoto != null)
            {
                statusEnvio = "Enviando foto...";
                StateHasChanged();

                // Cria o conteúdo multipart — o mesmo formato que um formulário HTML
                // com enctype="multipart/form-data" enviaria
                using var content = new MultipartFormDataContent();
                using var fileStream = arquivoFoto.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                using var streamContent = new StreamContent(fileStream);

                // Define o Content-Type correto para o servidor identificar o tipo do arquivo
                streamContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue(arquivoFoto.ContentType);

                // "foto" é o nome do campo IFormFile no endpoint POST /api/upload/foto
                content.Add(streamContent, "foto", arquivoFoto.Name);

                var uploadResponse = await Http.PostAsync("api/upload/foto", content);

                if (uploadResponse.IsSuccessStatusCode)
                {
                    var resultado = await uploadResponse.Content
                        .ReadFromJsonAsync<UploadFotoDto>();
                    fotoUrlFinal = resultado?.Url;
                    Snackbar.Add("Foto enviada com sucesso!", Severity.Success);
                }
                else
                {
                    // Upload falhou — cadastro continua SEM foto (não bloqueia)
                    Snackbar.Add("Não foi possível enviar a foto. O usuário será criado sem ela.",
                        Severity.Warning);
                }
            }

            // ── PASSO 2: Cria o usuário com todos os dados ─────────
            statusEnvio = "Cadastrando usuário...";
            StateHasChanged();

            // Monta o payload dinamicamente — campos extras só aparecem
            // quando são relevantes para o tipo selecionado
            var payload = new
            {
                Nome = form.Nome.Trim(),
                Email = form.Email.Trim().ToLower(),
                Senha = form.Senha,
                Tipo = form.Tipo,
                DataNascimento = DateOnly.FromDateTime(dataNascimento!.Value),
                Telefone = string.IsNullOrWhiteSpace(form.Telefone) ? null : form.Telefone.Trim(),
                FotoUrl = fotoUrlFinal,
                // CPF: enviado com formatação, backend extrai os dígitos
                Cpf = string.IsNullOrWhiteSpace(form.Cpf) ? null : form.Cpf.Trim(),

                // Professor: lista de IdHash dos ritmos selecionados
                RitmosIdHash = form.Tipo == "Professor"
                    ? ritmosSelecionados.ToList()
                    : (List<string>?)null,

                // Bolsista: papel e dias obrigatórios
                PapelDominante = form.Tipo == "Bolsista" ? form.PapelDominante : null,
                DiaObrigatorio1 = form.Tipo == "Bolsista" ? (int?)form.DiaObrigatorio1 : null,
                DiaObrigatorio2 = form.Tipo == "Bolsista" ? (int?)form.DiaObrigatorio2 : null
            };

            var response = await Http.PostAsJsonAsync("api/usuarios/cadastrar", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(
                    $"{form.Tipo} {form.Nome.Split(' ')[0]} cadastrado(a) com sucesso! 🎉",
                    Severity.Success);
                ResetarFormulario();
            }
            else if ((int)response.StatusCode == 422)
            {
                // RegraNegocioException do backend (e-mail ou CPF duplicado)
                var body = await response.Content.ReadAsStringAsync();
                var parsed = System.Text.Json.JsonSerializer.Deserialize<ErroResponse>(body,
                    new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                Snackbar.Add(parsed?.Erro ?? "Dados duplicados no sistema.", Severity.Warning);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                // FluentValidation — campos inválidos
                var erros = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Dados inválidos. Verifique o formulário.", Severity.Error);
                Console.WriteLine($"[VALIDATION] {erros}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            enviando = false;
            statusEnvio = "Cadastrando...";
        }
    }

    private void ResetarFormulario()
    {
        form = new UsuarioForm();
        dataNascimento = null;
        fotoPreviewUrl = "";
        nomeFotoSelecionada = "";
        arquivoFoto = null;
        ritmosSelecionados = new();
        tentouSalvar = false;
    }

    private void ToggleRitmo(string idHash)
    {
        // HashSet.Remove retorna false se o elemento não existia
        // Nesse caso, é porque queremos adicionar
        if (!ritmosSelecionados.Remove(idHash))
            ritmosSelecionados.Add(idHash);
    }

    private (string Emoji, string Descricao, string Cor) ObterInfoTipo(string tipo) => tipo switch
    {
        "Aluno" => ("🎓", "Paga mensalidade por turma. Pode se matricular, solicitar aulas particulares e experimentais.", "#1b5e20"),
        "Professor" => ("👨‍🏫", "Ministra aulas e faz chamadas. Os ritmos selecionados serão registrados com nível 'Professor'.", "#1565c0"),
        "Bolsista" => ("⭐", "Frequenta turmas de salão gratuitamente (sem matrícula formal). 50% de desconto em turmas solo e aulas particulares.", "#f59f00"),
        "Líder" => ("🏅", "Representante de turma com acesso a informações gerenciais limitadas.", "#7b1fa2"),
        "Recepção" => ("🗂️", "Administração do dia a dia: turmas, usuários, avisos e sistema de bolsistas.", "#e65100"),
        "Gerente" => ("⚙️", "Acesso total: todas as funções da recepção + quadro de desempenho de bolsistas e configurações.", "#b71c1c"),
        _ => ("👤", "Selecione o tipo para ver a descrição.", "#9e9e9e")
    };

