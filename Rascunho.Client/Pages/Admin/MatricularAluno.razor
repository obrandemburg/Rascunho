@* 
  ARQUIVO: Rascunho.Client/Pages/Admin/MatricularAluno.razor
  ROTA:    /admin/matricular
  ACESSO:  Recepção, Gerente
*@

@page "/admin/matricular"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@using Rascunho.Shared.DTOs
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Matricular Aluno — Ponto da Dança</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-1 font-weight-bold">
    <MudIcon Icon="@Icons.Material.Filled.HowToReg" Class="mr-2" />
    Matricular Aluno
</MudText>
<MudText Class="mb-6 mud-text-secondary">
    Selecione uma turma com vaga e adicione o aluno desejado.
</MudText>

@if (carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else
{
    @* ── FILTROS ─────────────────────────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-6">
        <MudItem xs="12" sm="6" md="4">
            <MudSelect T="string"
                       Label="Filtrar por Ritmo"
                       @bind-Value="filtroRitmoNome"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Dense="true">
                @foreach (var r in ritmos)
                {
                    <MudSelectItem T="string" Value="@r.Nome">@r.Nome</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudSelect T="int?"
                       Label="Filtrar por Dia"
                       @bind-Value="filtroDia"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Dense="true">
                @foreach (var d in DiasSemana)
                {
                    <MudSelectItem T="int?" Value="@((int?)d.Valor)">@d.Nome</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @* ══════════════════════════════════════════════════════════
       SEÇÃO: COM VAGA
    ══════════════════════════════════════════════════════════ *@
    <div class="mat-section-header" style="color:#2e7d32;">
        <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Style="vertical-align:middle;" Class="mr-1" />
        Com Vaga <span class="mat-counter">@TurmasComVaga.Count</span>
    </div>

    @if (TurmasComVaga.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-5">
            Nenhuma turma com vaga para os filtros selecionados.
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="3" Class="mb-6 rounded-xl overflow-hidden">
            @foreach (var turma in TurmasComVaga)
            {
                <div class="@(turmaSelecionada?.IdHash == turma.IdHash ? "mat-row mat-row--ativa" : "mat-row")">
                    <div class="mat-info">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                            @turma.RitmoNome
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="ml-1">@turma.Nivel</MudChip>
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            📅 @DiaNome(turma.DiaDaSemana) &nbsp;·&nbsp;
                            🕐 @turma.HorarioInicio–@turma.HorarioFim &nbsp;·&nbsp;
                            🏫 @turma.SalaNome
                        </MudText>
                        @if (turma.NomesProfessores.Any())
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                👨‍🏫 @string.Join(", ", turma.NomesProfessores)
                            </MudText>
                        }
                    </div>

                    <div class="mat-vagas">
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                            @(turma.LimiteAlunos - turma.QuantidadeMatriculados) vagas
                        </MudChip>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                            @turma.QuantidadeMatriculados / @turma.LimiteAlunos alunos
                        </MudText>
                    </div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="@(() => AbrirBuscaAluno(turma))">
                        Adicionar aluno
                    </MudButton>
                </div>

                @* ── Painel de busca inline ──────────────────── *@
                @if (turmaSelecionada?.IdHash == turma.IdHash)
                {
                    <div class="mat-busca-panel pa-4">
                        <MudText Typo="Typo.subtitle2" Class="mb-3">
                            Buscar aluno para: <strong>@turma.RitmoNome — @turma.Nivel</strong>
                        </MudText>

                        @* BUG 2 CORRIGIDO: lambda explícita para OnDebounceIntervalElapsed *@
                        <MudTextField @bind-Value="termoBusca"
                                      Label="Nome ou CPF do aluno"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Variant="Variant.Outlined"
                                      DebounceInterval="400"
                                      OnDebounceIntervalElapsed="@(async (string _) => await BuscarAlunos())"
                                      Clearable="true"
                                      Dense="true"
                                      Class="mb-3"
                                      Placeholder="Digite ao menos 2 caracteres..." />

                        @if (buscando)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
                        }
                        else if (termoBusca.Length >= 2 && resultadosBusca.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary pl-1">
                                Nenhum aluno ou bolsista encontrado.
                            </MudText>
                        }
                        else
                        {
                            <div class="pa-0">
                                @foreach (var aluno in resultadosBusca)
                                {
                                    var alunoCapturado = aluno;
                                    <div class="mat-aluno-item d-flex align-center pa-2"
                                         @onclick="@(() => SelecionarAluno(alunoCapturado))"
                                         style="cursor:pointer;">
                                        <MudAvatar Size="Size.Small" Color="Color.Primary"
                                                   Class="mr-3" Style="flex-shrink:0;">
                                            @if (!string.IsNullOrEmpty(alunoCapturado.FotoUrl))
                                            {
                                                <MudImage Src="@alunoCapturado.FotoUrl"
                                                          Alt="@alunoCapturado.Nome"
                                                          Style="width:100%;height:100%;object-fit:cover;" />
                                            }
                                            else
                                            {
                                                @(alunoCapturado.Nome.Length > 0
                                                    ? alunoCapturado.Nome[0].ToString()
                                                    : "?")
                                            }
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                                @alunoCapturado.Nome
                                            </MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                                @alunoCapturado.Tipo · @alunoCapturado.Genero
                                            </MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   Class="mt-2"
                                   OnClick="FecharBusca">
                            Fechar
                        </MudButton>
                    </div>
                }

                @if (turma.IdHash != TurmasComVaga.Last().IdHash)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }

    @* ══════════════════════════════════════════════════════════
       SEÇÃO: CHEIA
    ══════════════════════════════════════════════════════════ *@
    <div class="mat-section-header" style="color:#e65100;">
        <MudIcon Icon="@Icons.Material.Filled.Block" Style="vertical-align:middle;" Class="mr-1" />
        Cheia <span class="mat-counter">@TurmasCheia.Count</span>
    </div>

    @if (TurmasCheia.Count == 0)
    {
        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-5">
            Nenhuma turma cheia. ✅
        </MudAlert>
    }
    else
    {
        <MudPaper Elevation="1" Class="mb-6 rounded-xl overflow-hidden" Style="opacity:0.72;">
            @foreach (var turma in TurmasCheia)
            {
                <div class="mat-row">
                    <div class="mat-info">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                            @turma.RitmoNome — @turma.Nivel
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            📅 @DiaNome(turma.DiaDaSemana) &nbsp;·&nbsp;
                            🕐 @turma.HorarioInicio–@turma.HorarioFim &nbsp;·&nbsp;
                            🏫 @turma.SalaNome
                        </MudText>
                    </div>
                    <div class="mat-vagas">
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                            Cheia · @turma.QuantidadeMatriculados/@turma.LimiteAlunos
                        </MudChip>
                    </div>
                    <MudTooltip Text="Esta turma não possui vagas disponíveis.">
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   Size="Size.Small" Disabled="true"
                                   StartIcon="@Icons.Material.Filled.Block">
                            Sem vaga
                        </MudButton>
                    </MudTooltip>
                </div>
                @if (turma.IdHash != TurmasCheia.Last().IdHash)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }

    @* ══════════════════════════════════════════════════════════
       SEÇÃO: INATIVA
    ══════════════════════════════════════════════════════════ *@
    @if (TurmasInativas.Count > 0)
    {
        <div class="mat-section-header" style="color:#9e9e9e;">
            <MudIcon Icon="@Icons.Material.Filled.Archive" Style="vertical-align:middle;" Class="mr-1" />
            Inativa <span class="mat-counter">@TurmasInativas.Count</span>
        </div>

        <MudPaper Elevation="1" Class="mb-6 rounded-xl overflow-hidden" Style="opacity:0.5;">
            @foreach (var turma in TurmasInativas)
            {
                <div class="mat-row">
                    <div class="mat-info">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                            @turma.RitmoNome — @turma.Nivel
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            📅 @DiaNome(turma.DiaDaSemana) &nbsp;·&nbsp;
                            🕐 @turma.HorarioInicio–@turma.HorarioFim &nbsp;·&nbsp;
                            🏫 @turma.SalaNome
                        </MudText>
                    </div>
                    <div class="mat-vagas">
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                            Encerrada
                        </MudChip>
                    </div>
                </div>
                @if (turma.IdHash != TurmasInativas.Last().IdHash)
                {
                    <MudDivider />
                }
            }
        </MudPaper>
    }
}

@* ══════════════════════════════════════════════════════════════
   DIALOG DE CONFIRMAÇÃO — BUG 1 CORRIGIDO: @bind-Visible (não @bind-IsVisible)
══════════════════════════════════════════════════════════════ *@
<MudDialog @bind-Visible="dialogAberto"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.HowToReg" Class="mr-2" />
            Confirmar Matrícula
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (alunoParaConfirmar != null && turmaParaConfirmar != null)
        {
            <MudText Typo="Typo.body1" Class="mb-4">
                Deseja adicionar <strong>@alunoParaConfirmar.Nome</strong> à turma
                <strong>@turmaParaConfirmar.RitmoNome — @turmaParaConfirmar.Nivel</strong>
                (@DiaNome(turmaParaConfirmar.DiaDaSemana), @turmaParaConfirmar.HorarioInicio)?
            </MudText>

            <MudSelect T="string"
                       Label="Papel na turma"
                       @bind-Value="papelSelecionado"
                       Variant="Variant.Outlined"
                       HelperText="Pré-selecionado com base no gênero do aluno"
                       Dense="true"
                       Class="mb-3">
                <MudSelectItem Value="@("Condutor")">🕺 Condutor</MudSelectItem>
                <MudSelectItem Value="@("Conduzido")">💃 Conduzido</MudSelectItem>
                <MudSelectItem Value="@("Ambos")">🔄 Ambos</MudSelectItem>
            </MudSelect>
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Payments">
                Esta matrícula pode alterar o valor mensal do plano do aluno.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => { dialogAberto = false; })" Disabled="@processando">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ConfirmarMatricula" Disabled="@processando">
            @if (processando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Confirmar matrícula
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ── Estado ───────────────────────────────────────────────────
    private bool carregando = true;
    private List<ObterTurmaResponse> todasTurmas = new();
    private List<ObterRitmoResponse> ritmos = new();

    private string? filtroRitmoNome;
    private int? filtroDia;

    // turmaSelecionada → painel de busca aberto
    // turmaParaConfirmar → snapshot salvo ao abrir o dialog (evita null no dialog)
    private ObterTurmaResponse? turmaSelecionada;
    private ObterTurmaResponse? turmaParaConfirmar;

    private string termoBusca = "";
    private List<BuscarUsuarioResponse> resultadosBusca = new();
    private bool buscando = false;

    private BuscarUsuarioResponse? alunoParaConfirmar;
    private string papelSelecionado = "Ambos";
    private bool dialogAberto = false;
    private bool processando = false;

    // ── Lookup de dias ───────────────────────────────────────────
    private static readonly (string Nome, int Valor)[] DiasSemana =
    {
        ("Domingo",    0), ("Segunda-feira", 1), ("Terça-feira", 2),
        ("Quarta-feira", 3), ("Quinta-feira", 4), ("Sexta-feira", 5), ("Sábado", 6)
    };

    // ── Computed ─────────────────────────────────────────────────
    private List<ObterTurmaResponse> TurmasFiltradas => todasTurmas
        .Where(t =>
            (string.IsNullOrEmpty(filtroRitmoNome) || t.RitmoNome == filtroRitmoNome) &&
            (!filtroDia.HasValue || t.DiaDaSemana == filtroDia.Value))
        .ToList();

    private List<ObterTurmaResponse> TurmasComVaga =>
        TurmasFiltradas.Where(t => t.Ativa && t.QuantidadeMatriculados < t.LimiteAlunos).ToList();

    private List<ObterTurmaResponse> TurmasCheia =>
        TurmasFiltradas.Where(t => t.Ativa && t.QuantidadeMatriculados >= t.LimiteAlunos).ToList();

    private List<ObterTurmaResponse> TurmasInativas =>
        TurmasFiltradas.Where(t => !t.Ativa).ToList();

    // ── Lifecycle ────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var turmasTask = Http.GetFromJsonAsync<List<ObterTurmaResponse>>("api/turmas/");
            var ritmosTask = Http.GetFromJsonAsync<List<ObterRitmoResponse>>("api/ritmos/listar");
            await Task.WhenAll(turmasTask, ritmosTask);

            todasTurmas = turmasTask.Result ?? new();
            ritmos = (ritmosTask.Result ?? new()).Where(r => r.Ativo).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar dados: {ex.Message}", Severity.Error);
        }
        finally
        {
            carregando = false;
        }
    }

    // ── Busca ────────────────────────────────────────────────────
    private void AbrirBuscaAluno(ObterTurmaResponse turma)
    {
        turmaSelecionada = turma;
        termoBusca = "";
        resultadosBusca = new();
    }

    private void FecharBusca()
    {
        turmaSelecionada = null;
        termoBusca = "";
        resultadosBusca = new();
    }

    private async Task BuscarAlunos()
    {
        if (string.IsNullOrWhiteSpace(termoBusca) || termoBusca.Trim().Length < 2)
        {
            resultadosBusca = new();
            return;
        }

        buscando = true;
        StateHasChanged();

        try
        {
            var resultado = await Http.GetFromJsonAsync<List<BuscarUsuarioResponse>>(
                $"api/usuarios/buscar?q={Uri.EscapeDataString(termoBusca.Trim())}");
            resultadosBusca = resultado ?? new();
        }
        catch
        {
            resultadosBusca = new();
            Snackbar.Add("Erro ao buscar alunos.", Severity.Error);
        }
        finally
        {
            buscando = false;
            StateHasChanged();
        }
    }

    // ── Seleção e confirmação ────────────────────────────────────
    private void SelecionarAluno(BuscarUsuarioResponse aluno)
    {
        alunoParaConfirmar = aluno;

        // Salva snapshot da turma para o dialog (independente do painel de busca)
        turmaParaConfirmar = turmaSelecionada;

        papelSelecionado = aluno.Genero switch
        {
            "Masculino" => "Condutor",
            "Feminino"  => "Conduzido",
            _           => "Ambos"
        };

        dialogAberto = true;
        StateHasChanged(); // BUG 3 CORRIGIDO: força re-render após abrir dialog
    }

    private async Task ConfirmarMatricula()
    {
        if (alunoParaConfirmar == null || turmaParaConfirmar == null) return;

        processando = true;
        try
        {
            var payload = new
            {
                AlunoIdHash = alunoParaConfirmar.IdHash,
                Papel = papelSelecionado
            };

            var response = await Http.PostAsJsonAsync(
                $"api/turmas/{turmaParaConfirmar.IdHash}/admin/matricular", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(
                    $"{alunoParaConfirmar.Nome} matriculado(a) como {papelSelecionado} com sucesso! 🎉",
                    Severity.Success);

                // Atualiza contagem local sem recarregar a página
                var idx = todasTurmas.FindIndex(t => t.IdHash == turmaParaConfirmar.IdHash);
                if (idx >= 0)
                {
                    var t = todasTurmas[idx];
                    todasTurmas[idx] = t with { QuantidadeMatriculados = t.QuantidadeMatriculados + 1 };
                }

                dialogAberto = false;
                FecharBusca();
            }
            else if ((int)response.StatusCode == 422)
            {
                var body = await response.Content.ReadAsStringAsync();
                var parsed = System.Text.Json.JsonSerializer.Deserialize<ErroApi>(
                    body, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                Snackbar.Add(parsed?.Erro ?? "Regra de negócio violada.", Severity.Warning);
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                Snackbar.Add("Erro ao realizar a matrícula. Tente novamente.", Severity.Error);
                Console.WriteLine($"[MATRICULA ERROR] {(int)response.StatusCode}: {body}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            processando = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────
    private static string DiaNome(int dia) => dia switch
    {
        0 => "Domingo", 1 => "Segunda", 2 => "Terça",
        3 => "Quarta",  4 => "Quinta",  5 => "Sexta", 6 => "Sábado",
        _ => "?"
    };

    private record ErroApi(string Erro);
}

<style>
    .mat-section-header {
        display: flex;
        align-items: center;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 10px;
        margin-top: 4px;
    }
    .mat-counter {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 8px;
        background: rgba(0,0,0,0.08);
        border-radius: 12px;
        padding: 1px 10px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .mat-row {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        gap: 12px;
        transition: background 0.15s;
    }
    .mat-row:hover { background: rgba(0,0,0,0.025); }
    .mat-row--ativa { background: rgba(25, 118, 210, 0.06); }
    .mat-info { flex: 1; min-width: 0; }
    .mat-vagas {
        min-width: 130px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .mat-busca-panel {
        background: #f8f9fa;
        border-top: 2px solid rgba(25,118,210,0.15);
        animation: slideDown 0.18s ease-out;
    }
    .mat-aluno-item {
        border-radius: 8px;
        cursor: pointer;
        margin-bottom: 2px;
        transition: background 0.12s;
    }
    .mat-aluno-item:hover { background: rgba(25,118,210,0.08) !important; }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 600px) {
        .mat-row { flex-wrap: wrap; }
        .mat-vagas { min-width: 100%; text-align: left; align-items: flex-start; }
    }
</style>