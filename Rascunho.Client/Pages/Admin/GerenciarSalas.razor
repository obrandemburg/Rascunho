@page "/admin/salas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Recepção,Gerente")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-6 font-weight-bold">Gerenciamento de Salas</MudText>

    <MudPaper Elevation="3" Class="pa-6 rounded-lg mb-8 border-t-4 border-solid" Style="border-top-color: var(--mud-palette-primary);">
        <MudText Typo="Typo.h5" Class="mb-4">Cadastrar Nova Sala</MudText>
        
        <EditForm Model="@novaSala" OnValidSubmit="CriarSala">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="novaSala.Nome" Label="Nome da Sala (Ex: Sala 01 - Principal)" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="novaSala.CapacidadeMaxima" Label="Capacidade Máxima (Alunos)" Variant="Variant.Outlined" Min="1" Required="true" />
                </MudItem>

                <MudItem xs="12" Class="d-flex justify-end mt-2">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add">
                        Salvar Sala
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private SalaRequest novaSala = new() { CapacidadeMaxima = 20 };

    public class SalaRequest
    {
        public string Nome { get; set; } = "";
        public int CapacidadeMaxima { get; set; }
    }

    private async Task CriarSala()
    {
        if (novaSala.CapacidadeMaxima <= 0)
        {
            Snackbar.Add("A capacidade deve ser maior que zero.", Severity.Warning);
            return;
        }

        var response = await Http.PostAsJsonAsync("api/salas/criar", novaSala);
        
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Sala '{novaSala.Nome}' criada com sucesso!", Severity.Success);
            novaSala = new SalaRequest { CapacidadeMaxima = 20 }; // Limpa o formulário
        }
        else
        {
            // Se retornar 422, é porque o nome da sala já existe
            Snackbar.Add("Erro ao criar a sala. Talvez este nome já esteja em uso.", Severity.Error);
        }
    }
}