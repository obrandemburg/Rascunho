@page "/minhas-turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Professor")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Success" Class="mb-2 font-weight-bold">Portal do Professor</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">Gerencie suas turmas ativas e comunicação com alunos.</MudText>

    @if (carregando)
    {
        <MudProgressCircular Color="Color.Success" Indeterminate="true" />
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasLecionadas)
            {
                <MudItem xs="12">
                    <MudPaper Elevation="2" Class="pa-6 rounded-lg mb-4">
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudText Typo="Typo.h5" Color="Color.Success">@turma.RitmoNome</MudText>
                                <MudText Typo="Typo.body2">@turma.DiaSemana | @turma.HorarioInicio às @turma.HorarioFim</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-2">@turma.QuantidadeAlunos Alunos</MudChip>
                            </MudItem>
                            
                            <MudItem xs="12" md="8" Class="d-flex align-center justify-end">
                                <MudTextField @bind-Value="turma.LinkWhatsapp"
                                              Label="Link do Grupo (WhatsApp)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Custom.Brands.WhatsApp"
                                              Class="mr-4" />
                                
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           OnClick="() => AtualizarLink(turma)">
                                    Salvar Link
                                </MudButton>
                            </MudItem>

                            <MudItem xs="12" Class="d-flex gap-4 mt-2">
                                <MudButton StartIcon="@Icons.Material.Filled.Checklist"
                                           Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           Href="@($"/turmas/{turma.IdHash}/chamada")">
                                    Fazer Chamada
                                </MudButton>
                                <MudButton StartIcon="@Icons.Material.Filled.Campaign"
                                           Variant="Variant.Outlined"
                                           Color="Color.Info">
                                    Enviar Aviso
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private bool carregando = true;
    private List<TurmaProfessorDto> turmasLecionadas = new();

    public class TurmaProfessorDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public string LinkWhatsapp { get; set; } = "";
        public int QuantidadeAlunos { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<TurmaProfessorDto>>("api/turmas/professor/minhas");
            if (result != null) turmasLecionadas = result;
        }
        catch (Exception) { Snackbar.Add("Erro ao carregar turmas do professor.", Severity.Error); }
        finally { carregando = false; }
    }

    private async Task AtualizarLink(TurmaProfessorDto turma)
    {
        // Fluxo: Envia o novo link para a API salvar na entidade Turma
        var response = await Http.PutAsJsonAsync($"api/turmas/{turma.IdHash}/atualizar-link", turma.LinkWhatsapp);
        if (response.IsSuccessStatusCode)
            Snackbar.Add("Link do WhatsApp atualizado!", Severity.Success);
    }
}