@page "/fazer-chamada"
@page "/turmas/{TurmaIdHash}/chamada"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Professor")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2 font-weight-bold">Diário de Classe</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6">Selecione a turma e a data para registrar a presença dos alunos.</MudText>

    <MudGrid>
        @* ==========================================
           1. CABEÇALHO DE SELEÇÃO (TURMA E DATA)
           ========================================== *@
        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-6 rounded-lg border-t-4 border-solid" Style="border-top-color: var(--mud-palette-primary);">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        @if (carregandoTurmas)
                        {
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                            <MudText Class="ml-2 d-inline">Carregando suas turmas...</MudText>
                        }
                        else
                        {
                            <MudSelect T="string" Label="Selecione a Turma" @bind-Value="TurmaIdHash" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                                @foreach (var turma in turmas)
                                {
                                    <MudSelectItem T="string" Value="@turma.IdHash">@turma.RitmoNome - @turma.DiaSemana (@turma.HorarioInicio)</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>
                    
                    <MudItem xs="12" md="4">
                        <MudDatePicker Label="Data da Aula" @bind-Date="dataSelecionada" Variant="Variant.Outlined" DisableToolbar="true" MaxDate="DateTime.Today" />
                    </MudItem>

                    <MudItem xs="12" md="2" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="BuscarListaAlunos" Disabled="@(string.IsNullOrEmpty(TurmaIdHash) || !dataSelecionada.HasValue)">
                            Abrir Diário
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        @* ==========================================
           2. LISTA DE PRESENÇA (TABELA)
           ========================================== *@
        @if (carregandoLista)
        {
            <MudItem xs="12" Class="d-flex justify-center my-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            </MudItem>
        }
        else if (listaAlunos != null)
        {
            <MudItem xs="12">
                <MudTable Items="@listaAlunos" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Class="rounded-lg">
                    <HeaderContent>
                        <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Nome do Aluno</MudText></MudTh>
                        <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Status da Presença</MudText></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="aluno">
                        <MudTd DataLabel="Nome do Aluno">
                            <MudText Typo="Typo.body1">@aluno.NomeAluno</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status da Presença">
                            <MudSwitch @bind-Value="aluno.Presente"
                                       Color="Color.Primary"
                                       UnCheckedColor="Color.Error"
                                       Label="@(aluno.Presente ? "Presente" : "Faltou")" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <div class="d-flex justify-end pa-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Save" OnClick="SalvarChamada">
                                Salvar Chamada
                            </MudButton>
                        </div>
                    </PagerContent>
                </MudTable>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public string? TurmaIdHash { get; set; }

    private bool carregandoTurmas = true;
    private bool carregandoLista = false;
    private DateTime? dataSelecionada = DateTime.Today;

    // Listas de Estado
    private List<TurmaSimplesDto> turmas = new();
    private List<AlunoChamadaDto>? listaAlunos;

    // DTOs
    public class TurmaSimplesDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
    }

    public class AlunoChamadaDto
    {
        public string MatriculaIdHash { get; set; } = "";
        public string NomeAluno { get; set; } = "";
        public bool Presente { get; set; } = true; // Truque UX: Inicia como presente
    }

    public class SalvarChamadaRequest
    {
        public DateTime DataAula { get; set; }
        public List<AlunoChamadaDto> Alunos { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carrega as turmas do professor logado para preencher o Dropdown
            var result = await Http.GetFromJsonAsync<List<TurmaSimplesDto>>("api/turmas/professor/minhas");
            if (result != null)
            {
                turmas = result;
            }

            // Se o professor veio pelo botão "Fazer Chamada" da tela Minhas Turmas,
            // a URL já terá o TurmaIdHash, então podemos abrir a lista automaticamente.
            if (!string.IsNullOrEmpty(TurmaIdHash))
            {
                await BuscarListaAlunos();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar as turmas. Verifique sua conexão.", Severity.Error);
        }
        finally
        {
            carregandoTurmas = false;
        }
    }

    private async Task BuscarListaAlunos()
    {
        if (string.IsNullOrEmpty(TurmaIdHash) || !dataSelecionada.HasValue) return;

        carregandoLista = true;
        try
        {
            // Busca a lista de alunos matriculados nesta turma para a data específica.
            // A API deve retornar quem já estava presente ou a lista nova (Padrão: Presente)
            var dataFormatada = dataSelecionada.Value.ToString("yyyy-MM-dd");
            var result = await Http.GetFromJsonAsync<List<AlunoChamadaDto>>($"api/chamadas/turma/{TurmaIdHash}?data={dataFormatada}");
            
            listaAlunos = result ?? new List<AlunoChamadaDto>();
            
            if (!listaAlunos.Any())
            {
                Snackbar.Add("Não há alunos matriculados nesta turma ainda.", Severity.Info);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao buscar a lista de alunos.", Severity.Error);
        }
        finally
        {
            carregandoLista = false;
        }
    }

    private async Task SalvarChamada()
    {
        if (string.IsNullOrEmpty(TurmaIdHash) || listaAlunos == null || !dataSelecionada.HasValue) return;

        var request = new SalvarChamadaRequest
        {
            DataAula = dataSelecionada.Value,
            Alunos = listaAlunos
        };

        try
        {
            var response = await Http.PostAsJsonAsync($"api/chamadas/turma/{TurmaIdHash}", request);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Chamada salva com sucesso!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Falha ao salvar a chamada. Tente novamente.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Erro de conexão ao salvar a chamada.", Severity.Error);
        }
    }
}