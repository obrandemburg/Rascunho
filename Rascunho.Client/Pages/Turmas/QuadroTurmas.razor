@page "/quadro-turmas"
@using System.Net.Http.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4 font-weight-bold">Quadro de Turmas</MudText>
    
    <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-lg border-solid border-2" Style="border-color: #e0e0e0;">
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" Label="Filtrar por Ritmo" @bind-Value="filtroRitmo" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Todos")" />
                    <MudSelectItem Value="@("Forró")" />
                    <MudSelectItem Value="@("Samba")" />
                    <MudSelectItem Value="@("Zouk")" />
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string" Label="Dia da Semana" @bind-Value="filtroDia" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Value="@("Todos")" />
                    <MudSelectItem Value="@("Segunda-feira")" />
                    <MudSelectItem Value="@("Sábado")" />
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="Filtrar">Aplicar Filtros</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasExibidas)
            {
                bool cheia = turma.AlunosMatriculados >= turma.LimiteAlunos;
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">@turma.RitmoNome</MudText>
                                <MudText Typo="Typo.caption">@turma.Nivel</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body1"><b>@turma.DiaSemana</b></MudText>
                            <MudText Typo="Typo.body2">@turma.HorarioInicio - @turma.HorarioFim</MudText>
                            <MudText Typo="Typo.body2">Prof: @turma.ProfessorNome</MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <AuthorizeView Roles="Aluno">
                                <Authorized>
                                    @if (!cheia)
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="() => Matricular(turma.IdHash)">Ingressar</MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="ml-2">Experimental</MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" OnClick="() => MarcarInteresse(turma.IdHash)">Tenho Interesse</MudButton>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    <MudChip T="string" Color="@(cheia? Color.Error: Color.Success)" Variant="Variant.Text">
                                        @(cheia ? "Turma Lotada" : "Vagas Disponíveis")
                                    </MudChip>
                                </NotAuthorized>
                            </AuthorizeView>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private bool carregando = true;
    private string filtroRitmo = "Todos";
    private string filtroDia = "Todos";
    private List<TurmaDto> todasTurmas = new();
    private List<TurmaDto> turmasExibidas = new();

    public class TurmaDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string Nivel { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public string ProfessorNome { get; set; } = "";
        public int LimiteAlunos { get; set; }
        public int AlunosMatriculados { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<List<TurmaDto>>("api/turmas/listar-ativas");
            if (res != null) { todasTurmas = res; turmasExibidas = res; }
        }
        catch { Snackbar.Add("Erro ao buscar turmas.", Severity.Error); }
        finally { carregando = false; }
    }

    private void Filtrar()
    {
        var query = todasTurmas.AsQueryable();
        if (filtroRitmo != "Todos") query = query.Where(x => x.RitmoNome == filtroRitmo);
        if (filtroDia != "Todos") query = query.Where(x => x.DiaSemana == filtroDia);
        turmasExibidas = query.ToList();
    }

    private async Task Matricular(string id)
    {
        var res = await Http.PostAsync($"api/turmas/{id}/matricular", null);
        if (res.IsSuccessStatusCode) Snackbar.Add("Matrícula realizada!", Severity.Success);
    }

    private void MarcarInteresse(string id) => Snackbar.Add("Interesse registrado. Avisaremos se abrir vaga!", Severity.Info);
}