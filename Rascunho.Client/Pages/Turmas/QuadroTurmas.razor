@* ARQUIVO: Rascunho.Client/Pages/Turmas/QuadroTurmas.razor
  ROTA:    /turmas
  ACESSO:  Anônimo
*@

@page "/turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4 font-weight-bold">
        Quadro de Turmas
    </MudText>

    @* Filtros *@
    <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-lg" Style="border: 1px solid #e0e0e0;">
        <MudGrid>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" Label="Ritmo" @bind-Value="filtroRitmo" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    @foreach (var nome in nomeRitmos)
                    {
                        <MudSelectItem T="string" Value="@nome">@nome</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string" Label="Professor(a)" @bind-Value="filtroProfessor" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    @foreach (var prof in nomeProfessores)
                    {
                        <MudSelectItem T="string" Value="@prof">@prof</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudSelect T="string" Label="Dia da Semana" @bind-Value="filtroDia" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Segunda-feira")">Segunda</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Terça-feira")">Terça</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quarta-feira")">Quarta</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quinta-feira")">Quinta</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sexta-feira")">Sexta</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sábado")">Sábado</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudSelect T="string" Label="Turno" @bind-Value="filtroTurno" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Manhã")">Manhã</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Tarde")">Tarde</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Noite")">Noite</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="Filtrar">Filtrar</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!turmasExibidas.Any())
    {
        <MudAlert Severity="Severity.Info">
            Nenhuma turma encontrada com os filtros aplicados.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasExibidas)
            {
                bool cheia = turma.QuantidadeMatriculados >= turma.LimiteAlunos;

                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100">
                        <div style="height: 5px; background: @(cheia ? "#f44336" : "#1b5e20");
                        border-radius: 8px 8px 0 0;" />
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    @turma.RitmoNome
                                </MudText>
                                <MudText Typo="Typo.caption">@turma.Nivel</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string"
                                         Color="@(cheia ? Color.Error : Color.Success)"
                                         Size="Size.Small"
                                         Variant="Variant.Filled">
                                    @(cheia ? "Lotada" : "Vagas")
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            @*
                              CORREÇÃO: era @turma.DiaSemana (string)
                              Agora: @DiaDaSemanaTexto(turma.DiaDaSemana) converte o int para string legível.
                              DiaDaSemana é int na API: 0=Domingo, 1=Segunda ... 6=Sábado.
                            *@
                            <MudText Typo="Typo.body1">
                                <b>@DiaDaSemanaTexto(turma.DiaDaSemana)</b>
                            </MudText>
                            <MudText Typo="Typo.body2">
                                @turma.HorarioInicio — @turma.HorarioFim
                            </MudText>

                            <MudText Typo="Typo.body2">
                                Prof: @(turma.NomesProfessores.FirstOrDefault() ?? "—")
                            </MudText>

                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @turma.QuantidadeMatriculados / @turma.LimiteAlunos vagas
                            </MudText>
                        </MudCardContent>
                        @{
                            // BUG-002: Bolsistas não podem se matricular em dança solo/salão nos dias obrigatórios
                            bool ehDancaRestrita = turma.Modalidade.Contains("solo", StringComparison.OrdinalIgnoreCase)
                                               || turma.Modalidade.Contains("salão", StringComparison.OrdinalIgnoreCase);
                            bool bloqueadoPorBOL04 = ehBolsista
                                && diasObrigatorios.Contains(turma.DiaDaSemana)
                                && ehDancaRestrita;
                        }
                        <MudCardActions>
                            @if (ehAluno && !cheia && !bloqueadoPorBOL04)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => SolicitarConfirmacaoMatricula(turma))">
                                    Matricular
                                </MudButton>
                            }
                            else if (ehAluno && !cheia && bloqueadoPorBOL04)
                            {
                                <MudTooltip Text="Bolsistas não podem se matricular nesta modalidade no dia obrigatório [BOL04]">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               Disabled="true">
                                        Matricular
                                    </MudButton>
                                </MudTooltip>
                            }
                            else if (ehAluno && cheia)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           FullWidth="true"
                                           OnClick="@(() => EntrarNaListaEspera(turma.IdHash))">
                                    Entrar na Fila
                                </MudButton>
                            }
                            else if (!estaLogado)
                            {
                                <MudButton Href="/login"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Entrar para matricular
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@* ══════════════════════════════════════════════════════════════
   DIALOG DE CONFIRMAÇÃO DE MATRÍCULA (Aluno / Bolsista)
══════════════════════════════════════════════════════════════ *@
<MudDialog @bind-Visible="_dialogMatriculaAberto"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.HowToReg" Class="mr-2" />
            Confirmar Matrícula
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_turmaParaConfirmar != null)
        {
            <MudText Typo="Typo.body1" Class="mb-3">
                Você está se matriculando na turma:
            </MudText>
            <MudPaper Elevation="0" Class="pa-3 mb-3 rounded-lg" Style="background:#f5f5f5;">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                    @_turmaParaConfirmar.RitmoNome — @_turmaParaConfirmar.Nivel
                </MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    📅 @DiaDaSemanaTexto(_turmaParaConfirmar.DiaDaSemana) &nbsp;·&nbsp;
                    🕐 @_turmaParaConfirmar.HorarioInicio — @_turmaParaConfirmar.HorarioFim
                </MudText>
                @if (_turmaParaConfirmar.NomesProfessores.Any())
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        👨‍🏫 @string.Join(", ", _turmaParaConfirmar.NomesProfessores)
                    </MudText>
                }
            </MudPaper>
            <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Payments">
                Esta matrícula pode alterar o valor mensal do seu plano.
                Em caso de dúvidas, consulte a recepção.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogMatriculaAberto = false)" Disabled="@_processandoMatricula">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="ConfirmarMatricula"
                   Disabled="@_processandoMatricula">
            @if (_processandoMatricula)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Confirmar matrícula
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool carregando = true;
    private bool ehAluno = false;     // Aluno, Bolsista ou Líder (pode se matricular/entrar na fila)
    private bool ehBolsista = false;  // BUG-002: controla desabilitar botão Matricular nos dias obrigatórios
    private bool estaLogado = false;
    private HashSet<int> diasObrigatorios = new(); // BUG-002: dias obrigatórios do bolsista (0=Dom..6=Sáb)

    // ── Confirmação de matrícula ─────────────────────────────────
    private TurmaDto? _turmaParaConfirmar;
    private bool _dialogMatriculaAberto = false;
    private bool _processandoMatricula = false;
    private string filtroRitmo = "Todos";
    private string filtroDia = "Todos";
    private string filtroProfessor = "Todos";
    private string filtroTurno = "Todos";

    private List<string> nomeRitmos = new();
    private List<string> nomeProfessores = new();
    private List<TurmaDto> todasTurmas = new();
    private List<TurmaDto> turmasExibidas = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            estaLogado = authState.User.Identity?.IsAuthenticated == true;
            // Aluno, Bolsista e Líder podem se matricular e entrar na fila de espera
            ehAluno = authState.User.IsInRole("Aluno") ||
                      authState.User.IsInRole("Bolsista") ||
                      authState.User.IsInRole("Líder");
            ehBolsista = authState.User.IsInRole("Bolsista");
        }

        await CarregarTurmas();

        // BUG-002: Carrega os dias obrigatórios do bolsista para desabilitar o botão Matricular
        // quando a turma cai num dia obrigatório E a modalidade é dança solo/salão.
        if (ehBolsista)
        {
            try
            {
                var desempenho = await Http.GetFromJsonAsync<BolsistaDesempenhoMinimo>(
                    "api/bolsistas/meu-desempenho");
                if (desempenho?.DiaObrigatorio1.HasValue == true)
                    diasObrigatorios.Add(desempenho.DiaObrigatorio1.Value);
                if (desempenho?.DiaObrigatorio2.HasValue == true)
                    diasObrigatorios.Add(desempenho.DiaObrigatorio2.Value);
            }
            catch
            {
                // Silencioso: se falhar, o backend ainda bloqueia via BOL04
            }
        }
    }

    private async Task CarregarTurmas()
    {
        carregando = true;
        try
        {
            var res = await Http.GetFromJsonAsync<List<TurmaDto>>("api/turmas/listar-ativas");
            todasTurmas = res ?? new();
            turmasExibidas = todasTurmas;

            // Extrai nomes únicos de ritmos para o filtro
            nomeRitmos = todasTurmas
                .Select(t => t.RitmoNome)
                .Distinct()
                .OrderBy(n => n)
                .ToList();

            // Extrai nomes únicos de professores para o filtro
            nomeProfessores = todasTurmas
                .SelectMany(t => t.NomesProfessores)
                .Distinct()
                .OrderBy(n => n)
                .ToList();
        }
        catch
        {
            Snackbar.Add("Erro ao buscar turmas. Verifique se a API está online.", Severity.Error);
        }
        finally
        {
            carregando = false;
        }
    }

    private void Filtrar()
    {
        turmasExibidas = todasTurmas
            .Where(t => filtroRitmo == "Todos" || t.RitmoNome == filtroRitmo)
            .Where(t => filtroDia == "Todos" || DiaDaSemanaTexto(t.DiaDaSemana) == filtroDia || DiaDaSemanaTexto(t.DiaDaSemana).Contains(filtroDia))
            .Where(t => filtroProfessor == "Todos" || t.NomesProfessores.Contains(filtroProfessor))
            .Where(t => filtroTurno == "Todos" || TurnoCompativel(t.HorarioInicio, filtroTurno))
            .ToList();
    }

    private bool TurnoCompativel(string horario, string turno)
    {
        if (string.IsNullOrEmpty(horario) || !TimeSpan.TryParse(horario, out var tempo)) return true;
        return turno switch
        {
            "Manhã" => tempo.Hours < 12,
            "Tarde" => tempo.Hours >= 12 && tempo.Hours < 18,
            "Noite" => tempo.Hours >= 18,
            _ => true
        };
    }

    // ── Matrícula com confirmação ────────────────────────────────
    private void SolicitarConfirmacaoMatricula(TurmaDto turma)
    {
        _turmaParaConfirmar = turma;
        _dialogMatriculaAberto = true;
    }

    private async Task ConfirmarMatricula()
    {
        if (_turmaParaConfirmar == null) return;
        _processandoMatricula = true;
        try
        {
            var payload = new { Papel = "Ambos" };
            var response = await Http.PostAsJsonAsync($"api/turmas/{_turmaParaConfirmar.IdHash}/matricular", payload);

            if (response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                Snackbar.Add(msg, Severity.Success);
                _dialogMatriculaAberto = false;
                await CarregarTurmas();
            }
            else
            {
                var erro = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Erro: {erro}", Severity.Warning);
            }
        }
        finally
        {
            _processandoMatricula = false;
        }
    }

    private async Task EntrarNaListaEspera(string turmaIdHash)
    {
        // Feature #3: usa o endpoint dedicado de lista de espera
        var response = await Http.PostAsJsonAsync($"api/turmas/{turmaIdHash}/lista-espera", new { });

        if (response.IsSuccessStatusCode)
        {
            var resultado = await response.Content.ReadFromJsonAsync<MensagemDto>();
            Snackbar.Add(resultado?.Mensagem ?? "Você entrou na fila de espera!", Severity.Info);
        }
        else
        {
            var erro = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Erro: {erro}", Severity.Warning);
        }
    }

    public class MensagemDto
    {
        public string Mensagem { get; set; } = "";
    }


    private string DiaDaSemanaTexto(int dia) => dia switch
    {
        0 => "Domingo",
        1 => "Segunda-feira",
        2 => "Terça-feira",
        3 => "Quarta-feira",
        4 => "Quinta-feira",
        5 => "Sexta-feira",
        6 => "Sábado",
        _ => "—"
    };


    public class TurmaDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string Nivel { get; set; } = "";
        public int DiaDaSemana { get; set; }
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public List<string> NomesProfessores { get; set; } = new();
        public int LimiteAlunos { get; set; }
        public int QuantidadeMatriculados { get; set; }
        // BUG-002: campo adicionado para controle de BOL04 no frontend
        public string Modalidade { get; set; } = "";
    }

    // BUG-002: DTO mínimo para carregar os dias obrigatórios do bolsista
    public class BolsistaDesempenhoMinimo
    {
        public int? DiaObrigatorio1 { get; set; }
        public int? DiaObrigatorio2 { get; set; }
    }
}