@* 
  ARQUIVO: Rascunho.Client/Pages/Turmas/QuadroTurmas.razor
  ROTA:    /quadro-turmas
  ACESSO:  Anônimo

  CORREÇÕES SPRINT 6:
  O TurmaDto local não correspondia ao ObterTurmaResponse da API:
  
  ANTES (errado)          → DEPOIS (correto)
  ─────────────────────────────────────────────────────
  DiaSemana (string)      → DiaDaSemana (int)
  ProfessorNome (string)  → NomesProfessores (List<string>)
  AlunosMatriculados      → QuantidadeMatriculados
  
  Consequência: dia da semana, professor e contagem de vagas
  apareciam sempre como vazio/zero nos cards.
*@

@page "/quadro-turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4 font-weight-bold">
        Quadro de Turmas
    </MudText>

    @* Filtros *@
    <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-lg"
              Style="border: 1px solid #e0e0e0;">
        <MudGrid>
            <MudItem xs="12" sm="5">
                <MudSelect T="string"
                           Label="Filtrar por Ritmo"
                           @bind-Value="filtroRitmo"
                           AnchorOrigin="Origin.BottomCenter"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    @foreach (var nome in nomeRitmos)
                    {
                        <MudSelectItem T="string" Value="@nome">@nome</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudSelect T="string"
                           Label="Dia da Semana"
                           @bind-Value="filtroDia"
                           AnchorOrigin="Origin.BottomCenter"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Segunda-feira")">Segunda-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Terça-feira")">Terça-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quarta-feira")">Quarta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quinta-feira")">Quinta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sexta-feira")">Sexta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sábado")">Sábado</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="Filtrar">
                    Filtrar
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!turmasExibidas.Any())
    {
        <MudAlert Severity="Severity.Info">
            Nenhuma turma encontrada com os filtros aplicados.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasExibidas)
            {
                @*
                  CORREÇÃO: era turma.AlunosMatriculados → agora turma.QuantidadeMatriculados
                  QuantidadeMatriculados é o campo correto em ObterTurmaResponse.
                *@
                bool cheia = turma.QuantidadeMatriculados >= turma.LimiteAlunos;

                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100">
                        <div style="height: 5px; background: @(cheia ? "#f44336" : "#1b5e20");
                        border-radius: 8px 8px 0 0;" />
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    @turma.RitmoNome
                                </MudText>
                                <MudText Typo="Typo.caption">@turma.Nivel</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudChip T="string"
                                         Color="@(cheia ? Color.Error : Color.Success)"
                                         Size="Size.Small"
                                         Variant="Variant.Filled">
                                    @(cheia ? "Lotada" : "Vagas")
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            @*
                              CORREÇÃO: era @turma.DiaSemana (string)
                              Agora: @DiaDaSemanaTexto(turma.DiaDaSemana) converte o int para string legível.
                              DiaDaSemana é int na API: 0=Domingo, 1=Segunda ... 6=Sábado.
                            *@
                            <MudText Typo="Typo.body1">
                                <b>@DiaDaSemanaTexto(turma.DiaDaSemana)</b>
                            </MudText>
                            <MudText Typo="Typo.body2">
                                @turma.HorarioInicio — @turma.HorarioFim
                            </MudText>

                            @*
                              CORREÇÃO: era @turma.ProfessorNome (string inexistente na API)
                              A API retorna NomesProfessores (List<string>).
                              Exibimos o primeiro da lista ou "—" se vazio.
                            *@
                            <MudText Typo="Typo.body2">
                                Prof: @(turma.NomesProfessores.FirstOrDefault() ?? "—")
                            </MudText>

                            @*
                              CORREÇÃO: era turma.AlunosMatriculados → turma.QuantidadeMatriculados
                            *@
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @turma.QuantidadeMatriculados / @turma.LimiteAlunos vagas
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            @if (ehAluno && !cheia)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => Matricular(turma.IdHash))">
                                    Matricular
                                </MudButton>
                            }
                            else if (ehAluno && cheia)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           FullWidth="true"
                                           OnClick="@(() => MarcarInteresse(turma.IdHash))">
                                    Entrar na Fila
                                </MudButton>
                            }
                            else if (!estaLogado)
                            {
                                <MudButton Href="/login"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Entrar para matricular
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool carregando = true;
    private bool ehAluno = false;
    private bool estaLogado = false;
    private string filtroRitmo = "Todos";
    private string filtroDia = "Todos";

    private List<TurmaDto> todasTurmas = new();
    private List<TurmaDto> turmasExibidas = new();
    private List<string> nomeRitmos = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            estaLogado = authState.User.Identity?.IsAuthenticated == true;
            ehAluno = authState.User.IsInRole("Aluno");
        }

        await CarregarTurmas();
    }

    private async Task CarregarTurmas()
    {
        carregando = true;
        try
        {
            var res = await Http.GetFromJsonAsync<List<TurmaDto>>("api/turmas/listar-ativas");
            todasTurmas = res ?? new();
            turmasExibidas = todasTurmas;

            // Extrai nomes únicos de ritmos para o filtro
            nomeRitmos = todasTurmas
                .Select(t => t.RitmoNome)
                .Distinct()
                .OrderBy(n => n)
                .ToList();
        }
        catch
        {
            Snackbar.Add("Erro ao buscar turmas. Verifique se a API está online.", Severity.Error);
        }
        finally { carregando = false; }
    }

    private void Filtrar()
    {
        //
        // CORREÇÃO: o filtro de dia era por turma.DiaSemana (string) que estava sempre vazio.
        // Agora convertemos turma.DiaDaSemana (int) para string com DiaDaSemanaTexto()
        // e comparamos com o filtroSelecionado.
        //
        turmasExibidas = todasTurmas
            .Where(t => filtroRitmo == "Todos" || t.RitmoNome == filtroRitmo)
            .Where(t => filtroDia == "Todos" || DiaDaSemanaTexto(t.DiaDaSemana) == filtroDia)
            .ToList();
    }

    private async Task Matricular(string turmaIdHash)
    {
        var payload = new { Papel = "Ambos" };
        var response = await Http.PostAsJsonAsync($"api/turmas/{turmaIdHash}/matricular", payload);

        if (response.IsSuccessStatusCode)
        {
            var msg = await response.Content.ReadAsStringAsync();
            Snackbar.Add(msg, Severity.Success);
            await CarregarTurmas();
        }
        else
        {
            var erro = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Erro: {erro}", Severity.Warning);
        }
    }

    private async Task MarcarInteresse(string turmaIdHash)
    {
        var payload = new { Papel = "Ambos" };
        var response = await Http.PostAsJsonAsync($"api/turmas/{turmaIdHash}/matricular", payload);
        var msg = await response.Content.ReadAsStringAsync();
        Snackbar.Add(msg, Severity.Info);
    }

    // ──────────────────────────────────────────────────────────────
    // NOVO: converte DiaDaSemana (int) para nome legível.
    // DayOfWeek C#: 0=Domingo, 1=Segunda ... 6=Sábado
    // Esse método é chamado no template e no filtro.
    // ──────────────────────────────────────────────────────────────
    private string DiaDaSemanaTexto(int dia) => dia switch
    {
        0 => "Domingo",
        1 => "Segunda-feira",
        2 => "Terça-feira",
        3 => "Quarta-feira",
        4 => "Quinta-feira",
        5 => "Sexta-feira",
        6 => "Sábado",
        _ => "—"
    };

    // ──────────────────────────────────────────────────────────────
    // DTO LOCAL — CORRIGIDO para corresponder a ObterTurmaResponse:
    //
    //  ObterTurmaResponse(
    //    IdHash, RitmoNome, SalaNome, DataInicio,
    //    DiaDaSemana (int),             ← era DiaSemana (string)
    //    HorarioInicio (TimeSpan → JSON "18:00:00"),
    //    HorarioFim    (TimeSpan → JSON "19:00:00"),
    //    Nivel,
    //    LimiteAlunos,
    //    QuantidadeMatriculados (int),  ← era AlunosMatriculados
    //    LinkWhatsApp,
    //    Ativa,
    //    NomesProfessores (List<string>) ← era ProfessorNome (string)
    //  )
    // ──────────────────────────────────────────────────────────────
    public class TurmaDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string Nivel { get; set; } = "";
        public int DiaDaSemana { get; set; }         // ← era: string DiaSemana
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public List<string> NomesProfessores { get; set; } = new();// ← era: string ProfessorNome
        public int LimiteAlunos { get; set; }
        public int QuantidadeMatriculados { get; set; }         // ← era: AlunosMatriculados
    }
}
