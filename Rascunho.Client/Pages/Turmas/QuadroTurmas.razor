@* 
  ARQUIVO: Rascunho.Client/Pages/Turmas/QuadroTurmas.razor
  
  PROBLEMA CORRIGIDO:
  O AuthorizeView dentro do foreach em um loop de items causava
  múltiplas instâncias simultâneas tentando resolver o AuthState
  antes do CascadingAuthenticationState estar propagado.
  
  SOLUÇÃO: usar AuthenticationState injetado diretamente via
  [CascadingParameter] no @code, e verificar a role localmente
  — sem AuthorizeView no template. Isso é mais performático
  e elimina a cascata de erros de AuthState.
  
  ROTA: /quadro-turmas
  ACESSO: Anônimo (visitantes veem as turmas, alunos podem matricular)
*@

@page "/quadro-turmas"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4 font-weight-bold">
        Quadro de Turmas
    </MudText>

    @* Filtros *@
    <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-lg"
              Style="border: 1px solid #e0e0e0;">
        <MudGrid>
            <MudItem xs="12" sm="5">
                <MudSelect T="string"
                           Label="Filtrar por Ritmo"
                           @bind-Value="filtroRitmo"
                           AnchorOrigin="Origin.BottomCenter"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    @foreach (var nome in nomeRitmos)
                    {
                        <MudSelectItem T="string" Value="@nome">@nome</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudSelect T="string"
                           Label="Dia da Semana"
                           @bind-Value="filtroDia"
                           AnchorOrigin="Origin.BottomCenter"
                           Variant="Variant.Outlined">
                    <MudSelectItem T="string" Value="@("Todos")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Segunda-feira")">Segunda-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Terça-feira")">Terça-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quarta-feira")">Quarta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Quinta-feira")">Quinta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sexta-feira")">Sexta-feira</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Sábado")">Sábado</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="Filtrar">
                    Filtrar
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (carregando)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!turmasExibidas.Any())
    {
        <MudAlert Severity="Severity.Info">
            Nenhuma turma encontrada com os filtros aplicados.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var turma in turmasExibidas)
            {
                bool cheia = turma.AlunosMatriculados >= turma.LimiteAlunos;

                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="3" Class="rounded-lg h-100">
                        <div style="height: 5px; background: @(cheia ? "#f44336" : "#1b5e20");
                        border-radius: 8px 8px 0 0;" />
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    @turma.RitmoNome
                                </MudText>
                                <MudText Typo="Typo.caption">@turma.Nivel</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                @*
                                  CORREÇÃO: sem AuthorizeView aqui.
                                  Usamos a variável "ehAluno" calculada no @code
                                  para evitar múltiplas instâncias de AuthorizeView
                                  dentro do foreach — causa do crash.
                                *@
                                <MudChip T="string"
                                         Color="@(cheia ? Color.Error : Color.Success)"
                                         Size="Size.Small"
                                         Variant="Variant.Filled">
                                    @(cheia ? "Lotada" : "Vagas")
                                </MudChip>
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body1">
                                <b>@turma.DiaSemana</b>
                            </MudText>
                            <MudText Typo="Typo.body2">
                                @turma.HorarioInicio — @turma.HorarioFim
                            </MudText>
                            <MudText Typo="Typo.body2">
                                Prof: @turma.ProfessorNome
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                @turma.AlunosMatriculados / @turma.LimiteAlunos vagas
                            </MudText>
                        </MudCardContent>
                        <MudCardActions>
                            @if (ehAluno && !cheia)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => Matricular(turma.IdHash))">
                                    Matricular
                                </MudButton>
                            }
                            else if (ehAluno && cheia)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           FullWidth="true"
                                           OnClick="@(() => MarcarInteresse(turma.IdHash))">
                                    Entrar na Fila
                                </MudButton>
                            }
                            else if (!estaLogado)
                            {
                                <MudButton Href="/login"
                                           Variant="Variant.Text"
                                           Color="Color.Primary">
                                    Entrar para matricular
                                </MudButton>
                            }
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    // CascadingParameter: recebe o AuthenticationState propagado pelo
    // CascadingAuthenticationState que envolve o App.razor.
    // Usando Task<AuthenticationState> ao invés de AuthorizeView no template
    // — mais eficiente e elimina o crash de múltiplas instâncias.
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool carregando = true;
    private bool ehAluno = false;
    private bool estaLogado = false;
    private string filtroRitmo = "Todos";
    private string filtroDia = "Todos";
    private List<TurmaDto> todasTurmas = new();
    private List<TurmaDto> turmasExibidas = new();
    private List<string> nomeRitmos = new();

    protected override async Task OnInitializedAsync()
    {
        // Resolve o estado de autenticação UMA vez, antes de renderizar o template
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            estaLogado = authState.User.Identity?.IsAuthenticated == true;
            ehAluno = authState.User.IsInRole("Aluno");
        }

        await CarregarTurmas();
    }

    private async Task CarregarTurmas()
    {
        carregando = true;
        try
        {
            // GET /api/turmas/listar-ativas — endpoint público da API
            var res = await Http.GetFromJsonAsync<List<TurmaDto>>("api/turmas/listar-ativas");
            todasTurmas = res ?? new();
            turmasExibidas = todasTurmas;

            // Extrai nomes únicos de ritmos para popular o filtro dinamicamente
            nomeRitmos = todasTurmas
                .Select(t => t.RitmoNome)
                .Distinct()
                .OrderBy(n => n)
                .ToList();
        }
        catch
        {
            Snackbar.Add("Erro ao buscar turmas. Verifique se a API está online.", Severity.Error);
        }
        finally { carregando = false; }
    }

    private void Filtrar()
    {
        turmasExibidas = todasTurmas
            .Where(t => filtroRitmo == "Todos" || t.RitmoNome == filtroRitmo)
            .Where(t => filtroDia == "Todos" || t.DiaSemana == filtroDia)
            .ToList();
    }

    private async Task Matricular(string turmaIdHash)
    {
        // POST /api/turmas/{idHash}/matricular
        // Se houver vaga → matrícula. Se lotada → entra na fila de espera.
        var payload = new { Papel = "Ambos" };
        var response = await Http.PostAsJsonAsync(
            $"api/turmas/{turmaIdHash}/matricular", payload);

        if (response.IsSuccessStatusCode)
        {
            var msg = await response.Content.ReadAsStringAsync();
            Snackbar.Add(msg, Severity.Success);
            await CarregarTurmas(); // Atualiza contadores
        }
        else
        {
            var erro = await response.Content.ReadAsStringAsync();
            Snackbar.Add($"Erro: {erro}", Severity.Warning);
        }
    }

    private async Task MarcarInteresse(string turmaIdHash)
    {
        var payload = new { Papel = "Ambos" };
        var response = await Http.PostAsJsonAsync(
            $"api/turmas/{turmaIdHash}/matricular", payload);

        var msg = await response.Content.ReadAsStringAsync();
        Snackbar.Add(msg, Severity.Info);
    }

    public class TurmaDto
    {
        public string IdHash { get; set; } = "";
        public string RitmoNome { get; set; } = "";
        public string Nivel { get; set; } = "";
        public string DiaSemana { get; set; } = "";
        public string HorarioInicio { get; set; } = "";
        public string HorarioFim { get; set; } = "";
        public string ProfessorNome { get; set; } = "";
        public int LimiteAlunos { get; set; }
        public int AlunosMatriculados { get; set; }
    }
}