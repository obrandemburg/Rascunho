# 1. Usando o SDK do .NET 10 para compilar o projeto
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /src

# Copiando os arquivos de projeto (Perfeito para o Cache)
COPY ["Rascunho.Client/Rascunho.Client.csproj", "Rascunho.Client/"]
COPY ["Rascunho.Shared/Rascunho.Shared.csproj", "Rascunho.Shared/"]

# Restaurando dependências
RUN dotnet restore "Rascunho.Client/Rascunho.Client.csproj"

# Copiando o resto do código
COPY . .
WORKDIR "/src/Rascunho.Client"

# Publicando a aplicação
RUN dotnet publish "Rascunho.Client.csproj" -c Release -o /app/publish

# 2. Servidor Nginx para hospedar o frontend
FROM nginx:alpine AS final
WORKDIR /usr/share/nginx/html

# Copia os arquivos compilados do Blazor
COPY --from=build /app/publish/wwwroot .

# Mantive a sua lógica de cópia segura para evitar erros 404
RUN sh -c 'cp _framework/blazor.webassembly.*.js _framework/blazor.webassembly.js' && \
    sh -c 'for file in _framework/dotnet.*.js; do case "$file" in *runtime*|*native*) ;; *) cp "$file" _framework/dotnet.js ;; esac; done'

# Copia a configuração do Nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80